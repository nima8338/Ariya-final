{% doc %}
  @prompt
    add this text, Ships within 24 hours · Free US shipping · Arrives in 3–5 days, get rid of the free shipping icon
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-shipping-info-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.spacing }}px;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    width: 100%;
    flex-wrap: wrap;
  }

  .ai-shipping-info-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 6px;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
    font-weight: {{ block.settings.font_family.weight }};
  }

  .ai-shipping-info-item-{{ ai_gen_id }} svg {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    stroke: {{ block.settings.icon_color }};
  }

  .ai-shipping-info-item-{{ ai_gen_id }}--no-icon {
    gap: 0;
  }

  .ai-shipping-info-separator-{{ ai_gen_id }} {
    color: {{ block.settings.separator_color }};
    font-size: {{ block.settings.font_size }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-shipping-info-{{ ai_gen_id }} {
      gap: {{ block.settings.spacing | times: 0.8 }}px;
      padding: {{ block.settings.padding | times: 0.8 }}px;
    }

    .ai-shipping-info-item-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }

    .ai-shipping-info-item-{{ ai_gen_id }} svg {
      width: {{ block.settings.icon_size | times: 0.9 }}px;
      height: {{ block.settings.icon_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-shipping-info-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.show_fast_shipping %}
    <div class="ai-shipping-info-item-{{ ai_gen_id }}">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M16 3h5v5M4 20L21 3M21 16v5h-5M15 15l6 6M4 4l5 5"/>
      </svg>
      <span>{{ block.settings.fast_shipping_text }}</span>
    </div>
  {% endif %}

  {% if block.settings.show_fast_shipping and block.settings.show_free_shipping %}
    <span class="ai-shipping-info-separator-{{ ai_gen_id }}">{{ block.settings.separator }}</span>
  {% endif %}

  {% if block.settings.show_free_shipping %}
    <div class="ai-shipping-info-item-{{ ai_gen_id }} ai-shipping-info-item-{{ ai_gen_id }}--no-icon">
      <span>{{ block.settings.free_shipping_text }}</span>
    </div>
  {% endif %}

  {% if block.settings.show_free_shipping and block.settings.show_delivery_time %}
    <span class="ai-shipping-info-separator-{{ ai_gen_id }}">{{ block.settings.separator }}</span>
  {% endif %}

  {% if block.settings.show_delivery_time %}
    <div class="ai-shipping-info-item-{{ ai_gen_id }}">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"></circle>
        <polyline points="12 6 12 12 16 14"></polyline>
      </svg>
      <span>{{ block.settings.delivery_time_text }}</span>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Shipping information",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "checkbox",
      "id": "show_fast_shipping",
      "label": "Show fast shipping",
      "default": true
    },
    {
      "type": "text",
      "id": "fast_shipping_text",
      "label": "Fast shipping text",
      "default": "Ships within 24 hours"
    },
    {
      "type": "checkbox",
      "id": "show_free_shipping",
      "label": "Show free shipping",
      "default": true
    },
    {
      "type": "text",
      "id": "free_shipping_text",
      "label": "Free shipping text",
      "default": "Free US shipping"
    },
    {
      "type": "checkbox",
      "id": "show_delivery_time",
      "label": "Show delivery time",
      "default": true
    },
    {
      "type": "text",
      "id": "delivery_time_text",
      "label": "Delivery time text",
      "default": "Arrives in 3–5 days"
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Separator",
      "default": "·"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f9f6ff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#3c0e66"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon",
      "default": "#3c0e66"
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Separator",
      "default": "#c99cf1"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 12,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "font_picker",
      "id": "font_family",
      "label": "Font",
      "default": "libre_baskerville_n4"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 30,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Spacing between items",
      "min": 4,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Shipping information"
    }
  ]
}
{% endschema %}
