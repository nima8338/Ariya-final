{% schema %}
{
  "name": "Ingredient spotlight",
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "section_title",
      "label": "Title",
      "default": "Inside Calm Nights"
    },
