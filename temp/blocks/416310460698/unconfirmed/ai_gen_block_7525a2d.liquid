{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-ingredient-spotlight-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_top }}px 0 {{ block.settings.section_padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-ingredient-spotlight__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-ingredient-spotlight__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-ingredient-spotlight__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-ingredient-spotlight__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-ingredient-spotlight__grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: {{ block.settings.card_gap_mobile }}px;
  }

  .ai-ingredient-spotlight__card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    box-shadow: {{ block.settings.card_shadow_x }}px {{ block.settings.card_shadow_y }}px {{ block.settings.card_shadow_blur }}px {{ block.settings.card_shadow_color }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .ai-ingredient-spotlight__card-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    margin-bottom: 16px;
    overflow: visible;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-ingredient-spotlight__card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-ingredient-spotlight__card-content-{{ ai_gen_id }} {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .ai-ingredient-spotlight__card-badge-{{ ai_gen_id }} {
    display: inline-block;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    font-size: {{ block.settings.badge_font_size }}px;
    padding: 4px 12px;
    border-radius: 20px;
    margin-bottom: 8px;
    font-weight: 500;
    width: fit-content;
  }

  .ai-ingredient-spotlight__card-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_title_size }}px;
    color: {{ block.settings.card_title_color }};
    margin: 0 0 8px;
    font-weight: 600;
  }

  .ai-ingredient-spotlight__card-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.card_description_size }}px;
    color: {{ block.settings.card_description_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-ingredient-spotlight__card-{{ ai_gen_id }}.ai-ingredient-spotlight__card--tart-cherry-{{ ai_gen_id }} {
    grid-column: 1 / -1;
  }

  @media screen and (min-width: 750px) {
    .ai-ingredient-spotlight__grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(4, 1fr);
      gap: {{ block.settings.card_gap_desktop }}px;
    }

    .ai-ingredient-spotlight__card-{{ ai_gen_id }}.ai-ingredient-spotlight__card--l-theanine-{{ ai_gen_id }} {
      grid-column: 1;
      grid-row: 1;
    }

    .ai-ingredient-spotlight__card-{{ ai_gen_id }}.ai-ingredient-spotlight__card--lemon-balm-{{ ai_gen_id }} {
      grid-column: 2;
      grid-row: 1;
    }

    .ai-ingredient-spotlight__card-{{ ai_gen_id }}.ai-ingredient-spotlight__card--chamomile-{{ ai_gen_id }} {
      grid-column: 3;
      grid-row: 1;
    }

    .ai-ingredient-spotlight__card-{{ ai_gen_id }}.ai-ingredient-spotlight__card--magnolia-{{ ai_gen_id }} {
      grid-column: 4;
      grid-row: 1;
    }

    .ai-ingredient-spotlight__card-{{ ai_gen_id }}.ai-ingredient-spotlight__card--l-tryptophan-{{ ai_gen_id }} {
      grid-column: 1 / 2;
      grid-row: 2;
    }

    .ai-ingredient-spotlight__card-{{ ai_gen_id }}.ai-ingredient-spotlight__card--vitamin-b6-{{ ai_gen_id }} {
      grid-column: 2 / 3;
      grid-row: 2;
    }

    .ai-ingredient-spotlight__card-{{ ai_gen_id }}.ai-ingredient-spotlight__card--tart-cherry-{{ ai_gen_id }} {
      grid-column: 3 / 4;
      grid-row: 2;
    }

    .ai-ingredient-spotlight__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 1.5 }}px;
    }

    .ai-ingredient-spotlight__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 1.2 }}px;
    }
  }
{% endstyle %}

<div class="ai-ingredient-spotlight-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
