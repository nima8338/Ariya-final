{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-badges-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-founder-text-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.founder_text_size }}px;
    line-height: 1.4;
    margin-bottom: {{ block.settings.founder_text_margin }}px;
    font-weight: 600;
  }

  .ai-founder-text-question-{{ ai_gen_id }} {
    color: {{ block.settings.question_color }};
    display: block;
  }

  .ai-founder-text-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: underline;
    display: block;
  }

  .ai-founder-text-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-trust-badges-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.gap }}px;
    max-width: 100%;
  }

  .ai-trust-badge-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: {{ block.settings.icon_text_gap }}px;
  }

  .ai-trust-badge-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-trust-badge-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-trust-badge-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color }};
    fill: none;
    stroke-width: {{ block.settings.icon_stroke_width }};
  }

  .ai-trust-badge-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.3;
    color: {{ block.settings.text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-founder-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.founder_text_size_mobile }}px;
    }

    .ai-trust-badges-container-{{ ai_gen_id }} {
      gap: {{ block.settings.gap_mobile }}px;
    }

    .ai-trust-badge-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_mobile }}px;
      height: {{ block.settings.icon_size_mobile }}px;
    }

    .ai-trust-badge-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-trust-badges-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.show_founder_text %}
    <div class="ai-founder-text-{{ ai_gen_id }}">
      <span class="ai-founder-text-question-{{ ai_gen_id }}">{{ block.settings.question_text }}</span>
      <a 
        href="sms:{{ block.settings.phone_number }}" 
        class="ai-founder-text-link-{{ ai_gen_id }}"
      >
        {{ block.settings.link_text }}
      </a>
    </div>
  {% endif %}

  <div class="ai-trust-badges-container-{{ ai_gen_id }}">
    <div class="ai-trust-badge-item-{{ ai_gen_id }}">
      <div class="ai-trust-badge-icon-{{ ai_gen_id }}">
        {% if block.settings.image_1 != blank %}
          <img
            src="{{ block.settings.image_1 | image_url: width: 200 }}"
            alt="{{ block.settings.text_1 | escape }}"
            loading="lazy"
            width="{{ block.settings.icon_size }}"
            height="{{ block.settings.icon_size }}"
          >
        {% elsif block.settings.icon_1 != blank %}
          {{ block.settings.icon_1 }}
        {% else %}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
            <polyline points="9 12 11 14 15 10"></polyline>
          </svg>
        {% endif %}
      </div>
      <div class="ai-trust-badge-text-{{ ai_gen_id }}">{{ block.settings.text_1 }}</div>
    </div>

    <div class="ai-trust-badge-item-{{ ai_gen_id }}">
      <div class="ai-trust-badge-icon-{{ ai_gen_id }}">
        {% if block.settings.image_2 != blank %}
          <img
            src="{{ block.settings.image_2 | image_url: width: 200 }}"
            alt="{{ block.settings.text_2 | escape }}"
            loading="lazy"
            width="{{ block.settings.icon_size }}"
            height="{{ block.settings.icon_size }}"
          >
        {% elsif block.settings.icon_2 != blank %}
          {{ block.settings.icon_2 }}
        {% else %}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
            <path d="M12 2C8.5 2 6 4.5 6 8c0 4.5 6 11 6 11s6-6.5 6-11c0-3.5-2.5-6-6-6z"></path>
            <path d="M12 11c-1.1 0-2-.9-2-2s.9-2 2-2 2 .9 2 2-.9 2-2 2z"></path>
            <path d="M8 8c0-2.2 1.8-4 4-4"></path>
          </svg>
        {% endif %}
      </div>
      <div class="ai-trust-badge-text-{{ ai_gen_id }}">{{ block.settings.text_2 }}</div>
    </div>

    <div class="ai-trust-badge-item-{{ ai_gen_id }}">
      <div class="ai-trust-badge-icon-{{ ai_gen_id }}">
        {% if block.settings.image_3 != blank %}
          <img
            src="{{ block.settings.image_3 | image_url: width: 200 }}"
            alt="{{ block.settings.text_3 | escape }}"
            loading="lazy"
            width="{{ block.settings.icon_size }}"
            height="{{ block.settings.icon_size }}"
          >
        {% elsif block.settings.icon_3 != blank %}
          {{ block.settings.icon_3 }}
        {% else %}
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
            <rect x="1" y="3" width="15" height="13"></rect>
            <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
            <circle cx="5.5" cy="18.5" r="2.5"></circle>
            <circle cx="18.5" cy="18.5" r="2.5"></circle>
          </svg>
        {% endif %}
      </div>
      <div class="ai-trust-badge-text-{{ ai_gen_id }}">{{ block.settings.text_3 }}</div>
    </div>
  </div>
</div>

