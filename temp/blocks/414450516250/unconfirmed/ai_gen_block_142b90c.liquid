{% doc %}
  @prompt
    Create a new FAQ accordion section for Ariya Supplements’ Calm Nights product.
    
    Section Title:
    Frequently Asked Questions
    
    Supporting Text:
    Everything you need to know before your first night.
    
    Design Requirements:
    
    Mobile-first design
    White background
    Ariya purple accents (#4B1D7A or existing site purple)
    Clean typography
    Large touch-friendly accordion rows
    Smooth expand/collapse animation
    One accordion open by default
    Minimal, premium wellness aesthetic
    Consistent width and alignment with the rest of the product page
    Fully centered on desktop and mobile
    Slightly smaller overall heading size than the current FAQ section
    Reduce vertical spacing above and below the section for a cleaner layout
    Accordion 1 (Open by Default)
    Can Calm Nights Help You?
    
    If any of these sound familiar, Calm Nights was designed for you:
    
    ✓ Racing thoughts at bedtime
    
    ✓ Stress keeping you awake
    
    ✓ Taking too long to fall asleep
    
    ✓ Waking up during the night
    
    ✓ Waking up tired
    
    ✓ Looking for sleep support without melatonin
    
    Accordion 2
    How Does Calm Nights Work?
    
    Calm Nights combines amino acids, botanical extracts, and sleep-support nutrients that help calm a racing mind, support natural sleep pathways, and promote deeper overnight recovery without melatonin.
    
    Accordion 3
    What’s Inside Calm Nights?
    
    L-Theanine, L-Tryptophan, Lemon Balm Extract, Chamomile Extract, Tart Cherry Extract, Magnolia Bark Extract, and Vitamin B6.
    
    Every ingredient and dosage is fully disclosed.
    
    No proprietary blends.
    
    Accordion 4
    How To Use
    
    Take 2 capsules 30–60 minutes before bed.
    
    For best results, use consistently as part of a healthy nighttime routine.
    
    Accordion 5
    Quality & Transparency
    
    Fully disclosed dosages.
    
    Manufactured in an FDA-registered facility following NSF GMP standards.
    
    No proprietary blends.
    
    No hidden doses.
    
    Goal:
    Create a clean, premium FAQ section that is easy to scan, builds trust, and matches the overall Ariya website design.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-faq-accordion-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
  }

  .ai-faq-accordion-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-faq-accordion-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing }}px;
  }

  .ai-faq-accordion-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_margin }}px;
    font-weight: 600;
    line-height: 1.2;
  }

  .ai-faq-accordion-subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.subtext_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-faq-accordion-items-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_spacing }}px;
  }

  .ai-faq-accordion-item-{{ ai_gen_id }} {
    border: 1px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.item_background }};
  }

  .ai-faq-accordion-question-{{ ai_gen_id }} {
    width: 100%;
    padding: {{ block.settings.question_padding }}px;
    background: none;
    border: none;
    text-align: left;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    font-size: {{ block.settings.question_size }}px;
    font-weight: 600;
    color: {{ block.settings.question_color }};
    transition: background-color 0.3s ease;
  }

  .ai-faq-accordion-question-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.question_hover_bg }};
  }

  .ai-faq-accordion-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    transition: transform 0.3s ease;
    color: {{ block.settings.accent_color }};
  }

  .ai-faq-accordion-item-{{ ai_gen_id }}.active .ai-faq-accordion-icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-faq-accordion-answer-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s ease, padding 0.4s ease;
    padding: 0 {{ block.settings.question_padding }}px;
  }

  .ai-faq-accordion-item-{{ ai_gen_id }}.active .ai-faq-accordion-answer-{{ ai_gen_id }} {
    max-height: 1000px;
    padding: 0 {{ block.settings.question_padding }}px {{ block.settings.question_padding }}px;
  }

  .ai-faq-accordion-answer-content-{{ ai_gen_id }} {
    font-size: {{ block.settings.answer_size }}px;
    color: {{ block.settings.answer_color }};
    line-height: 1.6;
  }

  .ai-faq-accordion-answer-content-{{ ai_gen_id }} p {
    margin: 0 0 12px;
  }

  .ai-faq-accordion-answer-content-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-faq-accordion-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.75 }}px;
    }

    .ai-faq-accordion-subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size | times: 0.9 }}px;
    }

    .ai-faq-accordion-question-{{ ai_gen_id }} {
      font-size: {{ block.settings.question_size | times: 0.9 }}px;
      padding: {{ block.settings.question_padding | times: 0.8 }}px;
    }

    .ai-faq-accordion-answer-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.question_padding | times: 0.8 }}px;
    }

    .ai-faq-accordion-item-{{ ai_gen_id }}.active .ai-faq-accordion-answer-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.question_padding | times: 0.8 }}px {{ block.settings.question_padding | times: 0.8 }}px;
    }

    .ai-faq-accordion-answer-content-{{ ai_gen_id }} {
      font-size: {{ block.settings.answer_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<faq-accordion-{{ ai_gen_id }} class="ai-faq-accordion-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-faq-accordion-container-{{ ai_gen_id }}">
    {% if block.settings.title != blank or block.settings.subtext != blank %}
      <div class="ai-faq-accordion-header-{{ ai_gen_id }}">
        {% if block.settings.title != blank %}
          <h2 class="ai-faq-accordion-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
        {% endif %}
        {% if block.settings.subtext != blank %}
          <p class="ai-faq-accordion-subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-faq-accordion-items-{{ ai_gen_id }}">
      {% for i in (1..5) %}
        {% liquid
          assign question_key = 'question_' | append: i
          assign answer_key = 'answer_' | append: i
          assign open_key = 'open_' | append: i
          
          assign question = block.settings[question_key]
          assign answer = block.settings[answer_key]
          assign is_open = block.settings[open_key]
        %}

        {% if question != blank and answer != blank %}
          <div class="ai-faq-accordion-item-{{ ai_gen_id }} {% if is_open %}active{% endif %}" data-faq-item>
            <button 
              class="ai-faq-accordion-question-{{ ai_gen_id }}" 
              aria-expanded="{% if is_open %}true{% else %}false{% endif %}"
              data-faq-button
            >
              <span>{{ question }}</span>
              <svg class="ai-faq-accordion-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"></polyline>
              </svg>
            </button>
            <div class="ai-faq-accordion-answer-{{ ai_gen_id }}" data-faq-answer>
              <div class="ai-faq-accordion-answer-content-{{ ai_gen_id }}">
                {{ answer }}
              </div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</faq-accordion-{{ ai_gen_id }}>

<script>
  (function() {
    class FaqAccordion{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.items = this.querySelectorAll('[data-faq-item]');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.items.forEach((item) => {
          const button = item.querySelector('[data-faq-button]');
          
          button.addEventListener('click', () => {
            const isActive = item.classList.contains('active');
            
            if (isActive) {
              item.classList.remove('active');
              button.setAttribute('aria-expanded', 'false');
            } else {
              item.classList.add('active');
              button.setAttribute('aria-expanded', 'true');
            }
          });
        });
      }
    }

    customElements.define('faq-accordion-{{ ai_gen_id }}', FaqAccordion{{ ai_gen_id }});
  })();
</script>

