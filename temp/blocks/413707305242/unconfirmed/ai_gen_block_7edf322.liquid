    <div class="ai-sleep-stats-cta-{{ ai_gen_id }}">
      {% if block.settings.cta_headline != blank %}
        <h3 class="ai-sleep-stats-cta-headline-{{ ai_gen_id }}">{{ block.settings.cta_headline }}</h3>
      {% endif %}

      {% if block.settings.cta_body != blank %}
        <p class="ai-sleep-stats-cta-body-{{ ai_gen_id }}">{{ block.settings.cta_body }}</p>
      {% endif %}

      {% if block.settings.button_label != blank %}
