{% schema %}
{
  "name": "Sleep statistics",
  "settings": [
    {
      "type": "header",
      "content": "Section headline"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Your Brain Wasn't Designed For Modern Life."
    },
    {
      "type": "color",
      "id": "headline_color",
      "label": "Color",
      "default": "#1a0a2e"
    },
    {
      "type": "range",
      "id": "headline_size_mobile",
      "label": "Mobile size",
      "min": 20,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "headline_size_desktop",
      "label": "Desktop size",
      "min": 24,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "headline_spacing_mobile",
      "label": "Mobile spacing",
      "min": 12,
      "max": 48,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "headline_spacing_desktop",
      "label": "Desktop spacing",
      "min": 16,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Supporting text"
    },
    {
      "type": "text",
      "id": "supporting_text",
      "label": "Text",
      "default": "Late-night scrolling. Constant notifications. Endless stimulation."
    },
    {
      "type": "color",
      "id": "supporting_color",
      "label": "Color",
      "default": "#6b5a85"
    },
    {
      "type": "range",
      "id": "supporting_size_mobile",
      "label": "Mobile size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "supporting_size_desktop",
      "label": "Desktop size",
      "min": 14,
      "max": 28,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "supporting_spacing_mobile",
      "label": "Mobile spacing",
      "min": 24,
      "max": 64,
      "step": 4,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "supporting_spacing_desktop",
      "label": "Desktop spacing",
      "min": 32,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "header",
      "content": "Statistic 1"
    },
    {
      "type": "text",
      "id": "stat_1_number",
      "label": "Number",
      "default": "48%"
    },
    {
      "type": "text",
      "id": "stat_1_text",
      "label": "Text",
      "default": "of U.S. adults report lying awake at night due to stress."
    },
    {
      "type": "header",
      "content": "Statistic 2"
    },
    {
      "type": "text",
      "id": "stat_2_number",
      "label": "Number",
      "default": "1 in 3"
    },
    {
      "type": "text",
      "id": "stat_2_text",
      "label": "Text",
      "default": "adults don't get enough sleep on a regular basis."
    },
    {
      "type": "header",
      "content": "Statistic 3"
    },
    {
      "type": "text",
      "id": "stat_3_number",
      "label": "Number",
      "default": "50–70 Million"
    },
    {
      "type": "text",
      "id": "stat_3_text",
      "label": "Text",
      "default": "Americans struggle with chronic sleep issues."
    },
    {
      "type": "header",
