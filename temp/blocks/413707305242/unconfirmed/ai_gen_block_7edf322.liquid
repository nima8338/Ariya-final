          <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
          <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
        </svg>
        <div class="ai-sleep-stats-number-{{ ai_gen_id }}">{{ block.settings.stat_2_number }}</div>
        <p class="ai-sleep-stats-text-{{ ai_gen_id }}">{{ block.settings.stat_2_text }}</p>
      </div>

      <div class="ai-sleep-stats-card-{{ ai_gen_id }}">
        <svg class="ai-sleep-stats-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
        </svg>
        <div class="ai-sleep-stats-number-{{ ai_gen_id }}">{{ block.settings.stat_3_number }}</div>
        <p class="ai-sleep-stats-text-{{ ai_gen_id }}">{{ block.settings.stat_3_text }}</p>
