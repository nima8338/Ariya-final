            <div class="ai-ingredient-spotlight__card-left-{{ ai_gen_id }}">
              <div
                class="ai-ingredient-spotlight__icon-{{ ai_gen_id }}"
                style="background-color: {{ block.settings.ingredient_7_color }};"
              >
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="5"/>
                  <line x1="12" y1="1" x2="12" y2="3"/>
                  <line x1="12" y1="21" x2="12" y2="23"/>
                  <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
                  <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
                  <line x1="1" y1="12" x2="3" y2="12"/>
                  <line x1="21" y1="12" x2="23" y2="12"/>
                  <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
                  <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
                </svg>
              </div>
              <div class="ai-ingredient-spotlight__card-title-wrapper-{{ ai_gen_id }}">
                <h3 class="ai-ingredient-spotlight__ingredient-name-{{ ai_gen_id }}">
                  {{ block.settings.ingredient_7_name }}
                </h3>
                <p
                  class="ai-ingredient-spotlight__benefit-title-{{ ai_gen_id }}"
                  style="color: {{ block.settings.ingredient_7_color }};"
                >
                  {{ block.settings.ingredient_7_benefit }}
                </p>
              </div>
            </div>
            <svg
              class="ai-ingredient-spotlight__chevron-{{ ai_gen_id }}"
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </div>
          <div class="ai-ingredient-spotlight__card-content-{{ ai_gen_id }}">
            <p class="ai-ingredient-spotlight__description-{{ ai_gen_id }}">
              {{ block.settings.ingredient_7_description }}
            </p>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</ingredient-spotlight-{{ ai_gen_id }}>

<script>
  (function() {
    class IngredientSpotlight{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-ingredient-spotlight__card-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.cards.forEach((card) => {
          const header = card.querySelector('.ai-ingredient-spotlight__card-header-{{ ai_gen_id }}');
          
          header.addEventListener('click', () => {
            const isActive = card.classList.contains('active');
            
            if (isActive) {
              card.classList.remove('active');
            } else {
              card.classList.add('active');
            }
          });
        });
      }
    }

    customElements.define('ingredient-spotlight-{{ ai_gen_id }}', IngredientSpotlight{{ ai_gen_id }});
  })();
</script>

