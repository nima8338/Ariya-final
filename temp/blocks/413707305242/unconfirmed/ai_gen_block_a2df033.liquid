<script>
  (function() {
    class IngredientSpotlight{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-ingredient-spotlight__card-{{ ai_gen_id }}');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.cards.forEach((card) => {
          const header = card.querySelector('.ai-ingredient-spotlight__card-header-{{ ai_gen_id }}');
          
          header.addEventListener('click', () => {
            const isActive = card.classList.contains('active');
            
            if (isActive) {
              card.classList.remove('active');
            } else {
              card.classList.add('active');
            }
          });
        });
      }
    }

    customElements.define('ingredient-spotlight-{{ ai_gen_id }}', IngredientSpotlight{{ ai_gen_id }});
  })();
</script>

