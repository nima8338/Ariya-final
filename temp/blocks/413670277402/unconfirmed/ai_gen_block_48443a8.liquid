{% doc %}
  @prompt
    Create a premium mobile-first comparison section titled:
    
    “Why Ariya Is Different”
    
    Subheadline:
    
    Most sleep supplements are designed to sell. Calm Nights was designed to work.
    
    Design Requirements:
    
    Clean luxury wellness aesthetic
    Ariya purple branding
    Rounded corners
    Mobile-first layout
    High contrast and easy readability
    Minimalistic design with plenty of white space
    Create a two-column comparison: “Calm Nights” vs “Other Brands”
    Use green checkmarks for Ariya
    Use muted gray or soft red X icons for Other Brands
    Keep the section compact and highly scannable
    Make this feel like a premium supplement brand, not an Amazon listing
    Comparison Rows:
    
    ✓ Fully Disclosed Doses
    ✗ Proprietary Blends
    
    ✓ Standardized Plant Extracts
    ✗ Non-Standardized Ingredients
    
    ✓ Melatonin-Free Formula
    ✗ Melatonin-Based Formulas
    
    ✓ Wake Up Refreshed
    ✗ Morning Grogginess For Some Users
    
    Design Notes:
    
    The four comparison rows should be the visual focus.
    Keep text short and easy to scan.
    Avoid large paragraphs.
    Add subtle shadows and rounded cards.
    Use a premium comparison table style similar to high-converting DTC wellness brands.
    Optimize specifically for mobile viewing.
    The section should feel trustworthy, clean, and modern.
    Make Ariya’s side visually stronger and slightly more prominent than the Other Brands side.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-comparison-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-comparison-container-{{ ai_gen_id }} {
    max-width: 600px;
    margin: 0 auto;
  }

  .ai-comparison-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 32px;
  }

  .ai-comparison-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 700;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px 0;
    line-height: 1.2;
  }

  .ai-comparison-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-comparison-table-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    box-shadow: 0 4px 12px rgba(26, 10, 46, 0.08);
  }

  .ai-comparison-row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 1px solid {{ block.settings.divider_color }};
  }

  .ai-comparison-row-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-comparison-cell-{{ ai_gen_id }} {
    padding: 20px 16px;
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.4;
  }

  .ai-comparison-cell-{{ ai_gen_id }}--ariya {
    background-color: {{ block.settings.ariya_bg_color }};
    color: {{ block.settings.ariya_text_color }};
    font-weight: 600;
  }

  .ai-comparison-cell-{{ ai_gen_id }}--other {
    background-color: {{ block.settings.other_bg_color }};
    color: {{ block.settings.other_text_color }};
  }

  .ai-comparison-icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-comparison-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-comparison-text-{{ ai_gen_id }} {
    flex: 1;
  }

  @media screen and (max-width: 749px) {
    .ai-comparison-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-comparison-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }

    .ai-comparison-cell-{{ ai_gen_id }} {
      padding: 16px 12px;
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }

    .ai-comparison-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.85 }}px;
      height: {{ block.settings.icon_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<div class="ai-comparison-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-comparison-container-{{ ai_gen_id }}">
    <div class="ai-comparison-header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-comparison-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <p class="ai-comparison-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="ai-comparison-table-{{ ai_gen_id }}">
      {% if block.settings.row_1_ariya != blank or block.settings.row_1_other != blank %}
        <div class="ai-comparison-row-{{ ai_gen_id }}">
          <div class="ai-comparison-cell-{{ ai_gen_id }} ai-comparison-cell-{{ ai_gen_id }}--ariya">
            <div class="ai-comparison-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.check_color }}" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <div class="ai-comparison-text-{{ ai_gen_id }}">{{ block.settings.row_1_ariya }}</div>
          </div>
          <div class="ai-comparison-cell-{{ ai_gen_id }} ai-comparison-cell-{{ ai_gen_id }}--other">
            <div class="ai-comparison-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.x_color }}" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </div>
            <div class="ai-comparison-text-{{ ai_gen_id }}">{{ block.settings.row_1_other }}</div>
          </div>
        </div>
      {% endif %}

      {% if block.settings.row_2_ariya != blank or block.settings.row_2_other != blank %}
        <div class="ai-comparison-row-{{ ai_gen_id }}">
          <div class="ai-comparison-cell-{{ ai_gen_id }} ai-comparison-cell-{{ ai_gen_id }}--ariya">
            <div class="ai-comparison-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.check_color }}" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <div class="ai-comparison-text-{{ ai_gen_id }}">{{ block.settings.row_2_ariya }}</div>
          </div>
          <div class="ai-comparison-cell-{{ ai_gen_id }} ai-comparison-cell-{{ ai_gen_id }}--other">
            <div class="ai-comparison-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.x_color }}" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </div>
            <div class="ai-comparison-text-{{ ai_gen_id }}">{{ block.settings.row_2_other }}</div>
          </div>
        </div>
      {% endif %}

      {% if block.settings.row_3_ariya != blank or block.settings.row_3_other != blank %}
        <div class="ai-comparison-row-{{ ai_gen_id }}">
          <div class="ai-comparison-cell-{{ ai_gen_id }} ai-comparison-cell-{{ ai_gen_id }}--ariya">
            <div class="ai-comparison-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.check_color }}" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <div class="ai-comparison-text-{{ ai_gen_id }}">{{ block.settings.row_3_ariya }}</div>
          </div>
          <div class="ai-comparison-cell-{{ ai_gen_id }} ai-comparison-cell-{{ ai_gen_id }}--other">
            <div class="ai-comparison-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.x_color }}" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </div>
            <div class="ai-comparison-text-{{ ai_gen_id }}">{{ block.settings.row_3_other }}</div>
          </div>
        </div>
      {% endif %}

      {% if block.settings.row_4_ariya != blank or block.settings.row_4_other != blank %}
        <div class="ai-comparison-row-{{ ai_gen_id }}">
          <div class="ai-comparison-cell-{{ ai_gen_id }} ai-comparison-cell-{{ ai_gen_id }}--ariya">
            <div class="ai-comparison-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.check_color }}" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <div class="ai-comparison-text-{{ ai_gen_id }}">{{ block.settings.row_4_ariya }}</div>
          </div>
          <div class="ai-comparison-cell-{{ ai_gen_id }} ai-comparison-cell-{{ ai_gen_id }}--other">
            <div class="ai-comparison-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="{{ block.settings.x_color }}" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            </div>
            <div class="ai-comparison-text-{{ ai_gen_id }}">{{ block.settings.row_4_other }}</div>
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

