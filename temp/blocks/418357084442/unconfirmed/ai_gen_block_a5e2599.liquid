{% doc %}
  @prompt
    Create a Shopify video testimonial carousel section.
    
    Place it directly below the Hero Section and above the written reviews section.
    
    Section title:
    Real People. Real Results.
    
    Supporting text:
    Hear directly from people who have made Calm Nights part of their nightly routine.
    
    MOST IMPORTANT FUNCTIONAL REQUIREMENT:
    Each testimonial card must use a real HTML video element, not just an image with a fake play button.
    
    Each card must have:
    
    1. Uploaded Shopify video file setting
    2. Optional thumbnail/poster image setting
    3. Editable badge label
    4. Editable customer name
    5. Editable review text
    6. Optional star rating toggle
    
    The uploaded video file must be the actual playable video source.
    
    The thumbnail image must only be used as the video poster image before playback. It must not replace the video, cover the video, or block clicks.
    
    Use the thumbnail/poster image as the video poster attribute.
    
    When the customer taps the video or play button:
    
    * the video must play inside the same card
    * the poster/thumbnail should disappear
    * the play button should disappear
    * the video should show controls or use a working custom play button
    
    Do not create a decorative play button. The play button must trigger the video.
    
    Do not require pasted video links. Allow videos to be selected from Shopify uploaded files.
    
    Carousel requirements:
    
    * Horizontal swipe carousel
    * Swipe left and right on mobile
    * Left/right arrows on desktop
    * Support at least 4 testimonial videos
    * Show one main video centered with the next and previous videos partially visible
    * Smooth scrolling animation
    
    Card design:
    
    * Vertical TikTok/Reel style video format
    * Rounded corners
    * Soft shadow
    * White card background
    * Consistent video sizing
    * Premium wellness aesthetic
    * Ariya purple accents
    * Black text
    * Mobile-first layout
    
    Create placeholders for:
    Video 1
    Video 2
    Video 3
    Video 4
    
    Badge examples:
    BENEFITS
    SLEEP QUALITY
    FALL ASLEEP FASTER
    WAKE UP REFRESHED
    
    Review examples:
    ★★★★★ Sarah M.
    "Best sleep I've had in years."
    
    ★★★★★ Jake T.
    "Finally waking up refreshed."
    
    The final section should feel like a premium wellness brand video testimonial carousel and must allow visitors to watch customer videos directly on the product page without leaving the page.,  for the desktop and mobile lets make the video boxes smaller they are too vertically big,  create an animation where the videos are moving left and when it goes out the screen the videos loop back around, make it when a video is pressed the video enlarges so the viewer can see it better 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-testimonials-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 60px 20px;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .ai-video-testimonials__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-video-testimonials__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 48px;
  }

  .ai-video-testimonials__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px;
    font-weight: 600;
  }

  .ai-video-testimonials__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-video-testimonials__carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  .ai-video-testimonials__carousel-track-{{ ai_gen_id }} {
    display: flex;
    gap: 24px;
    width: fit-content;
    animation: ai-scroll-{{ ai_gen_id }} {{ block.settings.animation_speed }}s linear infinite;
  }

  .ai-video-testimonials__carousel-track-{{ ai_gen_id }}.paused {
    animation-play-state: paused;
  }

  .ai-video-testimonials__carousel-{{ ai_gen_id }} {
    display: flex;
    gap: 24px;
  }

  @keyframes ai-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .ai-video-testimonials__card-{{ ai_gen_id }} {
    flex: 0 0 240px;
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    box-shadow: 0 4px 12px rgba(26, 10, 46, 0.1);
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-video-testimonials__card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(26, 10, 46, 0.15);
  }

  .ai-video-testimonials__video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 12;
    background: #f9f6ff;
    overflow: hidden;
    cursor: pointer;
  }

  .ai-video-testimonials__video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-video-testimonials__play-button-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 56px;
    height: 56px;
    background: {{ block.settings.play_button_color }};
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease, opacity 0.2s ease;
    z-index: 2;
  }

  .ai-video-testimonials__play-button-{{ ai_gen_id }}:hover {
    transform: translate(-50%, -50%) scale(1.1);
  }

  .ai-video-testimonials__play-button-{{ ai_gen_id }}.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .ai-video-testimonials__play-icon-{{ ai_gen_id }} {
    width: 0;
    height: 0;
    border-left: 18px solid {{ block.settings.play_icon_color }};
    border-top: 11px solid transparent;
    border-bottom: 11px solid transparent;
    margin-left: 3px;
  }

  .ai-video-testimonials__badge-{{ ai_gen_id }} {
    position: absolute;
    top: 12px;
    left: 12px;
    background: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 4px 10px;
    border-radius: 16px;
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    z-index: 1;
  }

  .ai-video-testimonials__content-{{ ai_gen_id }} {
    padding: 16px;
  }

  .ai-video-testimonials__stars-{{ ai_gen_id }} {
    display: flex;
    gap: 3px;
    margin-bottom: 8px;
  }

  .ai-video-testimonials__star-{{ ai_gen_id }} {
    color: {{ block.settings.star_color }};
    font-size: 14px;
  }

  .ai-video-testimonials__name-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 6px;
  }

  .ai-video-testimonials__review-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    line-height: 1.4;
    margin: 0;
  }

  .ai-video-testimonials__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #f9f6ff;
    color: #6b5a85;
    font-size: 12px;
    text-align: center;
    padding: 16px;
  }

  .ai-video-testimonials__modal-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(26, 10, 46, 0.95);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .ai-video-testimonials__modal-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
  }

  .ai-video-testimonials__modal-content-{{ ai_gen_id }} {
    position: relative;
    width: 90%;
    max-width: 500px;
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transform: scale(0.9);
    transition: transform 0.3s ease;
  }

  .ai-video-testimonials__modal-{{ ai_gen_id }}.active .ai-video-testimonials__modal-content-{{ ai_gen_id }} {
    transform: scale(1);
  }

  .ai-video-testimonials__modal-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 16;
    background: #000000;
  }

  .ai-video-testimonials__modal-video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .ai-video-testimonials__modal-close-{{ ai_gen_id }} {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 40px;
    height: 40px;
    background: rgba(0, 0, 0, 0.7);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: background 0.2s ease;
  }

  .ai-video-testimonials__modal-close-{{ ai_gen_id }}:hover {
    background: rgba(0, 0, 0, 0.9);
  }

  .ai-video-testimonials__modal-close-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    position: relative;
  }

  .ai-video-testimonials__modal-close-icon-{{ ai_gen_id }}::before,
  .ai-video-testimonials__modal-close-icon-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 20px;
    height: 2px;
    background: #ffffff;
  }

  .ai-video-testimonials__modal-close-icon-{{ ai_gen_id }}::before {
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .ai-video-testimonials__modal-close-icon-{{ ai_gen_id }}::after {
    transform: translate(-50%, -50%) rotate(-45deg);
  }

  .ai-video-testimonials__modal-info-{{ ai_gen_id }} {
    padding: 20px;
  }

  .ai-video-testimonials__modal-badge-{{ ai_gen_id }} {
    display: inline-block;
    background: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: 16px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
  }

  .ai-video-testimonials__modal-stars-{{ ai_gen_id }} {
    display: flex;
    gap: 4px;
    margin-bottom: 10px;
  }

  .ai-video-testimonials__modal-star-{{ ai_gen_id }} {
    color: {{ block.settings.star_color }};
    font-size: 16px;
  }

  .ai-video-testimonials__modal-name-{{ ai_gen_id }} {
    font-size: 18px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px;
  }

  .ai-video-testimonials__modal-review-{{ ai_gen_id }} {
    font-size: 15px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    line-height: 1.5;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-video-testimonials-{{ ai_gen_id }} {
      padding: 40px 16px;
    }

    .ai-video-testimonials__card-{{ ai_gen_id }} {
      flex: 0 0 200px;
    }

    .ai-video-testimonials__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-video-testimonials__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }

    .ai-video-testimonials__play-button-{{ ai_gen_id }} {
      width: 48px;
      height: 48px;
    }

    .ai-video-testimonials__play-icon-{{ ai_gen_id }} {
      border-left: 15px solid {{ block.settings.play_icon_color }};
      border-top: 9px solid transparent;
      border-bottom: 9px solid transparent;
    }

    .ai-video-testimonials__modal-content-{{ ai_gen_id }} {
      max-width: 95%;
    }
  }
{% endstyle %}

<video-testimonials-{{ ai_gen_id }}
  class="ai-video-testimonials-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-video-1="{{ block.settings.video_1.sources | map: 'url' | join: '|' }}"
  data-badge-1="{{ block.settings.badge_1 }}"
  data-name-1="{{ block.settings.name_1 }}"
  data-review-1="{{ block.settings.review_1 }}"
  data-stars-1="{{ block.settings.show_stars_1 }}"
  data-video-2="{{ block.settings.video_2.sources | map: 'url' | join: '|' }}"
  data-badge-2="{{ block.settings.badge_2 }}"
  data-name-2="{{ block.settings.name_2 }}"
  data-review-2="{{ block.settings.review_2 }}"
  data-stars-2="{{ block.settings.show_stars_2 }}"
  data-video-3="{{ block.settings.video_3.sources | map: 'url' | join: '|' }}"
  data-badge-3="{{ block.settings.badge_3 }}"
  data-name-3="{{ block.settings.name_3 }}"
  data-review-3="{{ block.settings.review_3 }}"
  data-stars-3="{{ block.settings.show_stars_3 }}"
  data-video-4="{{ block.settings.video_4.sources | map: 'url' | join: '|' }}"
  data-badge-4="{{ block.settings.badge_4 }}"
  data-name-4="{{ block.settings.name_4 }}"
  data-review-4="{{ block.settings.review_4 }}"
  data-stars-4="{{ block.settings.show_stars_4 }}"
>
  <div class="ai-video-testimonials__container-{{ ai_gen_id }}">
    <div class="ai-video-testimonials__header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-video-testimonials__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <p class="ai-video-testimonials__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="ai-video-testimonials__carousel-wrapper-{{ ai_gen_id }}">
      <div class="ai-video-testimonials__carousel-track-{{ ai_gen_id }}">
        <div class="ai-video-testimonials__carousel-{{ ai_gen_id }}">
          {% for i in (1..4) %}
            {% liquid
              assign video_key = 'video_' | append: i
              assign poster_key = 'poster_' | append: i
              assign badge_key = 'badge_' | append: i
              assign name_key = 'name_' | append: i
              assign review_key = 'review_' | append: i
              assign show_stars_key = 'show_stars_' | append: i

              assign video = block.settings[video_key]
              assign poster = block.settings[poster_key]
              assign badge = block.settings[badge_key]
              assign name = block.settings[name_key]
              assign review = block.settings[review_key]
              assign show_stars = block.settings[show_stars_key]
            %}

            <div class="ai-video-testimonials__card-{{ ai_gen_id }}">
              <div 
                class="ai-video-testimonials__video-wrapper-{{ ai_gen_id }}"
                data-video-trigger="{{ i }}"
              >
                {% if badge != blank %}
                  <div class="ai-video-testimonials__badge-{{ ai_gen_id }}">{{ badge }}</div>
                {% endif %}

                {% if video != blank %}
                  <video
                    class="ai-video-testimonials__video-{{ ai_gen_id }}"
                    {% if poster != blank %}
                      poster="{{ poster | image_url: width: 640 }}"
                    {% endif %}
                    preload="metadata"
                    playsinline
                    data-video-index="{{ i }}"
                  >
                    {% for source in video.sources %}
                      <source src="{{ source.url }}" type="{{ source.mime_type }}">
                    {% endfor %}
                  </video>

                  <button
                    class="ai-video-testimonials__play-button-{{ ai_gen_id }}"
                    aria-label="Play video"
                    data-play-button="{{ i }}"
                  >
                    <div class="ai-video-testimonials__play-icon-{{ ai_gen_id }}"></div>
                  </button>
                {% else %}
                  <div class="ai-video-testimonials__placeholder-{{ ai_gen_id }}">
                    Upload a video for testimonial {{ i }}
                  </div>
                {% endif %}
              </div>

              <div class="ai-video-testimonials__content-{{ ai_gen_id }}">
                {% if show_stars %}
                  <div class="ai-video-testimonials__stars-{{ ai_gen_id }}">
                    {% for star in (1..5) %}
                      <span class="ai-video-testimonials__star-{{ ai_gen_id }}">★</span>
                    {% endfor %}
                  </div>
                {% endif %}

                {% if name != blank %}
                  <h3 class="ai-video-testimonials__name-{{ ai_gen_id }}">{{ name }}</h3>
                {% endif %}

                {% if review != blank %}
                  <p class="ai-video-testimonials__review-{{ ai_gen_id }}">{{ review }}</p>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>

        <div class="ai-video-testimonials__carousel-{{ ai_gen_id }}" aria-hidden="true">
          {% for i in (1..4) %}
            {% liquid
              assign video_key = 'video_' | append: i
              assign poster_key = 'poster_' | append: i
              assign badge_key = 'badge_' | append: i
              assign name_key = 'name_' | append: i
              assign review_key = 'review_' | append: i
              assign show_stars_key = 'show_stars_' | append: i

              assign video = block.settings[video_key]
              assign poster = block.settings[poster_key]
              assign badge = block.settings[badge_key]
              assign name = block.settings[name_key]
              assign review = block.settings[review_key]
              assign show_stars = block.settings[show_stars_key]
            %}

            <div class="ai-video-testimonials__card-{{ ai_gen_id }}">
              <div 
                class="ai-video-testimonials__video-wrapper-{{ ai_gen_id }}"
                data-video-trigger="{{ i }}-clone"
              >
                {% if badge != blank %}
                  <div class="ai-video-testimonials__badge-{{ ai_gen_id }}">{{ badge }}</div>
                {% endif %}

                {% if video != blank %}
                  <video
                    class="ai-video-testimonials__video-{{ ai_gen_id }}"
                    {% if poster != blank %}
                      poster="{{ poster | image_url: width: 640 }}"
                    {% endif %}
                    preload="metadata"
                    playsinline
                    data-video-index="{{ i }}-clone"
                  >
                    {% for source in video.sources %}
                      <source src="{{ source.url }}" type="{{ source.mime_type }}">
                    {% endfor %}
                  </video>

                  <button
                    class="ai-video-testimonials__play-button-{{ ai_gen_id }}"
                    aria-label="Play video"
                    data-play-button="{{ i }}-clone"
                  >
                    <div class="ai-video-testimonials__play-icon-{{ ai_gen_id }}"></div>
                  </button>
                {% else %}
                  <div class="ai-video-testimonials__placeholder-{{ ai_gen_id }}">
                    Upload a video for testimonial {{ i }}
                  </div>
                {% endif %}
              </div>

              <div class="ai-video-testimonials__content-{{ ai_gen_id }}">
                {% if show_stars %}
                  <div class="ai-video-testimonials__stars-{{ ai_gen_id }}">
                    {% for star in (1..5) %}
                      <span class="ai-video-testimonials__star-{{ ai_gen_id }}">★</span>
                    {% endfor %}
                  </div>
                {% endif %}

                {% if name != blank %}
                  <h3 class="ai-video-testimonials__name-{{ ai_gen_id }}">{{ name }}</h3>
                {% endif %}

                {% if review != blank %}
                  <p class="ai-video-testimonials__review-{{ ai_gen_id }}">{{ review }}</p>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>

  <div class="ai-video-testimonials__modal-{{ ai_gen_id }}" data-modal>
    <div class="ai-video-testimonials__modal-content-{{ ai_gen_id }}">
      <div class="ai-video-testimonials__modal-video-wrapper-{{ ai_gen_id }}">
        <button 
          class="ai-video-testimonials__modal-close-{{ ai_gen_id }}"
          aria-label="Close video"
          data-modal-close
        >
          <div class="ai-video-testimonials__modal-close-icon-{{ ai_gen_id }}"></div>
        </button>
        <video
          class="ai-video-testimonials__modal-video-{{ ai_gen_id }}"
          controls
          playsinline
          data-modal-video
        ></video>
      </div>
      <div class="ai-video-testimonials__modal-info-{{ ai_gen_id }}">
        <div class="ai-video-testimonials__modal-badge-{{ ai_gen_id }}" data-modal-badge></div>
        <div class="ai-video-testimonials__modal-stars-{{ ai_gen_id }}" data-modal-stars></div>
        <h3 class="ai-video-testimonials__modal-name-{{ ai_gen_id }}" data-modal-name></h3>
        <p class="ai-video-testimonials__modal-review-{{ ai_gen_id }}" data-modal-review></p>
      </div>
    </div>
  </div>
</video-testimonials-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoTestimonials{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.track = this.querySelector('.ai-video-testimonials__carousel-track-{{ ai_gen_id }}');
        this.videoTriggers = this.querySelectorAll('[data-video-trigger]');
        this.modal = this.querySelector('[data-modal]');
        this.modalVideo = this.querySelector('[data-modal-video]');
        this.modalClose = this.querySelector('[data-modal-close]');
        this.modalBadge = this.querySelector('[data-modal-badge]');
        this.modalStars = this.querySelector('[data-modal-stars]');
        this.modalName = this.querySelector('[data-modal-name]');
        this.modalReview = this.querySelector('[data-modal-review]');
      }

      connectedCallback() {
        this.setupVideoTriggers();
        this.setupModalClose();
        this.setupHoverPause();
      }

      setupVideoTriggers() {
        this.videoTriggers.forEach((trigger) => {
          trigger.addEventListener('click', (e) => {
            const index = trigger.getAttribute('data-video-trigger').replace('-clone', '');
            this.openModal(index);
          });
        });
      }

      openModal(index) {
        const videoUrls = this.getAttribute('data-video-' + index);
        const badge = this.getAttribute('data-badge-' + index);
        const name = this.getAttribute('data-name-' + index);
        const review = this.getAttribute('data-review-' + index);
        const showStars = this.getAttribute('data-stars-' + index) === 'true';
        
        if (!videoUrls) return;

        this.pauseAnimation();
        
        this.modalVideo.innerHTML = '';
        const urls = videoUrls.split('|');
        urls.forEach(url => {
          if (url) {
            const sourceEl = document.createElement('source');
            sourceEl.src = url;
            this.modalVideo.appendChild(sourceEl);
          }
        });

        if (badge) {
          this.modalBadge.textContent = badge;
          this.modalBadge.style.display = 'inline-block';
        } else {
          this.modalBadge.style.display = 'none';
        }

        if (showStars) {
          this.modalStars.innerHTML = '★★★★★'.split('').map(star => 
            '<span class="ai-video-testimonials__modal-star-{{ ai_gen_id }}">' + star + '</span>'
          ).join('');
          this.modalStars.style.display = 'flex';
        } else {
          this.modalStars.style.display = 'none';
        }

        this.modalName.textContent = name || '';
        this.modalReview.textContent = review || '';

        this.modal.classList.add('active');
        document.body.style.overflow = 'hidden';
        
        this.modalVideo.load();
        this.modalVideo.play();
      }

      setupModalClose() {
        this.modalClose.addEventListener('click', () => {
          this.closeModal();
        });

        this.modal.addEventListener('click', (e) => {
          if (e.target === this.modal) {
            this.closeModal();
          }
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && this.modal.classList.contains('active')) {
            this.closeModal();
          }
        });
      }

      closeModal() {
        this.modal.classList.remove('active');
        document.body.style.overflow = '';
        this.modalVideo.pause();
        this.modalVideo.currentTime = 0;
        this.resumeAnimation();
      }

      setupHoverPause() {
        this.track.addEventListener('mouseenter', () => {
          if (!this.modal.classList.contains('active')) {
            this.pauseAnimation();
          }
        });

        this.track.addEventListener('mouseleave', () => {
          if (!this.modal.classList.contains('active')) {
            this.resumeAnimation();
          }
        });
      }

      pauseAnimation() {
        this.track.classList.add('paused');
      }

      resumeAnimation() {
        this.track.classList.remove('paused');
      }
    }

    customElements.define('video-testimonials-{{ ai_gen_id }}', VideoTestimonials{{ ai_gen_id }});
  })();
</script>

