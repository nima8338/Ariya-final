{% doc %}
  @prompt
    Create a Customizable Founder Support & Trust Badge Block
    
    Create a custom Shopify section that sits directly below the Start Now / Add to Cart button on the Calm Nights product page.
    
    The section should contain two parts:
    
    Founder Support
    
    Place this at the top of the section.
    
    Display exactly:
    
    Line 1:
    Questions before ordering?
    
    Line 2:
    (720) 590-7295
    
    Founder Support Styling
    Center align everything.
    Make both lines bold and easy to read.
    Use black for Line 1.
    Use Ariya Purple #7D45C6 for the phone number.
    Make the phone number clickable.
    Clicking it should open:
    tel:[BUSINESS PHONE NUMBER] on desktop/mobile.
    Add a setting that lets me underline the first line.
    Add a separate setting that lets me underline the phone number.
    Add a slider to control the phone number font size independently from the first line.
    Add a slider for the first line font size.
    Add a setting to adjust the spacing between the founder support text and the trust badges.
    Do not use a button.
    Do not use a colored background.
    Do not use a border.
    Keep the design minimal and clean.
    Trust Badge Row
    
    Place this directly underneath the founder support text.
    
    Create three equal-width columns.
    
    Each column should contain:
    
    Custom uploaded image
    Badge text underneath
    
    I want to upload my own icons/images instead of using built-in icons.
    
    The three default badge texts should be:
    
    30-Day Money-Back Guarantee
    Vegan & Non-GMO
    Free Shipping
    Trust Badge Requirements
    Center align each badge.
    Display the uploaded image above the text.
    Make all uploaded images the same size.
    Keep the images noticeably large and easy to see.
    Keep all three badges evenly spaced.
    Use Ariya Purple #7D45C6 for the badge text.
    Prevent badge text from wrapping whenever possible so each badge stays on a single line.
    The entire row should remain responsive on desktop and mobile.
    Section Customization Options
    Founder Support
    First line text
    Phone number
    First line font size (desktop)
    First line font size (mobile)
    Phone number font size (desktop)
    Phone number font size (mobile)
    First line font weight
    Phone number font weight
    Underline first line (toggle)
    Underline phone number (toggle)
    Text color (first line)
    Phone number color
    Space below founder support
    Badge Settings
    Badge 1 image upload
    Badge 1 text
    Badge 2 image upload
    Badge 2 text
    Badge 3 image upload
    Badge 3 text
    Badge Design Settings
    Text size (desktop)
    Text size (mobile)
    Badge font weight
    Icon size (desktop)
    Icon size (mobile)
    Icon to text spacing
    Badge spacing (desktop)
    Badge spacing (mobile)
    Background color
    Top padding
    Bottom padding
    Side padding
    Desktop width
    Overall Design
    
    The final section should feel premium, clean, and modern, matching the Ariya brand. Keep the layout compact, mobile-first, and conversion-focused with balanced spacing and consistent alignment throughout.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-founder-trust-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.top_padding }}px {{ block.settings.side_padding }}px {{ block.settings.bottom_padding }}px;
  }

  .ai-founder-trust__founder-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.founder_spacing }}px;
  }

  .ai-founder-trust__question-{{ ai_gen_id }} {
    font-size: {{ block.settings.question_font_size_desktop }}px;
    font-weight: {{ block.settings.question_font_weight }};
    color: {{ block.settings.question_color }};
    margin: 0 0 8px 0;
    {% if block.settings.underline_question %}
      text-decoration: underline;
    {% endif %}
  }

  .ai-founder-trust__phone-link-{{ ai_gen_id }} {
    display: inline-block;
    font-size: {{ block.settings.phone_font_size_desktop }}px;
    font-weight: {{ block.settings.phone_font_weight }};
    color: {{ block.settings.phone_color }};
    text-decoration: none;
    {% if block.settings.underline_phone %}
      text-decoration: underline;
    {% endif %}
  }

  .ai-founder-trust__phone-link-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-founder-trust__badges-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.badge_spacing_desktop }}px;
    align-items: start;
  }

  .ai-founder-trust__badge-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: {{ block.settings.icon_text_spacing }}px;
  }

  .ai-founder-trust__badge-image-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size_desktop }}px;
    height: {{ block.settings.icon_size_desktop }}px;
    flex-shrink: 0;
  }

  .ai-founder-trust__badge-image-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-founder-trust__badge-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
  }

  .ai-founder-trust__badge-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-founder-trust__badge-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.badge_text_size_desktop }}px;
    font-weight: {{ block.settings.badge_font_weight }};
    color: {{ block.settings.badge_text_color }};
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  @media screen and (max-width: 749px) {
    .ai-founder-trust__question-{{ ai_gen_id }} {
      font-size: {{ block.settings.question_font_size_mobile }}px;
    }

    .ai-founder-trust__phone-link-{{ ai_gen_id }} {
      font-size: {{ block.settings.phone_font_size_mobile }}px;
    }

    .ai-founder-trust__badges-{{ ai_gen_id }} {
      gap: {{ block.settings.badge_spacing_mobile }}px;
    }

    .ai-founder-trust__badge-image-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_mobile }}px;
      height: {{ block.settings.icon_size_mobile }}px;
    }

    .ai-founder-trust__badge-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.badge_text_size_mobile }}px;
      white-space: normal;
    }
  }
{% endstyle %}

<founder-trust-{{ ai_gen_id }} class="ai-founder-trust-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-founder-trust__founder-{{ ai_gen_id }}">
    {% if block.settings.question_text != blank %}
      <div class="ai-founder-trust__question-{{ ai_gen_id }}">
        {{ block.settings.question_text }}
      </div>
    {% endif %}
    {% if block.settings.phone_number != blank %}
      <a href="tel:{{ block.settings.phone_number }}" class="ai-founder-trust__phone-link-{{ ai_gen_id }}">
        {{ block.settings.phone_number }}
      </a>
    {% endif %}
  </div>

  <div class="ai-founder-trust__badges-{{ ai_gen_id }}">
    <div class="ai-founder-trust__badge-{{ ai_gen_id }}">
      <div class="ai-founder-trust__badge-image-{{ ai_gen_id }}">
        {% if block.settings.badge_1_image %}
          <img
            src="{{ block.settings.badge_1_image | image_url: width: 200 }}"
            alt="{{ block.settings.badge_1_text | escape }}"
            loading="lazy"
            width="200"
            height="200"
          >
        {% else %}
          <div class="ai-founder-trust__badge-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
      {% if block.settings.badge_1_text != blank %}
        <div class="ai-founder-trust__badge-text-{{ ai_gen_id }}">
          {{ block.settings.badge_1_text }}
        </div>
      {% endif %}
    </div>

    <div class="ai-founder-trust__badge-{{ ai_gen_id }}">
      <div class="ai-founder-trust__badge-image-{{ ai_gen_id }}">
        {% if block.settings.badge_2_image %}
          <img
            src="{{ block.settings.badge_2_image | image_url: width: 200 }}"
            alt="{{ block.settings.badge_2_text | escape }}"
            loading="lazy"
            width="200"
            height="200"
          >
        {% else %}
          <div class="ai-founder-trust__badge-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
      {% if block.settings.badge_2_text != blank %}
        <div class="ai-founder-trust__badge-text-{{ ai_gen_id }}">
          {{ block.settings.badge_2_text }}
        </div>
      {% endif %}
    </div>

    <div class="ai-founder-trust__badge-{{ ai_gen_id }}">
      <div class="ai-founder-trust__badge-image-{{ ai_gen_id }}">
        {% if block.settings.badge_3_image %}
          <img
            src="{{ block.settings.badge_3_image | image_url: width: 200 }}"
            alt="{{ block.settings.badge_3_text | escape }}"
            loading="lazy"
            width="200"
            height="200"
          >
        {% else %}
          <div class="ai-founder-trust__badge-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
      {% if block.settings.badge_3_text != blank %}
        <div class="ai-founder-trust__badge-text-{{ ai_gen_id }}">
          {{ block.settings.badge_3_text }}
        </div>
      {% endif %}
    </div>
  </div>
</founder-trust-{{ ai_gen_id }}>

<script>
  (function() {
    class FounderTrust{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('founder-trust-{{ ai_gen_id }}', FounderTrust{{ ai_gen_id }});
  })();
</script>

