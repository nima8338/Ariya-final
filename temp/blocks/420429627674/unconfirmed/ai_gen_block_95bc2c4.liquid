{% doc %}
  @prompt
    Create a customizable founder-support and trust-badge block for the Calm Nights product page.
    
    Founder-support text
    
    Place this centered above the trust badges using exactly two lines:
    
    Line 1: Questions before ordering?
    Line 2: Text the founders directly →
    
    Styling:
    
    Make both lines larger and bold enough to stand out clearly.
    Use black for the first line.
    Use Ariya purple #7D45C6 for the second line.
    Underline the entire second line.
    Make the second line clickable and open a new text message using sms:[BUSINESS PHONE NUMBER].
    Do not display the phone number in the visible text.
    Do not use a button, icon, border, or colored background around the founder-support text.
    Keep the spacing compact, with a small gap between the founder text and the trust badges.
    
    Trust-badge row
    
    Under the founder-support text, create a clean three-column trust-badge row on a white background.
    
    Badge 1:
    
    Text: 30-Day Money-Back Guarantee
    
    Badge 2:
    
    Text: Vegan & Non-GMO
    
    Badge 3:
    
    Text: Free Shipping
    
    For each badge:
    
    Add an image-upload setting so I can insert my own icon or symbol.
    Display the uploaded icon above the text.
    Make the uploaded icons noticeably larger and easy to see.
    Keep all three icon images the same size.
    Center-align the icon and text.
    Use Ariya purple #7D45C6 for the badge text.
    Keep the text clean, readable, and evenly spaced.
    
    Keep all three badges side by side in three equal-width columns on mobile and desktop. Make the entire block responsive, balanced, and compact without crowding the text or icons., for the line 2 text ive inserted the number there so they can visually click it have only the number underlined, make the business phone number appear next to line 2 text, make sure the line 2 text and business phone number stay in the same line , get rid of line 2
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-founder-trust-block-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px;
    text-align: center;
  }

  .ai-founder-support-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.founder_badge_gap }}px;
  }

  .ai-founder-line-1-{{ ai_gen_id }} {
    font-size: {{ block.settings.founder_font_size }}px;
    font-weight: {{ block.settings.founder_font_weight }};
    color: {{ block.settings.line_1_color }};
    margin: 0;
    line-height: 1.2;
  }

  .ai-founder-phone-link-{{ ai_gen_id }} {
    font-size: {{ block.settings.founder_font_size }}px;
    font-weight: {{ block.settings.founder_font_weight }};
    color: {{ block.settings.line_2_color }};
    text-decoration: underline;
    margin: 0;
    line-height: 1.2;
    display: inline-block;
    white-space: nowrap;
  }

  .ai-founder-phone-link-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-trust-badges-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.badge_gap }}px;
    align-items: start;
  }

  .ai-trust-badge-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: {{ block.settings.icon_text_gap }}px;
  }

  .ai-trust-badge-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-trust-badge-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-trust-badge-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.badge_font_size }}px;
    color: {{ block.settings.badge_text_color }};
    line-height: 1.3;
    font-weight: {{ block.settings.badge_font_weight }};
  }

  @media screen and (max-width: 749px) {
    .ai-trust-badges-{{ ai_gen_id }} {
      gap: {{ block.settings.badge_gap_mobile }}px;
    }

    .ai-trust-badge-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_mobile }}px;
      height: {{ block.settings.icon_size_mobile }}px;
    }

    .ai-founder-line-1-{{ ai_gen_id }},
    .ai-founder-phone-link-{{ ai_gen_id }} {
      font-size: {{ block.settings.founder_font_size_mobile }}px;
    }

    .ai-trust-badge-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.badge_font_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-founder-trust-block-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-founder-support-{{ ai_gen_id }}">
    <div class="ai-founder-line-1-{{ ai_gen_id }}">
      {{ block.settings.line_1_text }}
    </div>
    <a href="sms:{{ block.settings.business_phone }}" class="ai-founder-phone-link-{{ ai_gen_id }}">
      {{ block.settings.business_phone }}
    </a>
  </div>

  <div class="ai-trust-badges-{{ ai_gen_id }}">
    <div class="ai-trust-badge-{{ ai_gen_id }}">
      {% if block.settings.badge_1_icon %}
        <div class="ai-trust-badge-icon-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.badge_1_icon | image_url: width: 200 }}"
            alt="{{ block.settings.badge_1_text }}"
            loading="lazy"
            width="200"
            height="200"
          >
        </div>
      {% endif %}
      <div class="ai-trust-badge-text-{{ ai_gen_id }}">
        {{ block.settings.badge_1_text }}
      </div>
    </div>

    <div class="ai-trust-badge-{{ ai_gen_id }}">
      {% if block.settings.badge_2_icon %}
        <div class="ai-trust-badge-icon-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.badge_2_icon | image_url: width: 200 }}"
            alt="{{ block.settings.badge_2_text }}"
            loading="lazy"
            width="200"
            height="200"
          >
        </div>
      {% endif %}
      <div class="ai-trust-badge-text-{{ ai_gen_id }}">
        {{ block.settings.badge_2_text }}
      </div>
    </div>

    <div class="ai-trust-badge-{{ ai_gen_id }}">
      {% if block.settings.badge_3_icon %}
        <div class="ai-trust-badge-icon-{{ ai_gen_id }}">
          <img
            src="{{ block.settings.badge_3_icon | image_url: width: 200 }}"
            alt="{{ block.settings.badge_3_text }}"
            loading="lazy"
            width="200"
            height="200"
          >
        </div>
      {% endif %}
      <div class="ai-trust-badge-text-{{ ai_gen_id }}">
        {{ block.settings.badge_3_text }}
      </div>
    </div>
  </div>
</div>

