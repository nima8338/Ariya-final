<script>
  (function() {
    class VideoTestimonialsCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.carousel = null;
        this.prevButton = null;
        this.nextButton = null;
        this.scrollAmount = 0;
      }

      connectedCallback() {
        this.carousel = this.querySelector('[data-carousel]');
        this.prevButton = this.querySelector('[data-direction="prev"]');
        this.nextButton = this.querySelector('[data-direction="next"]');

        if (!this.carousel || !this.prevButton || !this.nextButton) return;

        this.setupEventListeners();
        this.updateButtonStates();
      }

      setupEventListeners() {
        this.prevButton.addEventListener('click', () => this.scroll('prev'));
        this.nextButton.addEventListener('click', () => this.scroll('next'));
        this.carousel.addEventListener('scroll', () => this.updateButtonStates());

        let isDown = false;
        let startX;
        let scrollLeft;

        this.carousel.addEventListener('mousedown', (e) => {
          isDown = true;
          this.carousel.style.cursor = 'grabbing';
          startX = e.pageX - this.carousel.offsetLeft;
          scrollLeft = this.carousel.scrollLeft;
        });

        this.carousel.addEventListener('mouseleave', () => {
          isDown = false;
          this.carousel.style.cursor = 'grab';
        });

        this.carousel.addEventListener('mouseup', () => {
          isDown = false;
          this.carousel.style.cursor = 'grab';
        });

        this.carousel.addEventListener('mousemove', (e) => {
          if (!isDown) return;
          e.preventDefault();
          const x = e.pageX - this.carousel.offsetLeft;
          const walk = (x - startX) * 2;
          this.carousel.scrollLeft = scrollLeft - walk;
        });
      }

      scroll(direction) {
        const cardWidth = this.carousel.querySelector('.ai-video-testimonial-card-{{ ai_gen_id }}').offsetWidth;
        const gap = 20;
        const scrollDistance = cardWidth + gap;

        if (direction === 'next') {
          this.carousel.scrollLeft += scrollDistance;
        } else {
          this.carousel.scrollLeft -= scrollDistance;
        }
      }

      updateButtonStates() {
        const maxScroll = this.carousel.scrollWidth - this.carousel.clientWidth;
        const currentScroll = this.carousel.scrollLeft;

        this.prevButton.disabled = currentScroll <= 0;
        this.nextButton.disabled = currentScroll >= maxScroll - 1;
      }
    }

    customElements.define('video-testimonials-carousel-{{ ai_gen_id }}', VideoTestimonialsCarousel{{ ai_gen_id }});
  })();
</script>

