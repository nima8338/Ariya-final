<script>
  (function() {
    class CalmNightsStats{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const button = this.querySelector('[data-scroll-to-top]');
        if (button) {
          button.addEventListener('click', this.scrollToTop.bind(this));
        }
      }

      scrollToTop(event) {
        event.preventDefault();
        window.scrollTo({
          top: 0,
          behavior: 'smooth'
        });
      }
    }

    customElements.define('calm-nights-stats-{{ ai_gen_id }}', CalmNightsStats{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Calm Nights statistics",
  "settings": [
    {
      "type": "header",
      "content": "Hero image"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Image"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Image border radius",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Main headline"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Your Brain Wasn't Designed For Modern Life."
    },
    {
      "type": "range",
      "id": "headline_size",
      "label": "Headline size",
      "min": 24,
      "max": 72,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "color",
      "id": "headline_color",
      "label": "Headline color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Supporting text"
    },
    {
      "type": "text",
      "id": "supporting_text",
      "label": "Supporting text",
      "default": "Late-night scrolling. Constant notifications. Endless stimulation."
    },
    {
