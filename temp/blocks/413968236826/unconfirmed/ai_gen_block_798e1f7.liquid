{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-stats-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 60px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-stats-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .ai-stats-hero-image-{{ ai_gen_id }} {
    margin-bottom: 40px;
  }

  .ai-stats-hero-image-{{ ai_gen_id }} img {
    width: 100%;
    max-width: 800px;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    margin: 0 auto;
    display: block;
  }

  .ai-stats-hero-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    max-width: 800px;
    height: 400px;
    margin: 0 auto;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-stats-hero-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
    opacity: 0.3;
  }

  .ai-stats-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    font-weight: 700;
    color: {{ block.settings.headline_color }};
    margin: 0 0 20px 0;
    line-height: 1.2;
    letter-spacing: -0.02em;
  }

  .ai-stats-subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.subtext_color }};
    margin: 0 0 50px 0;
    line-height: 1.6;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-stats-cards-wrapper-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    margin-bottom: 40px;
    max-width: 1100px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-stats-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: 40px 30px;
    box-shadow: {{ block.settings.card_shadow }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-stats-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(60, 14, 102, 0.12);
  }

  .ai-stats-icon-{{ ai_gen_id }} {
    width: 48px;
    height: 48px;
    margin: 0 auto 20px;
    color: {{ block.settings.icon_color }};
  }

  .ai-stats-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-stats-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.stat_number_size }}px;
    font-weight: 700;
    color: {{ block.settings.stat_number_color }};
    margin: 0 0 12px 0;
    line-height: 1.1;
  }

  .ai-stats-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.stat_text_size }}px;
    color: {{ block.settings.stat_text_color }};
    line-height: 1.5;
    margin: 0;
  }

  .ai-stats-transition-{{ ai_gen_id }} {
    font-size: {{ block.settings.transition_text_size }}px;
    color: {{ block.settings.transition_text_color }};
    margin: 0 0 50px 0;
    line-height: 1.6;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-stats-cta-section-{{ ai_gen_id }} {
    background-color: {{ block.settings.cta_background }};
    border-radius: {{ block.settings.cta_border_radius }}px;
    padding: 50px 40px;
    max-width: 900px;
    margin: 0 auto;
  }

  .ai-stats-cta-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.cta_headline_size }}px;
    font-weight: 700;
    color: {{ block.settings.cta_headline_color }};
    margin: 0 0 20px 0;
    line-height: 1.3;
  }

  .ai-stats-cta-body-{{ ai_gen_id }} {
    font-size: {{ block.settings.cta_body_size }}px;
    color: {{ block.settings.cta_body_color }};
    margin: 0 0 30px 0;
    line-height: 1.6;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-stats-cta-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 16px 40px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
    margin-bottom: 30px;
  }

  .ai-stats-cta-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(60, 14, 102, 0.2);
  }

  .ai-stats-benefits-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    max-width: 500px;
    margin: 0 auto;
  }

  .ai-stats-benefit-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
  }

  .ai-stats-benefit-icon-{{ ai_gen_id }} {
    width: 32px;
    height: 32px;
    color: {{ block.settings.benefit_icon_color }};
  }

  .ai-stats-benefit-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-stats-benefit-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.benefit_text_size }}px;
    color: {{ block.settings.benefit_text_color }};
    margin: 0;
    text-align: center;
  }

  @media screen and (max-width: 768px) {
    .ai-stats-section-{{ ai_gen_id }} {
      padding: 40px 16px;
    }

    .ai-stats-hero-image-placeholder-{{ ai_gen_id }} {
      height: 250px;
    }

    .ai-stats-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.6 }}px;
      margin-bottom: 16px;
    }

    .ai-stats-subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size | times: 0.9 }}px;
      margin-bottom: 30px;
    }

    .ai-stats-cards-wrapper-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 20px;
      margin-bottom: 30px;
    }

    .ai-stats-card-{{ ai_gen_id }} {
      padding: 30px 20px;
    }

    .ai-stats-number-{{ ai_gen_id }} {
      font-size: {{ block.settings.stat_number_size | times: 0.8 }}px;
    }

    .ai-stats-transition-{{ ai_gen_id }} {
      font-size: {{ block.settings.transition_text_size | times: 0.9 }}px;
      margin-bottom: 30px;
    }

    .ai-stats-cta-section-{{ ai_gen_id }} {
      padding: 40px 24px;
    }

    .ai-stats-cta-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.cta_headline_size | times: 0.75 }}px;
    }

    .ai-stats-cta-body-{{ ai_gen_id }} {
      font-size: {{ block.settings.cta_body_size | times: 0.9 }}px;
    }

    .ai-stats-benefits-{{ ai_gen_id }} {
      gap: 16px;
    }
  }
{% endstyle %}

