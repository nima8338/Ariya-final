      {% endfor %}
    </div>
  </div>
</purchase-type-badges-{{ ai_gen_id }}>

<script>
  (function() {
    class PurchaseTypeBadges{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.subscriptionSelector = this.dataset.subscriptionSelector;
        this.onetimeSelector = this.dataset.onetimeSelector;
        this.subscriptionSet = this.querySelector('.ai-purchase-badges__set-subscription-{{ ai_gen_id }}');
        this.onetimeSet = this.querySelector('.ai-purchase-badges__set-onetime-{{ ai_gen_id }}');
      }

      connectedCallback() {
        this.checkPurchaseType();
        this.setupObserver();
        this.setupEventListeners();
      }

      checkPurchaseType() {
        let isSubscription = false;

        if (this.subscriptionSelector) {
          const subscriptionElement = document.querySelector(this.subscriptionSelector);
          if (subscriptionElement) {
            if (subscriptionElement.type === 'radio' || subscriptionElement.type === 'checkbox') {
              isSubscription = subscriptionElement.checked;
            } else if (subscriptionElement.tagName === 'SELECT') {
              isSubscription = subscriptionElement.value === 'subscription' || subscriptionElement.selectedOptions[0]?.dataset?.subscription === 'true';
            } else {
              isSubscription = subscriptionElement.classList.contains('active') || subscriptionElement.getAttribute('aria-selected') === 'true';
            }
          }
        }

        if (this.onetimeSelector && !isSubscription) {
          const onetimeElement = document.querySelector(this.onetimeSelector);
          if (onetimeElement) {
            if (onetimeElement.type === 'radio' || onetimeElement.type === 'checkbox') {
              isSubscription = !onetimeElement.checked;
            } else if (onetimeElement.tagName === 'SELECT') {
              isSubscription = onetimeElement.value !== 'onetime' && onetimeElement.selectedOptions[0]?.dataset?.subscription !== 'false';
            } else {
              isSubscription = !(onetimeElement.classList.contains('active') || onetimeElement.getAttribute('aria-selected') === 'true');
            }
          }
        }

        this.updateDisplay(isSubscription);
      }

      updateDisplay(isSubscription) {
        if (isSubscription) {
          this.subscriptionSet.classList.add('active');
          this.onetimeSet.classList.remove('active');
        } else {
          this.subscriptionSet.classList.remove('active');
          this.onetimeSet.classList.add('active');
        }
      }

      setupObserver() {
        const observer = new MutationObserver(() => {
          this.checkPurchaseType();
        });

        const observeElement = (selector) => {
          const element = document.querySelector(selector);
          if (element) {
            observer.observe(element, {
              attributes: true,
              attributeFilter: ['class', 'aria-selected', 'checked']
            });
          }
        };

        if (this.subscriptionSelector) {
          observeElement(this.subscriptionSelector);
        }
        if (this.onetimeSelector) {
          observeElement(this.onetimeSelector);
        }
      }

      setupEventListeners() {
        const addListener = (selector) => {
          const element = document.querySelector(selector);
          if (element) {
            element.addEventListener('change', () => {
              this.checkPurchaseType();
            });
            element.addEventListener('click', () => {
              setTimeout(() => this.checkPurchaseType(), 100);
            });
          }
        };

        if (this.subscriptionSelector) {
          addListener(this.subscriptionSelector);
        }
        if (this.onetimeSelector) {
          addListener(this.onetimeSelector);
        }
      }
    }

    customElements.define('purchase-type-badges-{{ ai_gen_id }}', PurchaseTypeBadges{{ ai_gen_id }});
  })();
</script>

