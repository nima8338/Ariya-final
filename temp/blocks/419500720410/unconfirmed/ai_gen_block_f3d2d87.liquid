{% doc %}
  @prompt
    create 2 horizontal 3 badges with a description, one needs to pop up when someone picked monthly subscription and the other needs to pop up when they picked a one time purchase
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-purchase-badges-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-purchase-badges__container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.badge_gap }}px;
    justify-content: {{ block.settings.alignment }};
    align-items: flex-start;
    flex-wrap: wrap;
  }

  .ai-purchase-badges__badge-{{ ai_gen_id }} {
    flex: 1;
    min-width: 0;
    max-width: calc(33.333% - {{ block.settings.badge_gap | times: 2 | divided_by: 3 }}px);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: {{ block.settings.badge_padding }}px;
    background-color: {{ block.settings.badge_background }};
    border-radius: {{ block.settings.badge_border_radius }}px;
    border: {{ block.settings.badge_border_width }}px solid {{ block.settings.badge_border_color }};
  }

  .ai-purchase-badges__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin-bottom: {{ block.settings.icon_spacing }}px;
    color: {{ block.settings.icon_color }};
    flex-shrink: 0;
  }

  .ai-purchase-badges__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-purchase-badges__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px;
  }

  .ai-purchase-badges__description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.4;
  }

  .ai-purchase-badges__set-{{ ai_gen_id }} {
    display: none;
  }

  .ai-purchase-badges__set-{{ ai_gen_id }}.active {
    display: block;
  }

  @media screen and (max-width: 749px) {
    .ai-purchase-badges__container-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-purchase-badges__badge-{{ ai_gen_id }} {
      max-width: 100%;
    }
  }
{% endstyle %}

<purchase-type-badges-{{ ai_gen_id }}
  class="ai-purchase-badges-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-subscription-selector="{{ block.settings.subscription_selector }}"
  data-onetime-selector="{{ block.settings.onetime_selector }}"
>
  <div class="ai-purchase-badges__set-{{ ai_gen_id }} ai-purchase-badges__set-subscription-{{ ai_gen_id }}">
    <div class="ai-purchase-badges__container-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign title_key = 'subscription_badge_' | append: i | append: '_title'
          assign description_key = 'subscription_badge_' | append: i | append: '_description'
          assign icon_key = 'subscription_badge_' | append: i | append: '_icon'

          assign title = block.settings[title_key]
          assign description = block.settings[description_key]
          assign icon = block.settings[icon_key]
        %}

        <div class="ai-purchase-badges__badge-{{ ai_gen_id }}">
          <div class="ai-purchase-badges__icon-{{ ai_gen_id }}">
            {% case icon %}
              {% when 'check' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              {% when 'star' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                </svg>
              {% when 'gift' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 12 20 22 4 22 4 12"></polyline>
                  <rect x="2" y="7" width="20" height="5"></rect>
                  <line x1="12" y1="22" x2="12" y2="7"></line>
                  <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path>
                  <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path>
                </svg>
              {% when 'truck' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="1" y="3" width="15" height="13"></rect>
                  <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                  <circle cx="5.5" cy="18.5" r="2.5"></circle>
                  <circle cx="18.5" cy="18.5" r="2.5"></circle>
                </svg>
              {% when 'refresh' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="23 4 23 10 17 10"></polyline>
                  <polyline points="1 20 1 14 7 14"></polyline>
                  <path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"></path>
                </svg>
              {% when 'percent' %}
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="19" y1="5" x2="5" y2="19"></line>
                  <circle cx="6.5" cy="6.5" r="2.5"></circle>
                  <circle cx="17.5" cy="17.5" r="2.5"></circle>
                </svg>
            {% endcase %}
          </div>
          <h3 class="ai-purchase-badges__title-{{ ai_gen_id }}">{{ title }}</h3>
          <p class="ai-purchase-badges__description-{{ ai_gen_id }}">{{ description }}</p>
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="ai-purchase-badges__set-{{ ai_gen_id }} ai-purchase-badges__set-onetime-{{ ai_gen_id }}">
    <div class="ai-purchase-badges__container-{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign title_key = 'onetime_badge_' | append: i | append: '_title'
          assign description_key = 'onetime_badge_' | append: i | append: '_description'
          assign icon_key = 'onetime_badge_' | append: i | append: '_icon'

          assign title = block.settings[title_key]
