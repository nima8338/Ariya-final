{% doc %}
  @prompt
    Create a clean, minimal founder-support text block using this copy:
    
    “Have a question before checking out? Text the founders directly →”
    
    Design requirements:
    
    Center-align the text.
    Keep the text small and visually secondary.
    Use black for “Have a question before checking out?”
    Use Ariya purple #7D45C6 for “Text the founders directly →”
    Make “Text the founders directly →” clickable.
    The link should open a new text message using: sms:[BUSINESS PHONE NUMBER]
    Do not use a button, border, background box, or icon.
    Keep the spacing compact and optimized for mobile.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-founder-support-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    text-align: center;
    padding: 12px 16px;
  }

  .ai-founder-support__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.4;
    margin: 0;
  }

  .ai-founder-support__question-{{ ai_gen_id }} {
    color: {{ block.settings.question_color }};
  }

  .ai-founder-support__link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .ai-founder-support__link-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  @media screen and (max-width: 749px) {
    .ai-founder-support-{{ ai_gen_id }} {
      padding: 10px 12px;
    }

    .ai-founder-support__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-founder-support-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <p class="ai-founder-support__text-{{ ai_gen_id }}">
    <span class="ai-founder-support__question-{{ ai_gen_id }}">{{ block.settings.question_text }}</span>
    <a 
      href="sms:{{ block.settings.phone_number }}" 
      class="ai-founder-support__link-{{ ai_gen_id }}"
    >
      {{ block.settings.link_text }}
    </a>
  </p>
</div>

{% schema %}
{
  "name": "Founder support text",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "question_text",
      "label": "Question text",
      "default": "Have a question before checking out?"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "default": "Text the founders directly →"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone number",
      "info": "Enter phone number with country code (e.g., +15551234567)"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "color",
      "id": "question_color",
      "label": "Question color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#7D45C6"
    }
  ],
  "presets": [
    {
      "name": "Founder support text"
    }
  ]
}
{% endschema %}
