{% doc %}
  @prompt
    Create a clean, minimal founder-support text block using this copy:
    
    “Questions before ordering? Text the founders directly →”
    
    Design requirements:
    
    Center-align the text.
    Keep the text small, clean, and easy to read.
    Use black for “Questions before ordering?”
    Use Ariya purple #7D45C6 for “Text the founders directly →”
    Make “Text the founders directly →” clickable.
    The link should open a new text message using: sms:[BUSINESS PHONE NUMBER]
    Do not use a button, border, background box, or icon.
    Keep the spacing compact and optimized for mobile and desktop.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-founder-support-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    text-align: center;
    padding: {{ block.settings.vertical_spacing }}px 20px;
  }

  .ai-founder-support-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.font_size }}px;
    line-height: 1.5;
    margin: 0;
  }

  .ai-founder-support-question-{{ ai_gen_id }} {
    color: {{ block.settings.question_color }};
  }

  .ai-founder-support-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .ai-founder-support-link-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  @media screen and (max-width: 749px) {
    .ai-founder-support-{{ ai_gen_id }} {
      padding: {{ block.settings.vertical_spacing | times: 0.8 }}px 16px;
    }

    .ai-founder-support-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-founder-support-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <p class="ai-founder-support-text-{{ ai_gen_id }}">
    <span class="ai-founder-support-question-{{ ai_gen_id }}">{{ block.settings.question_text }}</span>
    <a href="sms:{{ block.settings.phone_number }}" class="ai-founder-support-link-{{ ai_gen_id }}">{{ block.settings.link_text }}</a>
  </p>
</div>

{% schema %}
{
  "name": "Founder support text",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "question_text",
      "label": "Question text",
      "default": "Questions before ordering?"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "default": "Text the founders directly →"
    },
    {
      "type": "text",
      "id": "phone_number",
      "label": "Phone number"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "color",
      "id": "question_color",
      "label": "Question color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#7D45C6"
    },
    {
      "type": "range",
      "id": "vertical_spacing",
      "label": "Vertical spacing",
      "min": 10,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Founder support text"
    }
  ]
}
{% endschema %}
