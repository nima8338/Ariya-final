<script>
  (function() {
    class SleepStatistics{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        const button = this.querySelector('[data-scroll-to-top]');
        if (button) {
          button.addEventListener('click', this.scrollToTop.bind(this));
        }
      }

      scrollToTop(event) {
        event.preventDefault();
        window.scrollTo({
          top: 0,
          behavior: 'smooth'
        });
      }
    }

    customElements.define('sleep-statistics-{{ ai_gen_id }}', SleepStatistics{{ ai_gen_id }});
  })();
</script>

