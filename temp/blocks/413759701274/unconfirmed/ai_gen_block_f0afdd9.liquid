{% doc %}
  @prompt
    Create a brand new section called:Why Calm Nights?Supporting text:Most sleep supplements are designed to sell. Calm Nights was designed to work.Use a layout inspired by Moonbrew.Do NOT create a traditional comparison table.Create a highlighted Calm Nights column in the center with a subtle Ariya purple background.Each row should contain a benefit.Under the Calm Nights column display a green checkmark.On the opposite side display only a red X icon.Do NOT include any competitor text.Do NOT mention “Other Brands.”Do NOT write competitor claims.Only show the benefit on the left and the visual comparison using ✓ and ✕.Rows:Fully Disclosed DosesStandardized Plant ExtractsMelatonin-Free FormulaWake Up RefreshedNon-Habit FormingOptional sixth row:Made In An FDA-Registered FacilityDesign Requirements:Mobile firstWhite backgroundPremium wellness aestheticRounded cornersSoft shadowsAriya purple accentsGreen checkmarksRed X iconsClean typographyEasy to scan in under 3 secondsSimilar visual hierarchy to MoonbrewThe goal is to create a premium visual comparison section that immediately communicates why Calm Nights is different without requiring users to read long paragraphs.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-why-calm-nights-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-why-calm-nights-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-why-calm-nights-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 32px;
  }

  .ai-why-calm-nights-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px 0;
    line-height: 1.2;
  }

  .ai-why-calm-nights-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-why-calm-nights-comparison-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    box-shadow: {{ block.settings.shadow_horizontal }}px {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px {{ block.settings.shadow_color }};
  }

  .ai-why-calm-nights-row-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    border-bottom: 1px solid {{ block.settings.divider_color }};
  }

  .ai-why-calm-nights-row-{{ ai_gen_id }}:last-child {
    border-bottom: none;
  }

  .ai-why-calm-nights-benefit-{{ ai_gen_id }} {
    padding: {{ block.settings.row_padding }}px;
    font-size: {{ block.settings.benefit_text_size }}px;
    color: {{ block.settings.benefit_text_color }};
    font-weight: 500;
    text-align: left;
  }

  .ai-why-calm-nights-center-{{ ai_gen_id }} {
    background-color: {{ block.settings.center_background }};
    padding: {{ block.settings.row_padding }}px 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 80px;
  }

  .ai-why-calm-nights-other-{{ ai_gen_id }} {
    padding: {{ block.settings.row_padding }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-why-calm-nights-checkmark-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    color: {{ block.settings.checkmark_color }};
  }

  .ai-why-calm-nights-x-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    color: {{ block.settings.x_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-why-calm-nights-{{ ai_gen_id }} {
      padding: 32px 16px;
    }

    .ai-why-calm-nights-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-why-calm-nights-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.9 }}px;
    }

    .ai-why-calm-nights-benefit-{{ ai_gen_id }} {
      font-size: {{ block.settings.benefit_text_size | times: 0.9 }}px;
      padding: {{ block.settings.row_padding | times: 0.8 }}px;
    }

    .ai-why-calm-nights-center-{{ ai_gen_id }} {
      padding: {{ block.settings.row_padding | times: 0.8 }}px 16px;
      min-width: 60px;
    }

    .ai-why-calm-nights-other-{{ ai_gen_id }} {
      padding: {{ block.settings.row_padding | times: 0.8 }}px;
    }

    .ai-why-calm-nights-checkmark-{{ ai_gen_id }},
    .ai-why-calm-nights-x-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }
  }
{% endstyle %}

<div class="ai-why-calm-nights-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
