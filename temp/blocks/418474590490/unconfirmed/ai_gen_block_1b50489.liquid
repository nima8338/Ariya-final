{% doc %}
  @prompt
    Create a Shopify video testimonial carousel section.
    
    Place it directly below the Hero Section and above the written reviews section.
    
    Section title:
    Real People. Real Results.
    
    Supporting text:
    Hear directly from people who have made Calm Nights part of their nightly routine.
    
    MOST IMPORTANT FUNCTIONAL REQUIREMENT:
    Each testimonial card must use a real HTML video element, not just an image with a fake play button.
    
    Each card must have:
    
    1. Uploaded Shopify video file setting
    2. Optional thumbnail/poster image setting
    3. Editable badge label
    4. Editable customer name
    5. Editable review text
    6. Optional star rating toggle
    
    The uploaded video file must be the actual playable video source.
    
    The thumbnail image must only be used as the video poster image before playback. It must not replace the video, cover the video, or block clicks.
    
    Use the thumbnail/poster image as the video poster attribute.
    
    When the customer taps the video or play button:
    
    * the video must play inside the same card
    * the poster/thumbnail should disappear
    * the play button should disappear
    * the video should show controls or use a working custom play button
    
    Do not create a decorative play button. The play button must trigger the video.
    
    Do not require pasted video links. Allow videos to be selected from Shopify uploaded files.
    
    Carousel requirements:
    
    * Horizontal swipe carousel
    * Swipe left and right on mobile
    * Left/right arrows on desktop
    * Support at least 4 testimonial videos
    * Show one main video centered with the next and previous videos partially visible
    * Smooth scrolling animation
    
    Card design:
    
    * Vertical TikTok/Reel style video format
    * Rounded corners
    * Soft shadow
    * White card background
    * Consistent video sizing
    * Premium wellness aesthetic
    * Ariya purple accents
    * Black text
    * Mobile-first layout
    
    Create placeholders for:
    Video 1
    Video 2
    Video 3
    Video 4
    
    Badge examples:
    BENEFITS
    SLEEP QUALITY
    FALL ASLEEP FASTER
    WAKE UP REFRESHED
    
    Review examples:
    ★★★★★ Sarah M.
    "Best sleep I've had in years."
    
    ★★★★★ Jake T.
    "Finally waking up refreshed."
    
    The final section should feel like a premium wellness brand video testimonial carousel and must allow visitors to watch customer videos directly on the product page without leaving the page.,  create an animation where the videos are moving left and when it goes out the screen the videos loop back around and it never stops, make it when you press the video it expands and dont let anything overlap the video or cover it when its played, could you make the block a bit smaller but make sure it doesnt mess up the layout, make the animation move a bit faster
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-testimonials-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 40px 20px;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .ai-video-testimonials__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 32px;
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-video-testimonials__title-{{ ai_gen_id }} {
    font-size: 32px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0 0 12px;
  }

  .ai-video-testimonials__subtitle-{{ ai_gen_id }} {
    font-size: 16px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-video-testimonials__carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
  }

  .ai-video-testimonials__carousel-{{ ai_gen_id }} {
    display: flex;
    gap: 20px;
    animation: ai-video-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
    will-change: transform;
  }

  .ai-video-testimonials__carousel-{{ ai_gen_id }}.paused {
    animation-play-state: paused;
  }

  @keyframes ai-video-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .ai-video-testimonials__card-{{ ai_gen_id }} {
    flex: 0 0 280px;
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    box-shadow: 0 4px 12px rgba(26, 10, 46, 0.1);
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    cursor: pointer;
  }

  .ai-video-testimonials__card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 20px rgba(26, 10, 46, 0.15);
  }

  .ai-video-testimonials__video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 16;
    background: #f9f6ff;
    overflow: hidden;
  }

  .ai-video-testimonials__video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-video-testimonials__play-button-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60px;
    height: 60px;
    background: rgba(60, 14, 102, 0.9);
    border: none;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.3s ease;
    z-index: 2;
  }

  .ai-video-testimonials__play-button-{{ ai_gen_id }}:hover {
    background: rgba(90, 26, 154, 0.95);
    transform: translate(-50%, -50%) scale(1.1);
  }

  .ai-video-testimonials__play-button-{{ ai_gen_id }}.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .ai-video-testimonials__play-icon-{{ ai_gen_id }} {
    width: 0;
    height: 0;
    border-left: 20px solid #ffffff;
    border-top: 12px solid transparent;
    border-bottom: 12px solid transparent;
    margin-left: 4px;
  }

  .ai-video-testimonials__content-{{ ai_gen_id }} {
    padding: 16px;
  }

  .ai-video-testimonials__badge-{{ ai_gen_id }} {
    display: inline-block;
    padding: 4px 12px;
    background: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-radius: 12px;
    margin-bottom: 8px;
  }

  .ai-video-testimonials__stars-{{ ai_gen_id }} {
    display: flex;
    gap: 2px;
    margin-bottom: 8px;
  }

  .ai-video-testimonials__star-{{ ai_gen_id }} {
    color: {{ block.settings.star_color }};
    font-size: 14px;
  }

  .ai-video-testimonials__name-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.name_color }};
    margin: 0 0 6px;
  }

  .ai-video-testimonials__review-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.review_color }};
    line-height: 1.5;
    margin: 0;
  }

  .ai-video-testimonials__modal-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.9);
    display: none;
    align-items: center;
    justify-content: center;
    z-index: 9999;
    padding: 20px;
  }

  .ai-video-testimonials__modal-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-video-testimonials__modal-content-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    max-width: 500px;
    aspect-ratio: 9 / 16;
    background: #000;
    border-radius: 12px;
    overflow: hidden;
  }

  .ai-video-testimonials__modal-video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-video-testimonials__modal-close-{{ ai_gen_id }} {
    position: absolute;
    top: 16px;
    right: 16px;
    width: 40px;
    height: 40px;
    background: rgba(255, 255, 255, 0.9);
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: background 0.3s ease;
  }

  .ai-video-testimonials__modal-close-{{ ai_gen_id }}:hover {
    background: #ffffff;
  }

  .ai-video-testimonials__close-icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    position: relative;
  }

  .ai-video-testimonials__close-icon-{{ ai_gen_id }}::before,
  .ai-video-testimonials__close-icon-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 16px;
    height: 2px;
    background: #1a0a2e;
  }

  .ai-video-testimonials__close-icon-{{ ai_gen_id }}::before {
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .ai-video-testimonials__close-icon-{{ ai_gen_id }}::after {
    transform: translate(-50%, -50%) rotate(-45deg);
  }

  @media screen and (max-width: 749px) {
    .ai-video-testimonials__title-{{ ai_gen_id }} {
      font-size: 24px;
    }

    .ai-video-testimonials__subtitle-{{ ai_gen_id }} {
      font-size: 14px;
    }

    .ai-video-testimonials__card-{{ ai_gen_id }} {
      flex: 0 0 220px;
    }

    .ai-video-testimonials__modal-content-{{ ai_gen_id }} {
      max-width: 100%;
    }
  }
{% endstyle %}

<video-testimonials-{{ ai_gen_id }}
  class="ai-video-testimonials-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-video-testimonials__header-{{ ai_gen_id }}">
    {% if block.settings.title != blank %}
      <h2 class="ai-video-testimonials__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
    {% endif %}
    {% if block.settings.subtitle != blank %}
      <p class="ai-video-testimonials__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
    {% endif %}
  </div>

  <div class="ai-video-testimonials__carousel-wrapper-{{ ai_gen_id }}">
    <div class="ai-video-testimonials__carousel-{{ ai_gen_id }}" data-carousel>
      {% for i in (1..4) %}
        {% liquid
          assign video_key = 'video_' | append: i
          assign poster_key = 'poster_' | append: i
          assign badge_key = 'badge_' | append: i
          assign name_key = 'name_' | append: i
          assign review_key = 'review_' | append: i
          assign show_stars_key = 'show_stars_' | append: i

          assign video = block.settings[video_key]
          assign poster = block.settings[poster_key]
          assign badge = block.settings[badge_key]
          assign name = block.settings[name_key]
          assign review = block.settings[review_key]
          assign show_stars = block.settings[show_stars_key]
        %}

        <div class="ai-video-testimonials__card-{{ ai_gen_id }}" data-card="{{ i }}">
          <div class="ai-video-testimonials__video-wrapper-{{ ai_gen_id }}">
            {% if video != blank %}
              <video
                class="ai-video-testimonials__video-{{ ai_gen_id }}"
                data-video="{{ i }}"
                {% if poster != blank %}
                  poster="{{ poster | image_url: width: 600 }}"
                {% endif %}
                playsinline
                preload="metadata"
              >
                <source src="{{ video.sources[0].url }}" type="{{ video.sources[0].mime_type }}">
              </video>
              <button
                class="ai-video-testimonials__play-button-{{ ai_gen_id }}"
                data-play-button="{{ i }}"
                aria-label="Play video"
              >
                <div class="ai-video-testimonials__play-icon-{{ ai_gen_id }}"></div>
              </button>
            {% else %}
              <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: #f9f6ff; color: #6b5a85; font-size: 14px; text-align: center; padding: 20px;">
                Upload video {{ i }}
              </div>
            {% endif %}
          </div>

          <div class="ai-video-testimonials__content-{{ ai_gen_id }}">
            {% if badge != blank %}
              <span class="ai-video-testimonials__badge-{{ ai_gen_id }}">{{ badge }}</span>
            {% endif %}

            {% if show_stars %}
              <div class="ai-video-testimonials__stars-{{ ai_gen_id }}">
                {% for star in (1..5) %}
                  <span class="ai-video-testimonials__star-{{ ai_gen_id }}">★</span>
                {% endfor %}
              </div>
            {% endif %}

            {% if name != blank %}
              <p class="ai-video-testimonials__name-{{ ai_gen_id }}">{{ name }}</p>
            {% endif %}

            {% if review != blank %}
              <p class="ai-video-testimonials__review-{{ ai_gen_id }}">{{ review }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}

      {% for i in (1..4) %}
        {% liquid
          assign video_key = 'video_' | append: i
          assign poster_key = 'poster_' | append: i
          assign badge_key = 'badge_' | append: i
          assign name_key = 'name_' | append: i
          assign review_key = 'review_' | append: i
          assign show_stars_key = 'show_stars_' | append: i

          assign video = block.settings[video_key]
          assign poster = block.settings[poster_key]
          assign badge = block.settings[badge_key]
          assign name = block.settings[name_key]
          assign review = block.settings[review_key]
          assign show_stars = block.settings[show_stars_key]
        %}

        <div class="ai-video-testimonials__card-{{ ai_gen_id }}" data-card="{{ i }}" aria-hidden="true">
          <div class="ai-video-testimonials__video-wrapper-{{ ai_gen_id }}">
            {% if video != blank %}
              <video
                class="ai-video-testimonials__video-{{ ai_gen_id }}"
                {% if poster != blank %}
                  poster="{{ poster | image_url: width: 600 }}"
                {% endif %}
                playsinline
                preload="metadata"
              >
                <source src="{{ video.sources[0].url }}" type="{{ video.sources[0].mime_type }}">
              </video>
              <button
                class="ai-video-testimonials__play-button-{{ ai_gen_id }}"
                aria-label="Play video"
                tabindex="-1"
              >
                <div class="ai-video-testimonials__play-icon-{{ ai_gen_id }}"></div>
              </button>
            {% else %}
              <div style="width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; background: #f9f6ff; color: #6b5a85; font-size: 14px; text-align: center; padding: 20px;">
                Upload video {{ i }}
              </div>
            {% endif %}
          </div>

          <div class="ai-video-testimonials__content-{{ ai_gen_id }}">
            {% if badge != blank %}
              <span class="ai-video-testimonials__badge-{{ ai_gen_id }}">{{ badge }}</span>
            {% endif %}

            {% if show_stars %}
              <div class="ai-video-testimonials__stars-{{ ai_gen_id }}">
                {% for star in (1..5) %}
                  <span class="ai-video-testimonials__star-{{ ai_gen_id }}">★</span>
                {% endfor %}
              </div>
            {% endif %}

            {% if name != blank %}
              <p class="ai-video-testimonials__name-{{ ai_gen_id }}">{{ name }}</p>
            {% endif %}

            {% if review != blank %}
              <p class="ai-video-testimonials__review-{{ ai_gen_id }}">{{ review }}</p>
            {% endif %}
          </div>
        </div>
      {% endfor %}
    </div>
  </div>

  <div class="ai-video-testimonials__modal-{{ ai_gen_id }}" data-modal>
    <div class="ai-video-testimonials__modal-content-{{ ai_gen_id }}">
      <button
        class="ai-video-testimonials__modal-close-{{ ai_gen_id }}"
        data-modal-close
        aria-label="Close video"
      >
        <div class="ai-video-testimonials__close-icon-{{ ai_gen_id }}"></div>
      </button>
      <video
        class="ai-video-testimonials__modal-video-{{ ai_gen_id }}"
        data-modal-video
        controls
        playsinline
      ></video>
    </div>
  </div>
</video-testimonials-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoTestimonials{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.carousel = this.querySelector('[data-carousel]');
        this.cards = this.querySelectorAll('[data-card]');
        this.modal = this.querySelector('[data-modal]');
        this.modalVideo = this.querySelector('[data-modal-video]');
        this.modalClose = this.querySelector('[data-modal-close]');
      }

      connectedCallback() {
        this.setupVideoPlayers();
        this.setupModal();
        this.setupCarouselPause();
      }

      setupVideoPlayers() {
        this.cards.forEach((card) => {
          const videoId = card.dataset.card;
          const video = card.querySelector(`[data-video="${videoId}"]`);
          const playButton = card.querySelector(`[data-play-button="${videoId}"]`);

          if (!video || !playButton) return;

          playButton.addEventListener('click', (e) => {
            e.stopPropagation();
            this.openModal(video);
          });

          card.addEventListener('click', () => {
            this.openModal(video);
          });
        });
      }

      setupModal() {
        this.modalClose.addEventListener('click', () => {
          this.closeModal();
        });

        this.modal.addEventListener('click', (e) => {
          if (e.target === this.modal) {
            this.closeModal();
          }
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && this.modal.classList.contains('active')) {
            this.closeModal();
          }
        });
      }

      setupCarouselPause() {
        this.carousel.addEventListener('mouseenter', () => {
          this.carousel.classList.add('paused');
        });

        this.carousel.addEventListener('mouseleave', () => {
          this.carousel.classList.remove('paused');
        });
      }

      openModal(sourceVideo) {
        if (!sourceVideo || !sourceVideo.src) return;

        this.modalVideo.src = sourceVideo.src;
        this.modalVideo.poster = sourceVideo.poster || '';
        this.modal.classList.add('active');
        this.modalVideo.play();
        document.body.style.overflow = 'hidden';

        this.carousel.classList.add('paused');
      }

      closeModal() {
        this.modal.classList.remove('active');
        this.modalVideo.pause();
        this.modalVideo.currentTime = 0;
        this.modalVideo.src = '';
        document.body.style.overflow = '';

        this.carousel.classList.remove('paused');
      }
    }

    customElements.define('video-testimonials-{{ ai_gen_id }}', VideoTestimonials{{ ai_gen_id }});
  })();
</script>

