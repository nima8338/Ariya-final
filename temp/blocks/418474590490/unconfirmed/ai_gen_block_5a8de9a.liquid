{% doc %}
  @prompt
    In the Video testimonials block, when a video is expanded in a modal or overlay, the close/exit button in the top-right corner is being covered by the site header and cannot be clicked. Add CSS to push the close/exit button lower (increase its top offset, e.g. to 70px or enough to clear the header) while keeping it fixed in the top-right position. Target the expanded video modal close button specifically so it does not affect other elements.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-testimonials-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
  }

  .ai-video-testimonials-container-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    gap: {{ block.settings.grid_gap }}px;
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-video-testimonial-card-{{ ai_gen_id }} {
    position: relative;
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    cursor: pointer;
    background-color: {{ block.settings.card_background_color }};
    transition: transform 0.3s ease;
  }

  .ai-video-testimonial-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-video-thumbnail-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    background-color: #f0f0f0;
    overflow: hidden;
  }

  .ai-video-thumbnail-{{ ai_gen_id }} img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-play-button-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60px;
    height: 60px;
    background-color: {{ block.settings.play_button_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s ease;
  }

  .ai-video-testimonial-card-{{ ai_gen_id }}:hover .ai-video-play-button-{{ ai_gen_id }} {
    transform: translate(-50%, -50%) scale(1.1);
  }

  .ai-video-play-button-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    fill: {{ block.settings.play_button_icon_color }};
    margin-left: 3px;
  }

  .ai-video-testimonial-info-{{ ai_gen_id }} {
    padding: {{ block.settings.card_padding }}px;
  }

  .ai-video-testimonial-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.name_font_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 4px 0;
  }

  .ai-video-testimonial-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_font_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
  }

  .ai-video-modal-{{ ai_gen_id }} {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: rgba(0, 0, 0, 0.9);
    z-index: 9999;
    align-items: center;
    justify-content: center;
  }

  .ai-video-modal-{{ ai_gen_id }}.active {
    display: flex;
  }

  .ai-video-modal-content-{{ ai_gen_id }} {
    position: relative;
    width: 90%;
    max-width: 1200px;
    aspect-ratio: 16 / 9;
  }

  .ai-video-modal-content-{{ ai_gen_id }} iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  .ai-video-modal-close-{{ ai_gen_id }} {
    position: fixed;
    top: {{ block.settings.close_button_top_offset }}px;
    right: 20px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 10px;
    z-index: 10000;
  }

  .ai-video-modal-close-{{ ai_gen_id }} svg {
    width: 32px;
    height: 32px;
    stroke: #ffffff;
    stroke-width: 2;
  }

  .ai-video-modal-close-{{ ai_gen_id }}:hover svg {
    stroke: {{ block.settings.play_button_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-video-testimonials-container-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_mobile }}, 1fr);
    }
  }
{% endstyle %}

<video-testimonials-{{ ai_gen_id }}
  class="ai-video-testimonials-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-video-testimonials-container-{{ ai_gen_id }}">
    {% for i in (1..6) %}
      {% liquid
        assign video_url_key = 'video_url_' | append: i
        assign thumbnail_key = 'thumbnail_' | append: i
        assign name_key = 'name_' | append: i
        assign title_key = 'title_' | append: i

        assign video_url = block.settings[video_url_key]
        assign thumbnail = block.settings[thumbnail_key]
        assign name = block.settings[name_key]
        assign title = block.settings[title_key]
      %}

      {% if video_url != blank %}
        <div
          class="ai-video-testimonial-card-{{ ai_gen_id }}"
          data-video-url="{{ video_url }}"
        >
          <div class="ai-video-thumbnail-{{ ai_gen_id }}">
            {% if thumbnail %}
              <img
                src="{{ thumbnail | image_url: width: 600 }}"
                alt="{{ name }}"
                loading="lazy"
              >
            {% else %}
              <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: #f0f0f0;"></div>
            {% endif %}
            <div class="ai-video-play-button-{{ ai_gen_id }}">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                viewBox="0 0 24 24"
              >
                <path d="M8 5v14l11-7z" />
              </svg>
            </div>
          </div>
          {% if name != blank or title != blank %}
            <div class="ai-video-testimonial-info-{{ ai_gen_id }}">
              {% if name != blank %}
                <h3 class="ai-video-testimonial-name-{{ ai_gen_id }}">{{ name }}</h3>
              {% endif %}
              {% if title != blank %}
                <p class="ai-video-testimonial-title-{{ ai_gen_id }}">{{ title }}</p>
              {% endif %}
            </div>
          {% endif %}
        </div>
      {% endif %}
    {% endfor %}
  </div>

  <div class="ai-video-modal-{{ ai_gen_id }}">
    <button
      class="ai-video-modal-close-{{ ai_gen_id }}"
      aria-label="Close video"
    >
      <svg
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
      >
        <line
          x1="18"
          y1="6"
          x2="6"
          y2="18"
        ></line>
        <line
          x1="6"
          y1="6"
          x2="18"
          y2="18"
        ></line>
      </svg>
    </button>
    <div class="ai-video-modal-content-{{ ai_gen_id }}"></div>
  </div>
</video-testimonials-{{ ai_gen_id }}>

<script>
  (function () {
    class VideoTestimonials{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.cards = this.querySelectorAll('.ai-video-testimonial-card-{{ ai_gen_id }}');
        this.modal = this.querySelector('.ai-video-modal-{{ ai_gen_id }}');
        this.modalContent = this.querySelector('.ai-video-modal-content-{{ ai_gen_id }}');
        this.closeButton = this.querySelector('.ai-video-modal-close-{{ ai_gen_id }}');

        this.setupEventListeners();
      }

      setupEventListeners() {
        this.cards.forEach((card) => {
          card.addEventListener('click', () => {
            const videoUrl = card.dataset.videoUrl;
            this.openModal(videoUrl);
          });
        });

        this.closeButton.addEventListener('click', () => {
          this.closeModal();
        });

        this.modal.addEventListener('click', (e) => {
          if (e.target === this.modal) {
            this.closeModal();
          }
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && this.modal.classList.contains('active')) {
            this.closeModal();
          }
        });
      }

      openModal(videoUrl) {
        const embedUrl = this.getEmbedUrl(videoUrl);
        if (embedUrl) {
          this.modalContent.innerHTML = `<iframe src="${embedUrl}" allow="autoplay; encrypted-media" allowfullscreen></iframe>`;
          this.modal.classList.add('active');
          document.body.style.overflow = 'hidden';
        }
      }

      closeModal() {
        this.modal.classList.remove('active');
        this.modalContent.innerHTML = '';
        document.body.style.overflow = '';
      }

      getEmbedUrl(url) {
        if (url.includes('youtube.com') || url.includes('youtu.be')) {
          const videoId = this.extractYouTubeId(url);
          return videoId ? `https://www.youtube.com/embed/${videoId}?autoplay=1` : null;
        } else if (url.includes('vimeo.com')) {
          const videoId = this.extractVimeoId(url);
          return videoId ? `https://player.vimeo.com/video/${videoId}?autoplay=1` : null;
        }
        return null;
      }

      extractYouTubeId(url) {
        const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|&v=)([^#&?]*).*/;
        const match = url.match(regExp);
        return match && match[2].length === 11 ? match[2] : null;
      }

      extractVimeoId(url) {
        const regExp = /vimeo.*\/(\d+)/i;
        const match = url.match(regExp);
        return match ? match[1] : null;
      }
    }

    customElements.define('video-testimonials-{{ ai_gen_id }}', VideoTestimonials{{ ai_gen_id }});
  })();
</script>

