{% doc %}
  @prompt
    Create a Shopify video testimonial carousel section.
    
    Place it directly below the Hero Section and above the written reviews section.
    
    Section title:
    Real People. Real Results.
    
    Supporting text:
    Hear directly from people who have made Calm Nights part of their nightly routine.
    
    MOST IMPORTANT FUNCTIONAL REQUIREMENT:
    Each testimonial card must use a real HTML video element, not just an image with a fake play button.
    
    Each card must have:
    
    1. Uploaded Shopify video file setting
    2. Optional thumbnail/poster image setting
    3. Editable badge label
    4. Editable customer name
    5. Editable review text
    6. Optional star rating toggle
    
    The uploaded video file must be the actual playable video source.
    
    The thumbnail image must only be used as the video poster image before playback. It must not replace the video, cover the video, or block clicks.
    
    Use the thumbnail/poster image as the video poster attribute.
    
    When the customer taps the video or play button:
    
    * the video must play inside the same card
    * the poster/thumbnail should disappear
    * the play button should disappear
    * the video should show controls or use a working custom play button
    
    Do not create a decorative play button. The play button must trigger the video.
    
    Do not require pasted video links. Allow videos to be selected from Shopify uploaded files.
    
    Carousel requirements:
    
    * Horizontal swipe carousel
    * Swipe left and right on mobile
    * Left/right arrows on desktop
    * Support at least 4 testimonial videos
    * Show one main video centered with the next and previous videos partially visible
    * Smooth scrolling animation
    
    Card design:
    
    * Vertical TikTok/Reel style video format
    * Rounded corners
    * Soft shadow
    * White card background
    * Consistent video sizing
    * Premium wellness aesthetic
    * Ariya purple accents
    * Black text
    * Mobile-first layout
    
    Create placeholders for:
    Video 1
    Video 2
    Video 3
    Video 4
    
    Badge examples:
    BENEFITS
    SLEEP QUALITY
    FALL ASLEEP FASTER
    WAKE UP REFRESHED
    
    Review examples:
    ★★★★★ Sarah M.
    "Best sleep I've had in years."
    
    ★★★★★ Jake T.
    "Finally waking up refreshed."
    
    The final section should feel like a premium wellness brand video testimonial carousel and must allow visitors to watch customer videos directly on the product page without leaving the page.,  create an animation where the videos are moving left and when it goes out the screen the videos loop back around and it never stops, could you make the block a bit smaller but make sure it doesnt mess up the layout, make the boxes and layout a little bigger but make sure it doesnt mess it up, make the boxes a little bit wider , make it when the video is pressed it expands just the video alone and the exit button is visibly there to be pressed, when the video expands there is not exit button, insert an exit button on the expanded video close to the top right , insert an X button on the videos when they get pressed so you can exit out of the expanded video 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-testimonials-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 50px 20px;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .ai-video-testimonials__container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
  }

  .ai-video-testimonials__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-video-testimonials__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-video-testimonials__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0;
  }

  .ai-video-testimonials__carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    width: 100%;
  }

  .ai-video-testimonials__carousel-track-{{ ai_gen_id }} {
    display: flex;
    gap: 20px;
    width: max-content;
    animation: ai-scroll-{{ ai_gen_id }} {{ block.settings.animation_speed }}s linear infinite;
  }

  .ai-video-testimonials__carousel-track-{{ ai_gen_id }}:hover {
    animation-play-state: paused;
  }

  @keyframes ai-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .ai-video-testimonials__card-{{ ai_gen_id }} {
    flex: 0 0 320px;
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    box-shadow: 0 3px 12px rgba(0, 0, 0, 0.1);
    padding: 16px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-video-testimonials__card-{{ ai_gen_id }}:hover {
    transform: translateY(-6px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
  }

  .ai-video-testimonials__video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 16;
    border-radius: {{ block.settings.video_border_radius }}px;
    overflow: hidden;
    background: #000;
    margin-bottom: 12px;
    cursor: pointer;
  }

  .ai-video-testimonials__video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .ai-video-testimonials__play-button-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 60px;
    height: 60px;
    background: {{ block.settings.play_button_color }};
    border: none;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease, opacity 0.2s ease;
    z-index: 2;
  }

  .ai-video-testimonials__play-button-{{ ai_gen_id }}:hover {
    transform: translate(-50%, -50%) scale(1.1);
  }

  .ai-video-testimonials__play-button-{{ ai_gen_id }}.hidden {
    opacity: 0;
    pointer-events: none;
  }

  .ai-video-testimonials__play-icon-{{ ai_gen_id }} {
    width: 0;
    height: 0;
    border-left: 18px solid {{ block.settings.play_icon_color }};
    border-top: 12px solid transparent;
    border-bottom: 12px solid transparent;
    margin-left: 4px;
  }

  .ai-video-testimonials__badge-{{ ai_gen_id }} {
    display: inline-block;
    background: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 5px 12px;
    border-radius: 18px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 8px;
  }

  .ai-video-testimonials__customer-name-{{ ai_gen_id }} {
    font-size: 15px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px;
  }

  .ai-video-testimonials__stars-{{ ai_gen_id }} {
    display: flex;
    gap: 3px;
    margin-bottom: 8px;
  }

  .ai-video-testimonials__star-{{ ai_gen_id }} {
    color: {{ block.settings.star_color }};
    font-size: 14px;
  }

  .ai-video-testimonials__review-text-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    line-height: 1.5;
    margin: 0;
  }

  .ai-video-testimonials__modal-{{ ai_gen_id }} {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.95);
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.3s ease, visibility 0.3s ease;
  }

  .ai-video-testimonials__modal-{{ ai_gen_id }}.active {
    opacity: 1;
    visibility: visible;
  }

  .ai-video-testimonials__modal-content-{{ ai_gen_id }} {
    position: relative;
    width: 90%;
    max-width: 500px;
    aspect-ratio: 9 / 16;
    background: #000;
  }

  .ai-video-testimonials__modal-video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-video-testimonials__close-button-{{ ai_gen_id }} {
    position: fixed;
    top: 20px;
    right: 20px;
    width: 52px;
    height: 52px;
    background: {{ block.settings.play_button_color }};
    border: 3px solid {{ block.settings.play_icon_color }};
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.2s ease, background 0.2s ease;
    z-index: 10001;
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.6);
  }

  .ai-video-testimonials__close-button-{{ ai_gen_id }}:hover {
    transform: scale(1.15);
    background: {{ block.settings.badge_background }};
  }

  .ai-video-testimonials__close-icon-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
    position: relative;
  }

  .ai-video-testimonials__close-icon-{{ ai_gen_id }}::before,
  .ai-video-testimonials__close-icon-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 24px;
    height: 3px;
    background: {{ block.settings.play_icon_color }};
    border-radius: 2px;
  }

  .ai-video-testimonials__close-icon-{{ ai_gen_id }}::before {
    transform: translate(-50%, -50%) rotate(45deg);
  }

  .ai-video-testimonials__close-icon-{{ ai_gen_id }}::after {
    transform: translate(-50%, -50%) rotate(-45deg);
  }

  @media screen and (max-width: 749px) {
    .ai-video-testimonials-{{ ai_gen_id }} {
      padding: 40px 16px;
    }

    .ai-video-testimonials__card-{{ ai_gen_id }} {
      flex: 0 0 240px;
    }

    .ai-video-testimonials__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.7 }}px;
    }

    .ai-video-testimonials__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 0.85 }}px;
    }

    .ai-video-testimonials__play-button-{{ ai_gen_id }} {
      width: 50px;
      height: 50px;
    }

    .ai-video-testimonials__play-icon-{{ ai_gen_id }} {
      border-left-width: 14px;
      border-top-width: 10px;
      border-bottom-width: 10px;
    }

    .ai-video-testimonials__modal-content-{{ ai_gen_id }} {
      width: 100%;
      max-width: 100%;
      height: 100%;
      aspect-ratio: auto;
    }

    .ai-video-testimonials__close-button-{{ ai_gen_id }} {
      width: 48px;
      height: 48px;
      top: 16px;
      right: 16px;
    }

    .ai-video-testimonials__close-icon-{{ ai_gen_id }} {
      width: 22px;
      height: 22px;
    }

    .ai-video-testimonials__close-icon-{{ ai_gen_id }}::before,
    .ai-video-testimonials__close-icon-{{ ai_gen_id }}::after {
      width: 22px;
    }
  }
{% endstyle %}

<video-testimonials-{{ ai_gen_id }} class="ai-video-testimonials-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-video-testimonials__container-{{ ai_gen_id }}">
    <div class="ai-video-testimonials__header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-video-testimonials__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <p class="ai-video-testimonials__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="ai-video-testimonials__carousel-wrapper-{{ ai_gen_id }}">
      <div class="ai-video-testimonials__carousel-track-{{ ai_gen_id }}" data-carousel-track>
        {% for i in (1..4) %}
          {% liquid
            assign video_key = 'video_' | append: i
            assign poster_key = 'poster_' | append: i
            assign badge_key = 'badge_' | append: i
            assign name_key = 'name_' | append: i
            assign review_key = 'review_' | append: i
            assign show_stars_key = 'show_stars_' | append: i

            assign video = block.settings[video_key]
            assign poster = block.settings[poster_key]
            assign badge = block.settings[badge_key]
            assign name = block.settings[name_key]
            assign review = block.settings[review_key]
            assign show_stars = block.settings[show_stars_key]
          %}

          <div class="ai-video-testimonials__card-{{ ai_gen_id }}" data-card="{{ i }}">
            <div class="ai-video-testimonials__video-wrapper-{{ ai_gen_id }}" data-video-wrapper="{{ i }}">
              {% if video != blank %}
                <video
                  class="ai-video-testimonials__video-{{ ai_gen_id }}"
                  {% if poster != blank %}
                    poster="{{ poster | image_url: width: 600 }}"
                  {% endif %}
                  preload="metadata"
                  playsinline
                  data-video="{{ i }}"
                  data-video-src="{{ video.sources[0].url }}"
                  data-video-type="{{ video.sources[0].mime_type }}"
                >
                  <source src="{{ video.sources[0].url }}" type="{{ video.sources[0].mime_type }}">
                </video>
                <button
                  class="ai-video-testimonials__play-button-{{ ai_gen_id }}"
                  aria-label="Play video"
                  data-play-button="{{ i }}"
                >
                  <div class="ai-video-testimonials__play-icon-{{ ai_gen_id }}"></div>
                </button>
              {% else %}
                <div style="width: 100%; height: 100%; background: #f4f4f4; display: flex; align-items: center; justify-content: center; color: #999; font-size: 13px; text-align: center; padding: 20px;">
                  Add video {{ i }}
                </div>
              {% endif %}
            </div>

            {% if badge != blank %}
              <div class="ai-video-testimonials__badge-{{ ai_gen_id }}">{{ badge }}</div>
            {% endif %}

            {% if show_stars %}
              <div class="ai-video-testimonials__stars-{{ ai_gen_id }}">
                {% for star in (1..5) %}
                  <span class="ai-video-testimonials__star-{{ ai_gen_id }}">★</span>
                {% endfor %}
              </div>
            {% endif %}

            {% if name != blank %}
              <h3 class="ai-video-testimonials__customer-name-{{ ai_gen_id }}">{{ name }}</h3>
            {% endif %}

            {% if review != blank %}
              <p class="ai-video-testimonials__review-text-{{ ai_gen_id }}">{{ review }}</p>
            {% endif %}
          </div>
        {% endfor %}

        {% for i in (1..4) %}
          {% liquid
            assign video_key = 'video_' | append: i
            assign poster_key = 'poster_' | append: i
            assign badge_key = 'badge_' | append: i
            assign name_key = 'name_' | append: i
            assign review_key = 'review_' | append: i
            assign show_stars_key = 'show_stars_' | append: i

            assign video = block.settings[video_key]
            assign poster = block.settings[poster_key]
            assign badge = block.settings[badge_key]
            assign name = block.settings[name_key]
            assign review = block.settings[review_key]
            assign show_stars = block.settings[show_stars_key]
          %}

          <div class="ai-video-testimonials__card-{{ ai_gen_id }}" data-card="{{ i }}-clone" aria-hidden="true">
            <div class="ai-video-testimonials__video-wrapper-{{ ai_gen_id }}" data-video-wrapper="{{ i }}-clone">
              {% if video != blank %}
                <video
                  class="ai-video-testimonials__video-{{ ai_gen_id }}"
                  {% if poster != blank %}
                    poster="{{ poster | image_url: width: 600 }}"
                  {% endif %}
                  preload="metadata"
                  playsinline
                  data-video="{{ i }}-clone"
                  data-video-src="{{ video.sources[0].url }}"
                  data-video-type="{{ video.sources[0].mime_type }}"
                >
                  <source src="{{ video.sources[0].url }}" type="{{ video.sources[0].mime_type }}">
                </video>
                <button
                  class="ai-video-testimonials__play-button-{{ ai_gen_id }}"
                  aria-label="Play video"
                  data-play-button="{{ i }}-clone"
                >
                  <div class="ai-video-testimonials__play-icon-{{ ai_gen_id }}"></div>
                </button>
              {% else %}
                <div style="width: 100%; height: 100%; background: #f4f4f4; display: flex; align-items: center; justify-content: center; color: #999; font-size: 13px; text-align: center; padding: 20px;">
                  Add video {{ i }}
                </div>
              {% endif %}
            </div>

            {% if badge != blank %}
              <div class="ai-video-testimonials__badge-{{ ai_gen_id }}">{{ badge }}</div>
            {% endif %}

            {% if show_stars %}
              <div class="ai-video-testimonials__stars-{{ ai_gen_id }}">
                {% for star in (1..5) %}
                  <span class="ai-video-testimonials__star-{{ ai_gen_id }}">★</span>
                {% endfor %}
              </div>
            {% endif %}

            {% if name != blank %}
              <h3 class="ai-video-testimonials__customer-name-{{ ai_gen_id }}">{{ name }}</h3>
            {% endif %}

            {% if review != blank %}
              <p class="ai-video-testimonials__review-text-{{ ai_gen_id }}">{{ review }}</p>
            {% endif %}
          </div>
        {% endfor %}
      </div>
    </div>
  </div>

  <div class="ai-video-testimonials__modal-{{ ai_gen_id }}" data-modal>
    <button
      class="ai-video-testimonials__close-button-{{ ai_gen_id }}"
      aria-label="Close video"
      data-close-button
    >
      <div class="ai-video-testimonials__close-icon-{{ ai_gen_id }}"></div>
    </button>
    <div class="ai-video-testimonials__modal-content-{{ ai_gen_id }}">
      <video
        class="ai-video-testimonials__modal-video-{{ ai_gen_id }}"
        controls
        playsinline
        data-modal-video
      ></video>
    </div>
  </div>
</video-testimonials-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoTestimonials{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.track = this.querySelector('[data-carousel-track]');
        this.videoWrappers = this.querySelectorAll('[data-video-wrapper]');
        this.modal = this.querySelector('[data-modal]');
        this.modalVideo = this.querySelector('[data-modal-video]');
        this.closeButton = this.querySelector('[data-close-button]');
      }

      connectedCallback() {
        this.setupVideoControls();
        this.setupModal();
      }

      setupVideoControls() {
        this.videoWrappers.forEach((wrapper) => {
          const video = wrapper.querySelector('[data-video]');
          if (!video) return;

          wrapper.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            this.openModal(video);
          });
        });
      }

      setupModal() {
        this.closeButton.addEventListener('click', (e) => {
          e.stopPropagation();
          this.closeModal();
        });

        this.modal.addEventListener('click', (e) => {
          if (e.target === this.modal) {
            this.closeModal();
          }
        });

        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && this.modal.classList.contains('active')) {
            this.closeModal();
          }
        });
      }

      openModal(video) {
        const videoSrc = video.dataset.videoSrc;
        const videoType = video.dataset.videoType;

        if (!videoSrc) return;

        this.modalVideo.innerHTML = '';
        const source = document.createElement('source');
        source.src = videoSrc;
        source.type = videoType;
        this.modalVideo.appendChild(source);

        this.modalVideo.load();
        this.modal.classList.add('active');
        document.body.style.overflow = 'hidden';

        this.modalVideo.play();
      }

      closeModal() {
        this.modal.classList.remove('active');
        this.modalVideo.pause();
        this.modalVideo.currentTime = 0;
        document.body.style.overflow = '';
      }
    }

    customElements.define('video-testimonials-{{ ai_gen_id }}', VideoTestimonials{{ ai_gen_id }});
  })();
</script>

