{% doc %}
  @prompt
    Create a New Video Testimonial Carousel Section
    
    Place this section directly below the Hero Section and above the written reviews section.
    
    The goal is to create a premium video testimonial carousel similar to leading wellness brands.
    
    ⸻
    
    Section Title
    
    Real People. Real Results.
    
    Supporting Text
    
    Hear directly from people who have made Calm Nights part of their nightly routine.
    
    ⸻
    
    Layout Requirements
    
    Create a horizontal video carousel.
    
    Users should be able to:
    
    Swipe left and right on mobile
    
    Click left and right arrows on desktop
    
    Scroll through multiple testimonial videos
    
    Tap any video to play it directly inside the carousel
    
    The carousel should support at least 4 uploaded videos.
    
    Create placeholders for:
    
    Video 1
    
    Video 2
    
    Video 3
    
    Video 4
    
    Allow me to easily replace each placeholder with my own uploaded video later.
    
    ⸻
    
    Card Design
    
    Each video should appear inside its own premium card.
    
    Each card should include:
    
    Vertical TikTok/Reel style video format
    
    Rounded corners
    
    Soft shadow
    
    White card background
    
    Consistent video sizing
    
    Smooth scrolling animation
    
    Display one primary video centered on screen with the next and previous video partially visible on each side, similar to premium product testimonial carousels.
    
    ⸻
    
    Video Labels
    
    Allow a small badge above each video.
    
    Examples:
    
    BENEFITS
    
    SLEEP QUALITY
    
    FALL ASLEEP FASTER
    
    WAKE UP REFRESHED
    
    Allow these labels to be edited later.
    
    ⸻
    
    Optional Review Text
    
    Under each video, allow:
    
    Customer name
    
    Short review headline
    
    Examples:
    
    ★★★★★ Sarah M.
    
    "Best sleep I've had in years."
    
    ★★★★★ Jake T.
    
    "Finally waking up refreshed."
    
    Make these fields editable.
    
    ⸻
    
    Mobile Optimization
    
    This section must be optimized primarily for mobile.
    
    Video cards should be large enough to easily view facial expressions and captions.
    
    Keep spacing clean and premium.
    
    Maintain Ariya's branding:
    
    White backgrounds
    
    Ariya purple accents
    
    Black text
    
    Rounded corners
    
    Luxury wellness aesthetic
    
    ⸻
    
    Goal
    
    Create a highly visual social proof section that immediately builds trust and allows visitors to watch multiple customer testimonials without leaving the product page.
    
    The section should feel similar to premium wellness brands that showcase user-generated video reviews through a swipeable video carousel., give me the option to insert videos from my files instead of having to paste a link
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-video-testimonials-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 60px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-video-testimonials__container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-video-testimonials__header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 40px;
  }

  .ai-video-testimonials__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-video-testimonials__subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    margin: 0;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-video-testimonials__carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
    overflow: hidden;
    padding: 20px 0;
  }

  .ai-video-testimonials__carousel-{{ ai_gen_id }} {
    display: flex;
    gap: 20px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding: 0 calc(50% - {{ block.settings.card_width }}px / 2);
  }

  .ai-video-testimonials__carousel-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-video-testimonials__card-{{ ai_gen_id }} {
    flex: 0 0 {{ block.settings.card_width }}px;
    scroll-snap-align: center;
    background: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    box-shadow: 0 4px 20px rgba(26, 10, 46, 0.1);
    padding: 16px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-video-testimonials__card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 30px rgba(60, 14, 102, 0.15);
  }

  .ai-video-testimonials__badge-{{ ai_gen_id }} {
    display: inline-block;
    background: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 12px;
  }

  .ai-video-testimonials__video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: 9 / 16;
    border-radius: {{ block.settings.video_border_radius }}px;
    overflow: hidden;
    background: #f4f4f4;
    margin-bottom: 16px;
  }

  .ai-video-testimonials__video-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-video-testimonials__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #F9F6FF 0%, #e8d9f7 100%);
    color: #6b5a85;
    padding: 20px;
    text-align: center;
  }

  .ai-video-testimonials__placeholder-icon-{{ ai_gen_id }} {
    width: 60px;
    height: 60px;
    margin-bottom: 12px;
    opacity: 0.5;
  }

  .ai-video-testimonials__placeholder-text-{{ ai_gen_id }} {
    font-size: 13px;
    font-weight: 500;
  }

  .ai-video-testimonials__review-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-video-testimonials__stars-{{ ai_gen_id }} {
    color: {{ block.settings.star_color }};
    font-size: 14px;
    margin-bottom: 8px;
  }

  .ai-video-testimonials__customer-name-{{ ai_gen_id }} {
    font-size: 14px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin-bottom: 4px;
  }

  .ai-video-testimonials__review-text-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    font-style: italic;
  }

  .ai-video-testimonials__nav-{{ ai_gen_id }} {
    display: none;
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: {{ block.settings.card_background }};
    border: none;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    cursor: pointer;
    box-shadow: 0 4px 12px rgba(26, 10, 46, 0.15);
    z-index: 10;
    transition: all 0.3s ease;
  }

  .ai-video-testimonials__nav-{{ ai_gen_id }}:hover {
    background: {{ block.settings.badge_background }};
    transform: translateY(-50%) scale(1.1);
  }

  .ai-video-testimonials__nav-{{ ai_gen_id }} svg {
    width: 24px;
    height: 24px;
    stroke: {{ block.settings.text_color }};
  }

  .ai-video-testimonials__nav--prev-{{ ai_gen_id }} {
    left: 20px;
  }

  .ai-video-testimonials__nav--next-{{ ai_gen_id }} {
    right: 20px;
  }

  @media screen and (min-width: 750px) {
    .ai-video-testimonials-{{ ai_gen_id }} {
      padding: 80px 40px;
    }

    .ai-video-testimonials__title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 1.2 }}px;
    }

    .ai-video-testimonials__subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size | times: 1.1 }}px;
    }

    .ai-video-testimonials__nav-{{ ai_gen_id }} {
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .ai-video-testimonials__carousel-{{ ai_gen_id }} {
      gap: 30px;
    }
  }

  @media screen and (max-width: 749px) {
    .ai-video-testimonials__carousel-{{ ai_gen_id }} {
      padding: 0 20px;
    }

    .ai-video-testimonials__card-{{ ai_gen_id }} {
      flex: 0 0 {{ block.settings.card_width | times: 0.85 }}px;
    }
  }
{% endstyle %}

<video-testimonials-{{ ai_gen_id }}
  class="ai-video-testimonials-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-video-testimonials__container-{{ ai_gen_id }}">
    <div class="ai-video-testimonials__header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-video-testimonials__title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <p class="ai-video-testimonials__subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="ai-video-testimonials__carousel-wrapper-{{ ai_gen_id }}">
      <button
        class="ai-video-testimonials__nav-{{ ai_gen_id }} ai-video-testimonials__nav--prev-{{ ai_gen_id }}"
        aria-label="Previous testimonial"
        data-nav="prev"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
      </button>

      <div class="ai-video-testimonials__carousel-{{ ai_gen_id }}" data-carousel>
        {% for i in (1..4) %}
          {% liquid
            assign video_key = 'video_' | append: i
            assign badge_key = 'badge_' | append: i
            assign name_key = 'customer_name_' | append: i
            assign review_key = 'review_text_' | append: i
            assign show_stars_key = 'show_stars_' | append: i

            assign video = block.settings[video_key]
            assign badge = block.settings[badge_key]
            assign customer_name = block.settings[name_key]
            assign review_text = block.settings[review_key]
            assign show_stars = block.settings[show_stars_key]
          %}

          <div class="ai-video-testimonials__card-{{ ai_gen_id }}">
            {% if badge != blank %}
              <div class="ai-video-testimonials__badge-{{ ai_gen_id }}">{{ badge }}</div>
            {% endif %}

            <div class="ai-video-testimonials__video-wrapper-{{ ai_gen_id }}">
              {% if video != blank %}
                <video
                  class="ai-video-testimonials__video-{{ ai_gen_id }}"
                  controls
                  playsinline
                  preload="metadata"
                >
                  <source src="{{ video }}" type="video/mp4">
                  Your browser does not support the video tag.
                </video>
              {% else %}
                <div class="ai-video-testimonials__placeholder-{{ ai_gen_id }}">
                  <svg class="ai-video-testimonials__placeholder-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" />
                  </svg>
                  <div class="ai-video-testimonials__placeholder-text-{{ ai_gen_id }}">
                    Upload video {{ i }}
                  </div>
                </div>
              {% endif %}
            </div>

            {% if customer_name != blank or review_text != blank %}
              <div class="ai-video-testimonials__review-{{ ai_gen_id }}">
                {% if show_stars %}
                  <div class="ai-video-testimonials__stars-{{ ai_gen_id }}">★★★★★</div>
                {% endif %}
                {% if customer_name != blank %}
                  <div class="ai-video-testimonials__customer-name-{{ ai_gen_id }}">{{ customer_name }}</div>
                {% endif %}
                {% if review_text != blank %}
                  <div class="ai-video-testimonials__review-text-{{ ai_gen_id }}">"{{ review_text }}"</div>
                {% endif %}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>

      <button
        class="ai-video-testimonials__nav-{{ ai_gen_id }} ai-video-testimonials__nav--next-{{ ai_gen_id }}"
        aria-label="Next testimonial"
        data-nav="next"
      >
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </button>
    </div>
  </div>
</video-testimonials-{{ ai_gen_id }}>

<script>
  (function() {
    class VideoTestimonials{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.carousel = this.querySelector('[data-carousel]');
        this.prevButton = this.querySelector('[data-nav="prev"]');
        this.nextButton = this.querySelector('[data-nav="next"]');
        this.cards = this.querySelectorAll('.ai-video-testimonials__card-{{ ai_gen_id }}');
        this.cardWidth = this.cards[0]?.offsetWidth || 0;
        this.gap = 20;

        if (window.innerWidth >= 750) {
          this.gap = 30;
        }

        this.setupEventListeners();
        this.pauseAllVideos();
      }

      setupEventListeners() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => this.scroll('prev'));
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => this.scroll('next'));
        }

        this.carousel.addEventListener('scroll', () => {
          this.pauseAllVideos();
        });

        const videos = this.querySelectorAll('.ai-video-testimonials__video-{{ ai_gen_id }}');
        videos.forEach(video => {
          video.addEventListener('play', (e) => {
            videos.forEach(v => {
              if (v !== e.target) {
                v.pause();
              }
            });
          });
        });
      }

      scroll(direction) {
        const scrollAmount = this.cardWidth + this.gap;
        const currentScroll = this.carousel.scrollLeft;

        if (direction === 'next') {
          this.carousel.scrollLeft = currentScroll + scrollAmount;
        } else {
          this.carousel.scrollLeft = currentScroll - scrollAmount;
        }
      }

      pauseAllVideos() {
        const videos = this.querySelectorAll('.ai-video-testimonials__video-{{ ai_gen_id }}');
        videos.forEach(video => {
          if (!video.paused) {
            video.pause();
          }
        });
      }
    }

    customElements.define('video-testimonials-{{ ai_gen_id }}', VideoTestimonials{{ ai_gen_id }});
  })();
</script>

