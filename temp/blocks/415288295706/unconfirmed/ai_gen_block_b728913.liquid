{% doc %}
  @prompt
    Create a New “Why Sleep Matters” SectionCreate a new section inspired by the simple statistics layout used by premium wellness brands.LayoutAllow a large image at the top of the section that can be uploaded and changed inside the Shopify editor.Image should be full width with rounded corners.Keep the section clean, minimal, and easy to scan.No icons.No decorative graphics.No extra cards.No animations.Use a simple vertical flow:ImageHeadlineShort supporting textStatistic 1Statistic 2Design StyleWhite backgroundAriya purple for numbers and headingsDark text for descriptionsLarge bold percentagesMinimal spacingMobile-first designInspired by the clean simplicity of Grüns’ statistics sectionContentHeadlineModern Life Makes Restful Sleep Harder Than EverSupporting TextStress, screens, and constant stimulation make it harder to unwind and get quality sleep.Statistic 174%of adults say stress disrupts their sleep.Statistic 272%of adults experience daytime sleepiness linked to:Mood Changes • Increased Stress • Lower ProductivityTypographyPercentages should be the largest element in the section.Headline should be bold and easy to read.Descriptions should be noticeably smaller than the percentages.Center align all content.ImportantKeep this section extremely simple.Do not add icons, badges, symbols, extra statistics, explanations, or feature callouts.The goal is to create a clean, high-impact visual section where the large percentages immediately grab attention, similar to premium wellness brands., at the bottom put this,                                          That’s Why We Created Calm Nights.
    Melatonin-free sleep support designed to quiet a racing mind and help you wake up feeling rested., at the bottom
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-sleep-stats-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 20px;
  }

  .ai-sleep-stats-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    text-align: center;
  }

  .ai-sleep-stats-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: {{ block.settings.spacing_after_image }}px;
  }

  .ai-sleep-stats-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: block;
  }

  .ai-sleep-stats-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-sleep-stats-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-sleep-stats-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-sleep-stats-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    font-weight: 700;
    color: {{ block.settings.headline_color }};
    margin: 0 0 {{ block.settings.spacing_after_headline }}px 0;
    line-height: 1.2;
  }

  .ai-sleep-stats-supporting-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.supporting_text_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0 0 {{ block.settings.spacing_after_supporting }}px 0;
    line-height: 1.5;
  }

  .ai-sleep-stats-stat-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.spacing_between_stats }}px;
  }

  .ai-sleep-stats-stat-{{ ai_gen_id }}:last-of-type {
    margin-bottom: {{ block.settings.spacing_after_stats }}px;
  }

  .ai-sleep-stats-percentage-{{ ai_gen_id }} {
    font-size: {{ block.settings.percentage_size }}px;
    font-weight: 700;
    color: {{ block.settings.percentage_color }};
    margin: 0 0 {{ block.settings.spacing_after_percentage }}px 0;
    line-height: 1;
  }

  .ai-sleep-stats-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-sleep-stats-cta-{{ ai_gen_id }} {
    font-size: {{ block.settings.cta_size }}px;
    font-weight: 600;
    color: {{ block.settings.cta_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .ai-sleep-stats-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.7 }}px;
    }

    .ai-sleep-stats-percentage-{{ ai_gen_id }} {
      font-size: {{ block.settings.percentage_size | times: 0.6 }}px;
    }

    .ai-sleep-stats-supporting-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.supporting_text_size | times: 0.9 }}px;
    }

    .ai-sleep-stats-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size | times: 0.9 }}px;
    }

    .ai-sleep-stats-cta-{{ ai_gen_id }} {
      font-size: {{ block.settings.cta_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-sleep-stats-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-sleep-stats-container-{{ ai_gen_id }}">
    {% if block.settings.image != blank %}
      <div class="ai-sleep-stats-image-wrapper-{{ ai_gen_id }}">
        <img
          src="{{ block.settings.image | image_url: width: 2000 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-sleep-stats-image-{{ ai_gen_id }}"
        >
      </div>
    {% else %}
      <div class="ai-sleep-stats-image-wrapper-{{ ai_gen_id }}">
        <div class="ai-sleep-stats-image-placeholder-{{ ai_gen_id }}">
          {{ 'lifestyle-1' | placeholder_svg_tag }}
          <div class="ai-sleep-stats-empty-state-{{ ai_gen_id }}">
            Add an image to get started
          </div>
        </div>
      </div>
    {% endif %}

    {% if block.settings.headline != blank %}
      <h2 class="ai-sleep-stats-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
    {% endif %}

    {% if block.settings.supporting_text != blank %}
      <p class="ai-sleep-stats-supporting-text-{{ ai_gen_id }}">{{ block.settings.supporting_text }}</p>
    {% endif %}

    {% if block.settings.stat_1_percentage != blank %}
      <div class="ai-sleep-stats-stat-{{ ai_gen_id }}">
        <div class="ai-sleep-stats-percentage-{{ ai_gen_id }}">{{ block.settings.stat_1_percentage }}</div>
        {% if block.settings.stat_1_description != blank %}
          <p class="ai-sleep-stats-description-{{ ai_gen_id }}">{{ block.settings.stat_1_description }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.stat_2_percentage != blank %}
      <div class="ai-sleep-stats-stat-{{ ai_gen_id }}">
        <div class="ai-sleep-stats-percentage-{{ ai_gen_id }}">{{ block.settings.stat_2_percentage }}</div>
        {% if block.settings.stat_2_description != blank %}
          <p class="ai-sleep-stats-description-{{ ai_gen_id }}">{{ block.settings.stat_2_description }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.cta_text != blank %}
      <p class="ai-sleep-stats-cta-{{ ai_gen_id }}">{{ block.settings.cta_text }}</p>
    {% endif %}
  </div>
</div>

