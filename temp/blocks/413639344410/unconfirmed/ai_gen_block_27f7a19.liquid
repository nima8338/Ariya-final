<script>
  (function() {
    class CalmNightsBenefits{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.accordionItems = this.querySelectorAll('[data-accordion-item]');
        this.setupAccordions();
      }

      setupAccordions() {
        this.accordionItems.forEach((item) => {
          const header = item.querySelector('.ai-benefits-accordion-header-{{ ai_gen_id }}');
          const content = item.querySelector('.ai-benefits-accordion-content-{{ ai_gen_id }}');
          const contentInner = item.querySelector('.ai-benefits-accordion-content-inner-{{ ai_gen_id }}');

          header.addEventListener('click', () => {
            const isActive = item.classList.contains('active');

            this.accordionItems.forEach((otherItem) => {
              if (otherItem !== item) {
                otherItem.classList.remove('active');
                const otherContent = otherItem.querySelector('.ai-benefits-accordion-content-{{ ai_gen_id }}');
                const otherHeader = otherItem.querySelector('.ai-benefits-accordion-header-{{ ai_gen_id }}');
                otherContent.style.maxHeight = null;
                otherHeader.setAttribute('aria-expanded', 'false');
              }
            });

            if (isActive) {
              item.classList.remove('active');
              content.style.maxHeight = null;
              header.setAttribute('aria-expanded', 'false');
            } else {
              item.classList.add('active');
              content.style.maxHeight = contentInner.scrollHeight + 'px';
              header.setAttribute('aria-expanded', 'true');
            }
          });
        });
      }
    }

    customElements.define('calm-nights-benefits-{{ ai_gen_id }}', CalmNightsBenefits{{ ai_gen_id }});
  })();
</script>

