    width: 100%;
    height: 100%;
    stroke: {{ block.settings.icon_color }};
    fill: none;
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-benefits-text-wrapper-{{ ai_gen_id }} {
    flex-grow: 1;
  }

