{% doc %}
  @prompt
    Create a premium featured product section for Ariya Supplements’ Calm Nights.
    
    Goal:
    Recreate a clean, aesthetic product feature block with the product image on the left and product details on the right. Make it feel premium, calm, natural, and trustworthy.
    
    Layout:
    Desktop: 2-column layout.
    Left side: large rounded product image card.
    Right side: product title, short description, benefit bullets, price, serving info, shipping line, Add to Cart button, and View Full Details button.
    Mobile: stack image on top and product details underneath.
    
    Design Style:
    Use a soft cream/off-white background.
    Keep the section spacious with lots of white space.
    Use rounded corners on the image.
    Use Ariya purple for buttons, icons, and accents.
    Use gold only for small badges or subtle highlights.
    Make it elegant and minimal, not crowded.
    Match the current Ariya website fonts and style.
    
    Top Badge:
    Melatonin-Free
    
    Product Title:
    Calm Nights
    
    Description:
    A melatonin-free sleep support formula built with standardized extracts to help you unwind, sleep deeper, and wake up refreshed.
    
    Benefit Bullets:
    ✓ Fall asleep faster and naturally
    ✓ Wake up refreshed, not groggy
    ✓ Supports natural sleep pathways
    ✓ Helps calm nighttime stress
    ✓ No proprietary blends
    
    Price:
    $35.00
    
    Serving Info:
    60 capsules • 30 servings
    
    Value Line:
    $0.99/night with subscription
    
    Shipping Line:
    Free shipping
    
    Buttons:
    Primary button: Add to Cart
    Secondary button: View Full Details
    
    Functionality:
    Make the section connected to the Calm Nights product so the Add to Cart button adds the product directly to cart.
    The View Full Details button should link to the Calm Nights product page.
    
    Image:
    Add an editable image field so we can upload the Calm Nights bottle image.
    The image should be large, aesthetic, rounded, and aligned nicely with the product text.
    
    Important:
    Make the section look polished and premium on both desktop and mobile.
    Do not make it look like a basic Shopify product block.
    Keep the copy short and conversion-focused., move the melatonin free banner to the top left of the image 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-featured-product-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 20px;
  }

  .ai-featured-product-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: {{ block.settings.column_gap }}px;
    align-items: center;
  }

  .ai-featured-product-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
  }

  .ai-featured-product-image-card-{{ ai_gen_id }} {
    position: relative;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: visible;
    background-color: #ffffff;
  }

  .ai-featured-product-image-card-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-featured-product-badge-{{ ai_gen_id }} {
    position: absolute;
    top: -10px;
    left: -10px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    padding: 8px 16px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    z-index: 2;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .ai-featured-product-content-{{ ai_gen_id }} {
    padding: 0 20px;
  }

  .ai-featured-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: 600;
    color: {{ block.settings.text_color }};
    margin: 0 0 16px 0;
    line-height: 1.2;
  }

  .ai-featured-product-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0 0 24px 0;
    opacity: 0.9;
  }

  .ai-featured-product-benefits-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0 0 32px 0;
  }

  .ai-featured-product-benefit-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    margin-bottom: 12px;
    font-size: {{ block.settings.benefit_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.5;
  }

  .ai-featured-product-benefit-icon-{{ ai_gen_id }} {
    color: {{ block.settings.accent_color }};
    flex-shrink: 0;
    margin-top: 2px;
    font-weight: 700;
  }

  .ai-featured-product-price-section-{{ ai_gen_id }} {
    margin-bottom: 16px;
  }

  .ai-featured-product-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    margin: 0 0 8px 0;
  }

  .ai-featured-product-serving-{{ ai_gen_id }} {
    font-size: {{ block.settings.meta_size }}px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    margin: 0 0 8px 0;
  }

  .ai-featured-product-value-{{ ai_gen_id }} {
    font-size: {{ block.settings.meta_size }}px;
    color: {{ block.settings.accent_color }};
    font-weight: 600;
    margin: 0 0 8px 0;
  }

  .ai-featured-product-shipping-{{ ai_gen_id }} {
    font-size: {{ block.settings.meta_size }}px;
    color: {{ block.settings.accent_color }};
    font-weight: 600;
    margin: 0 0 24px 0;
  }

  .ai-featured-product-buttons-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .ai-featured-product-button-primary-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px 32px;
    background-color: {{ block.settings.primary_button_bg }};
    color: {{ block.settings.primary_button_text_color }};
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_size }}px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    text-decoration: none;
    display: inline-block;
  }

  .ai-featured-product-button-primary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.primary_button_hover_bg }};
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(60, 14, 102, 0.2);
  }

  .ai-featured-product-button-secondary-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px 32px;
    background-color: transparent;
    color: {{ block.settings.secondary_button_text_color }};
    border: 2px solid {{ block.settings.secondary_button_border }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_size }}px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    text-align: center;
    text-decoration: none;
    display: inline-block;
  }

  .ai-featured-product-button-secondary-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.secondary_button_hover_bg }};
    border-color: {{ block.settings.secondary_button_hover_border }};
    color: {{ block.settings.secondary_button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-featured-product-container-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .ai-featured-product-content-{{ ai_gen_id }} {
      padding: 0;
    }

    .ai-featured-product-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | times: 0.8 }}px;
    }

    .ai-featured-product-price-{{ ai_gen_id }} {
      font-size: {{ block.settings.price_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<ariya-featured-product-{{ ai_gen_id }}
  class="ai-featured-product-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
  data-product-id="{{ block.settings.product.id }}"
>
  <div class="ai-featured-product-container-{{ ai_gen_id }}">
    <div class="ai-featured-product-image-wrapper-{{ ai_gen_id }}">
      <div class="ai-featured-product-image-card-{{ ai_gen_id }}">
        {% if block.settings.show_badge and block.settings.badge_text != blank %}
          <div class="ai-featured-product-badge-{{ ai_gen_id }}">
            {{ block.settings.badge_text }}
          </div>
        {% endif %}
        {% if block.settings.product_image %}
          <img
            src="{{ block.settings.product_image | image_url: width: 1200 }}"
            alt="{{ block.settings.product_image.alt | default: block.settings.product.title | escape }}"
            loading="lazy"
            width="{{ block.settings.product_image.width }}"
            height="{{ block.settings.product_image.height }}"
          >
        {% elsif block.settings.product.featured_image %}
          <img
            src="{{ block.settings.product.featured_image | image_url: width: 1200 }}"
            alt="{{ block.settings.product.featured_image.alt | default: block.settings.product.title | escape }}"
            loading="lazy"
            width="{{ block.settings.product.featured_image.width }}"
            height="{{ block.settings.product.featured_image.height }}"
          >
        {% else %}
          <div style="background: #f9f6ff; aspect-ratio: 1; display: flex; align-items: center; justify-content: center; border-radius: {{ block.settings.image_border_radius }}px;">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-featured-product-content-{{ ai_gen_id }}">
      {% if block.settings.product_title != blank %}
        <h2 class="ai-featured-product-title-{{ ai_gen_id }}">
          {{ block.settings.product_title }}
        </h2>
      {% elsif block.settings.product %}
        <h2 class="ai-featured-product-title-{{ ai_gen_id }}">
          {{ block.settings.product.title }}
        </h2>
      {% endif %}

      {% if block.settings.product_description != blank %}
        <div class="ai-featured-product-description-{{ ai_gen_id }}">
          {{ block.settings.product_description }}
        </div>
      {% endif %}

      {% if block.settings.show_benefits %}
        <ul class="ai-featured-product-benefits-{{ ai_gen_id }}">
          {% if block.settings.benefit_1 != blank %}
            <li class="ai-featured-product-benefit-{{ ai_gen_id }}">
              <span class="ai-featured-product-benefit-icon-{{ ai_gen_id }}">✓</span>
              <span>{{ block.settings.benefit_1 }}</span>
            </li>
          {% endif %}
          {% if block.settings.benefit_2 != blank %}
            <li class="ai-featured-product-benefit-{{ ai_gen_id }}">
              <span class="ai-featured-product-benefit-icon-{{ ai_gen_id }}">✓</span>
              <span>{{ block.settings.benefit_2 }}</span>
            </li>
          {% endif %}
          {% if block.settings.benefit_3 != blank %}
            <li class="ai-featured-product-benefit-{{ ai_gen_id }}">
              <span class="ai-featured-product-benefit-icon-{{ ai_gen_id }}">✓</span>
              <span>{{ block.settings.benefit_3 }}</span>
            </li>
          {% endif %}
          {% if block.settings.benefit_4 != blank %}
            <li class="ai-featured-product-benefit-{{ ai_gen_id }}">
              <span class="ai-featured-product-benefit-icon-{{ ai_gen_id }}">✓</span>
              <span>{{ block.settings.benefit_4 }}</span>
            </li>
          {% endif %}
          {% if block.settings.benefit_5 != blank %}
            <li class="ai-featured-product-benefit-{{ ai_gen_id }}">
              <span class="ai-featured-product-benefit-icon-{{ ai_gen_id }}">✓</span>
              <span>{{ block.settings.benefit_5 }}</span>
            </li>
          {% endif %}
        </ul>
      {% endif %}

      <div class="ai-featured-product-price-section-{{ ai_gen_id }}">
        {% if block.settings.custom_price != blank %}
          <div class="ai-featured-product-price-{{ ai_gen_id }}">
            {{ block.settings.custom_price }}
          </div>
        {% elsif block.settings.product %}
          <div class="ai-featured-product-price-{{ ai_gen_id }}">
            {{ block.settings.product.price | money }}
          </div>
        {% endif %}

        {% if block.settings.serving_info != blank %}
          <div class="ai-featured-product-serving-{{ ai_gen_id }}">
            {{ block.settings.serving_info }}
          </div>
        {% endif %}

        {% if block.settings.value_line != blank %}
          <div class="ai-featured-product-value-{{ ai_gen_id }}">
            {{ block.settings.value_line }}
          </div>
        {% endif %}

        {% if block.settings.shipping_text != blank %}
          <div class="ai-featured-product-shipping-{{ ai_gen_id }}">
            {{ block.settings.shipping_text }}
          </div>
        {% endif %}
      </div>

      <div class="ai-featured-product-buttons-{{ ai_gen_id }}">
        {% if block.settings.product %}
          <button
            type="button"
            class="ai-featured-product-button-primary-{{ ai_gen_id }}"
            data-add-to-cart
          >
            {{ block.settings.primary_btn_text }}
          </button>
        {% else %}
          <a
            href="#"
            class="ai-featured-product-button-primary-{{ ai_gen_id }}"
          >
            {{ block.settings.primary_btn_text }}
          </a>
        {% endif %}

        {% if block.settings.product %}
          <a
            href="{{ block.settings.product.url }}"
            class="ai-featured-product-button-secondary-{{ ai_gen_id }}"
          >
            {{ block.settings.secondary_btn_text }}
          </a>
        {% else %}
          <a
            href="#"
            class="ai-featured-product-button-secondary-{{ ai_gen_id }}"
          >
            {{ block.settings.secondary_btn_text }}
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</ariya-featured-product-{{ ai_gen_id }}>

<script>
  (function() {
    class AriyaFeaturedProduct{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.addToCartButton = this.querySelector('[data-add-to-cart]');
        this.productId = this.dataset.productId;
      }

      connectedCallback() {
        if (this.addToCartButton && this.productId) {
          this.addToCartButton.addEventListener('click', this.handleAddToCart.bind(this));
        }
      }

      async handleAddToCart(event) {
        event.preventDefault();
        
        if (!this.productId) return;

        this.addToCartButton.disabled = true;
        const originalText = this.addToCartButton.textContent;
        this.addToCartButton.textContent = 'Adding...';

        try {
          const response = await fetch('/cart/add.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify({
              items: [{
                id: this.productId,
                quantity: 1
              }]
            })
          });

          if (!response.ok) {
            throw new Error('Failed to add to cart');
          }

          const data = await response.json();
          
          this.addToCartButton.textContent = 'Added!';
          
          setTimeout(function() {
            window.location.href = '/cart';
          }, 500);

        } catch (error) {
          console.error('Error adding to cart:', error);
          this.addToCartButton.textContent = 'Error - Try Again';
          this.addToCartButton.disabled = false;
          
          setTimeout(function() {
            this.addToCartButton.textContent = originalText;
          }.bind(this), 2000);
        }
      }
    }

    customElements.define('ariya-featured-product-{{ ai_gen_id }}', AriyaFeaturedProduct{{ ai_gen_id }});
  })();
</script>

