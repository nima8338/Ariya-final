{% doc %}
  @prompt
    create 2 horizontal 3 badges with a description, one needs to pop up when someone picked monthly subscription and the other needs to pop up when they picked a one time purchase, make all 3 of the badges line up next to each other and get rid of the boxes around each one, make the 3 badges line up horizontally together on mobile, make the words stay in the screen on mobile make it multiple lines if needed
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-subscription-badges-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-subscription-badges__container-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.badge_gap }}px;
    align-items: flex-start;
    justify-content: flex-start;
    flex-wrap: nowrap;
  }

  .ai-subscription-badges__badge-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: {{ block.settings.icon_text_gap }}px;
    flex: 1 1 0;
    min-width: 0;
  }

  .ai-subscription-badges__icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    flex-shrink: 0;
    color: {{ block.settings.icon_color }};
    margin-top: 2px;
  }

  .ai-subscription-badges__text-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.3;
    margin: 0;
    word-wrap: break-word;
    overflow-wrap: break-word;
  }

  .ai-subscription-badges__container-{{ ai_gen_id }}[data-hidden="true"] {
    display: none;
  }

  @media screen and (max-width: 749px) {
    .ai-subscription-badges__container-{{ ai_gen_id }} {
      gap: {{ block.settings.badge_gap | times: 0.6 }}px;
      flex-wrap: wrap;
    }

    .ai-subscription-badges__badge-{{ ai_gen_id }} {
      flex: 1 1 auto;
      min-width: 0;
    }

    .ai-subscription-badges__icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size | times: 0.8 }}px;
      height: {{ block.settings.icon_size | times: 0.8 }}px;
    }

    .ai-subscription-badges__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.85 }}px;
    }
  }
{% endstyle %}

<subscription-badges-{{ ai_gen_id }}
  class="ai-subscription-badges-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div
    class="ai-subscription-badges__container-{{ ai_gen_id }}"
    data-type="subscription"
    data-hidden="true"
  >
    <div class="ai-subscription-badges__badge-{{ ai_gen_id }}">
      <svg
        class="ai-subscription-badges__icon-{{ ai_gen_id }}"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M12 2v20M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"></path>
      </svg>
      <p class="ai-subscription-badges__text-{{ ai_gen_id }}">{{ block.settings.subscription_badge_1_text }}</p>
    </div>

    <div class="ai-subscription-badges__badge-{{ ai_gen_id }}">
      <svg
        class="ai-subscription-badges__icon-{{ ai_gen_id }}"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
        <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
        <line x1="12" y1="22.08" x2="12" y2="12"></line>
      </svg>
      <p class="ai-subscription-badges__text-{{ ai_gen_id }}">{{ block.settings.subscription_badge_2_text }}</p>
    </div>

    <div class="ai-subscription-badges__badge-{{ ai_gen_id }}">
      <svg
        class="ai-subscription-badges__icon-{{ ai_gen_id }}"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <circle cx="12" cy="12" r="10"></circle>
        <polyline points="12 6 12 12 16 14"></polyline>
      </svg>
      <p class="ai-subscription-badges__text-{{ ai_gen_id }}">{{ block.settings.subscription_badge_3_text }}</p>
    </div>
  </div>

  <div
    class="ai-subscription-badges__container-{{ ai_gen_id }}"
    data-type="onetime"
    data-hidden="true"
  >
    <div class="ai-subscription-badges__badge-{{ ai_gen_id }}">
      <svg
        class="ai-subscription-badges__icon-{{ ai_gen_id }}"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
        <circle cx="12" cy="7" r="4"></circle>
      </svg>
      <p class="ai-subscription-badges__text-{{ ai_gen_id }}">{{ block.settings.onetime_badge_1_text }}</p>
    </div>

    <div class="ai-subscription-badges__badge-{{ ai_gen_id }}">
      <svg
        class="ai-subscription-badges__icon-{{ ai_gen_id }}"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <polyline points="20 6 9 17 4 12"></polyline>
      </svg>
      <p class="ai-subscription-badges__text-{{ ai_gen_id }}">{{ block.settings.onetime_badge_2_text }}</p>
    </div>

    <div class="ai-subscription-badges__badge-{{ ai_gen_id }}">
      <svg
        class="ai-subscription-badges__icon-{{ ai_gen_id }}"
        xmlns="http://www.w3.org/2000/svg"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
        <polyline points="22 4 12 14.01 9 11.01"></polyline>
      </svg>
      <p class="ai-subscription-badges__text-{{ ai_gen_id }}">{{ block.settings.onetime_badge_3_text }}</p>
    </div>
  </div>
</subscription-badges-{{ ai_gen_id }}>

<script>
  (function() {
    class SubscriptionBadges{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.subscriptionContainer = this.querySelector('[data-type="subscription"]');
        this.onetimeContainer = this.querySelector('[data-type="onetime"]');
      }

      connectedCallback() {
        this.setupListeners();
        this.checkInitialState();
      }

      setupListeners() {
        const sellingPlanInputs = document.querySelectorAll('input[name="selling_plan"]');
        
        if (sellingPlanInputs.length > 0) {
          sellingPlanInputs.forEach(input => {
            input.addEventListener('change', () => this.handleSellingPlanChange());
          });
        }

        document.addEventListener('change', (event) => {
          if (event.target.name === 'selling_plan') {
            this.handleSellingPlanChange();
          }
        });
      }

      checkInitialState() {
        const checkedInput = document.querySelector('input[name="selling_plan"]:checked');
        
        if (checkedInput) {
          if (checkedInput.value === '' || checkedInput.value === 'null') {
            this.showOnetime();
          } else {
            this.showSubscription();
          }
        } else {
          this.showOnetime();
        }
      }

      handleSellingPlanChange() {
        const checkedInput = document.querySelector('input[name="selling_plan"]:checked');
        
        if (checkedInput) {
          if (checkedInput.value === '' || checkedInput.value === 'null') {
            this.showOnetime();
          } else {
            this.showSubscription();
          }
        }
      }

      showSubscription() {
        this.subscriptionContainer.setAttribute('data-hidden', 'false');
        this.onetimeContainer.setAttribute('data-hidden', 'true');
      }

      showOnetime() {
        this.subscriptionContainer.setAttribute('data-hidden', 'true');
        this.onetimeContainer.setAttribute('data-hidden', 'false');
      }
    }

    customElements.define('subscription-badges-{{ ai_gen_id }}', SubscriptionBadges{{ ai_gen_id }});
  })();
</script>

