{% doc %}
  @prompt
    create 2 horizontal 3 badges with a description, one needs to pop up when someone picked monthly subscription and the other needs to pop up when they picked a one time purchase, make all 3 of the badges line up next to each other and get rid of the boxes around each one, make the 3 badges line up horizontally together on mobile, make the words stay in the screen on mobile make it multiple lines if needed, get rid of the text and badges and change it to where i can insert a different picture for one time purchase and subscription, bring the image as high as you can cut any top part thats white space for both
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-subscription-image-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin-top: -{{ block.settings.top_offset }}px;
  }

  .ai-subscription-image__container-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-subscription-image__container-{{ ai_gen_id }}[data-hidden="true"] {
    display: none;
  }

  .ai-subscription-image__img-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-subscription-image__placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    min-height: 100px;
  }

  .ai-subscription-image__placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 100px;
  }

  .ai-subscription-image__empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    font-size: 12px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }
{% endstyle %}

<subscription-image-{{ ai_gen_id }}
  class="ai-subscription-image-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div
    class="ai-subscription-image__container-{{ ai_gen_id }}"
    data-type="subscription"
    data-hidden="true"
  >
    {% if block.settings.subscription_image %}
      <img
        src="{{ block.settings.subscription_image | image_url: width: 2000 }}"
        alt="{{ block.settings.subscription_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.subscription_image.width }}"
        height="{{ block.settings.subscription_image.height }}"
        class="ai-subscription-image__img-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-subscription-image__placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-subscription-image__empty-state-{{ ai_gen_id }}">
          Add subscription image
        </div>
      </div>
    {% endif %}
  </div>

  <div
    class="ai-subscription-image__container-{{ ai_gen_id }}"
    data-type="onetime"
    data-hidden="true"
  >
    {% if block.settings.onetime_image %}
      <img
        src="{{ block.settings.onetime_image | image_url: width: 2000 }}"
        alt="{{ block.settings.onetime_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.onetime_image.width }}"
        height="{{ block.settings.onetime_image.height }}"
        class="ai-subscription-image__img-{{ ai_gen_id }}"
      >
    {% else %}
      <div class="ai-subscription-image__placeholder-{{ ai_gen_id }}">
        {{ 'image' | placeholder_svg_tag }}
        <div class="ai-subscription-image__empty-state-{{ ai_gen_id }}">
          Add one-time purchase image
        </div>
      </div>
    {% endif %}
  </div>
</subscription-image-{{ ai_gen_id }}>

<script>
  (function() {
    class SubscriptionImage{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.subscriptionContainer = this.querySelector('[data-type="subscription"]');
        this.onetimeContainer = this.querySelector('[data-type="onetime"]');
      }

      connectedCallback() {
        this.setupListeners();
        this.checkInitialState();
      }

      setupListeners() {
        const sellingPlanInputs = document.querySelectorAll('input[name="selling_plan"]');
        
        if (sellingPlanInputs.length > 0) {
          sellingPlanInputs.forEach(input => {
            input.addEventListener('change', () => this.handleSellingPlanChange());
          });
        }

        document.addEventListener('change', (event) => {
          if (event.target.name === 'selling_plan') {
            this.handleSellingPlanChange();
          }
        });
      }

      checkInitialState() {
        const checkedInput = document.querySelector('input[name="selling_plan"]:checked');
        
        if (checkedInput) {
          if (checkedInput.value === '' || checkedInput.value === 'null') {
            this.showOnetime();
          } else {
            this.showSubscription();
          }
        } else {
          this.showOnetime();
        }
      }

      handleSellingPlanChange() {
        const checkedInput = document.querySelector('input[name="selling_plan"]:checked');
        
        if (checkedInput) {
          if (checkedInput.value === '' || checkedInput.value === 'null') {
            this.showOnetime();
          } else {
            this.showSubscription();
          }
        }
      }

      showSubscription() {
        this.subscriptionContainer.setAttribute('data-hidden', 'false');
        this.onetimeContainer.setAttribute('data-hidden', 'true');
      }

      showOnetime() {
        this.subscriptionContainer.setAttribute('data-hidden', 'true');
        this.onetimeContainer.setAttribute('data-hidden', 'false');
      }
    }

    customElements.define('subscription-image-{{ ai_gen_id }}', SubscriptionImage{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Subscription images",
  "settings": [
    {
      "type": "header",
      "content": "Subscription"
    },
    {
      "type": "image_picker",
      "id": "subscription_image",
      "label": "Subscription image"
    },
    {
      "type": "header",
      "content": "One time purchase"
    },
    {
      "type": "image_picker",
      "id": "onetime_image",
      "label": "One-time purchase image"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "top_offset",
      "label": "Move up",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Subscription images"
    }
  ]
}
{% endschema %}
