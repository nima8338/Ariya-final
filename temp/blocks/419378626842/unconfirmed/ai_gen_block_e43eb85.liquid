{% doc %}
  @prompt
    make a headline with a text option, make a background color option and make the textbox as long as possible horizontally, make the box reach the edges of the mobile version horizontally, the text needs to stay in one line just stretch out the background block horizontally as long as possible while keeping the text in one line
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-headline-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 100%;
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px {{ block.settings.padding_horizontal }}px;
    text-align: {{ block.settings.text_alignment }};
    background-color: {{ block.settings.background_color }};
  }

  .ai-headline__text-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.font_size }}px;
    line-height: {{ block.settings.line_height }};
    letter-spacing: {{ block.settings.letter_spacing }}em;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    {% if block.settings.text_transform == 'uppercase' %}
      text-transform: uppercase;
    {% endif %}
  }

  @media screen and (max-width: 749px) {
    .ai-headline-{{ ai_gen_id }} {
      padding-left: 0;
      padding-right: 0;
    }

    .ai-headline__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-headline-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.heading_text != blank %}
    <h2 class="ai-headline__text-{{ ai_gen_id }}">{{ block.settings.heading_text }}</h2>
  {% else %}
    <h2 class="ai-headline__text-{{ ai_gen_id }}">Add your headline text</h2>
  {% endif %}
</div>

{% schema %}
{
  "name": "Headline",
  "settings": [
    {
      "type": "text",
      "id": "heading_text",
      "label": "Headline text"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a0a2e"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 16,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "select",
      "id": "line_height",
      "label": "Line height",
      "options": [
        {
          "value": "1",
          "label": "Tight"
        },
        {
          "value": "1.2",
          "label": "Normal"
        },
        {
          "value": "1.5",
          "label": "Loose"
        }
      ],
      "default": "1.2"
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": -0.1,
      "max": 0.2,
      "step": 0.1,
      "default": 0
    },
    {
      "type": "select",
      "id": "text_transform",
      "label": "Text case",
      "options": [
        {
          "value": "none",
          "label": "Default"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        }
      ],
      "default": "none"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Headline"
    }
  ]
}
{% endschema %}
