{% doc %}
  @prompt
    Create a mobile-first educational statistics section for Ariya Supplements’ sleep product, Calm Nights.The design should feel premium, modern, and clean, similar to leading DTC wellness brands.Use Ariya’s purple branding, large bold statistics, plenty of white space, rounded corners, and a strong call-to-action button.Section Headline:Your Brain Wasn’t Designed For Modern Life.Supporting Text:Late-night scrolling. Constant notifications. Endless stimulation.Statistic #1:48%of Americans report frequent stress.Statistic #2:1 in 3adults don’t get enough sleep on a regular basis.Statistic #3:Millionsrely on sleep aids every night searching for better sleep.Transition Text:Modern life makes it harder than ever to slow down and relax before bed.CTA Headline:That’s Why We Created Calm Nights.CTA Text:Melatonin-free sleep support designed to help quiet a racing mind, promote relaxation, and help you wake up refreshed.Button Text:Shop Calm NightsDesign Notes:Large percentage numbers should be the visual focus.Statistics should stack vertically on mobile.Use subtle moon, sleep, or relaxation-themed icons.Maintain a premium luxury wellness aesthetic.Keep the section easy to scan in under 5 seconds.One thing I’d test against this version:The World Never Stops. Your Brain Never Gets A Break.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-stats-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_mobile }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-stats-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-stats-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size_mobile }}px;
    font-weight: 700;
    color: {{ block.settings.headline_color }};
    text-align: center;
    margin: 0 0 {{ block.settings.headline_spacing }}px;
    line-height: 1.2;
  }

  .ai-stats-supporting-{{ ai_gen_id }} {
    font-size: {{ block.settings.supporting_size_mobile }}px;
    color: {{ block.settings.text_color }};
    text-align: center;
    margin: 0 0 {{ block.settings.stats_spacing }}px;
    line-height: 1.6;
  }

  .ai-stats-grid-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.stat_gap }}px;
    margin-bottom: {{ block.settings.transition_spacing }}px;
  }

  .ai-stat-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_radius }}px;
    padding: {{ block.settings.card_padding_mobile }}px;
    text-align: center;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
  }

  .ai-stat-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    margin: 0 auto {{ block.settings.icon_spacing }}px;
    color: {{ block.settings.icon_color }};
  }

  .ai-stat-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.stat_number_size_mobile }}px;
    font-weight: 800;
    color: {{ block.settings.stat_number_color }};
    margin: 0 0 {{ block.settings.stat_label_spacing }}px;
    line-height: 1;
  }

  .ai-stat-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.stat_label_size_mobile }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.5;
    margin: 0;
  }

  .ai-stats-transition-{{ ai_gen_id }} {
    font-size: {{ block.settings.transition_size_mobile }}px;
    color: {{ block.settings.text_color }};
    text-align: center;
    margin: 0 0 {{ block.settings.cta_spacing }}px;
    line-height: 1.6;
  }

  .ai-stats-cta-{{ ai_gen_id }} {
    background-color: {{ block.settings.cta_background }};
    border-radius: {{ block.settings.cta_radius }}px;
    padding: {{ block.settings.cta_padding_mobile }}px;
    text-align: center;
  }

  .ai-cta-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.cta_headline_size_mobile }}px;
    font-weight: 700;
    color: {{ block.settings.cta_headline_color }};
    margin: 0 0 {{ block.settings.cta_text_spacing }}px;
    line-height: 1.3;
  }

  .ai-cta-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.cta_text_size_mobile }}px;
    color: {{ block.settings.cta_text_color }};
    margin: 0 0 {{ block.settings.button_spacing }}px;
    line-height: 1.6;
  }

  .ai-cta-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    text-decoration: none;
    border-radius: {{ block.settings.button_radius }}px;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-cta-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    transform: translateY(-2px);
  }

  @media screen and (min-width: 750px) {
    .ai-stats-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_desktop }}px 40px;
    }

    .ai-stats-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size_desktop }}px;
    }

    .ai-stats-supporting-{{ ai_gen_id }} {
      font-size: {{ block.settings.supporting_size_desktop }}px;
    }

    .ai-stats-grid-{{ ai_gen_id }} {
      flex-direction: row;
      gap: {{ block.settings.stat_gap_desktop }}px;
    }

    .ai-stat-card-{{ ai_gen_id }} {
      flex: 1;
      padding: {{ block.settings.card_padding_desktop }}px;
    }

    .ai-stat-number-{{ ai_gen_id }} {
      font-size: {{ block.settings.stat_number_size_desktop }}px;
    }

    .ai-stat-label-{{ ai_gen_id }} {
      font-size: {{ block.settings.stat_label_size_desktop }}px;
    }

    .ai-stats-transition-{{ ai_gen_id }} {
      font-size: {{ block.settings.transition_size_desktop }}px;
    }

    .ai-stats-cta-{{ ai_gen_id }} {
      padding: {{ block.settings.cta_padding_desktop }}px;
    }

    .ai-cta-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.cta_headline_size_desktop }}px;
    }

    .ai-cta-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.cta_text_size_desktop }}px;
    }
  }
{% endstyle %}

<div class="ai-stats-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-stats-container-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h2 class="ai-stats-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
    {% endif %}

    {% if block.settings.supporting_text != blank %}
      <div class="ai-stats-supporting-{{ ai_gen_id }}">{{ block.settings.supporting_text }}</div>
    {% endif %}

    <div class="ai-stats-grid-{{ ai_gen_id }}">
      {% if block.settings.stat_1_enabled %}
        <div class="ai-stat-card-{{ ai_gen_id }}">
          {% if block.settings.show_icons %}
            <div class="ai-stat-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                <polyline points="7.5 4.21 12 6.81 16.5 4.21"></polyline>
                <polyline points="7.5 19.79 7.5 14.6 3 12"></polyline>
                <polyline points="21 12 16.5 14.6 16.5 19.79"></polyline>
                <polyline points="3.27 6.96 12 12.01 20.73 6.96"></polyline>
                <line x1="12" y1="22.08" x2="12" y2="12"></line>
              </svg>
            </div>
          {% endif %}
          <div class="ai-stat-number-{{ ai_gen_id }}">{{ block.settings.stat_1_number }}</div>
          <div class="ai-stat-label-{{ ai_gen_id }}">{{ block.settings.stat_1_label }}</div>
        </div>
      {% endif %}

      {% if block.settings.stat_2_enabled %}
        <div class="ai-stat-card-{{ ai_gen_id }}">
          {% if block.settings.show_icons %}
            <div class="ai-stat-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
              </svg>
            </div>
          {% endif %}
          <div class="ai-stat-number-{{ ai_gen_id }}">{{ block.settings.stat_2_number }}</div>
          <div class="ai-stat-label-{{ ai_gen_id }}">{{ block.settings.stat_2_label }}</div>
        </div>
      {% endif %}

      {% if block.settings.stat_3_enabled %}
        <div class="ai-stat-card-{{ ai_gen_id }}">
          {% if block.settings.show_icons %}
            <div class="ai-stat-icon-{{ ai_gen_id }}">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2a10 10 0 0 0 0 20 7 7 0 0 1 0-14 5 5 0 0 0 0-6Z"></path>
              </svg>
            </div>
          {% endif %}
          <div class="ai-stat-number-{{ ai_gen_id }}">{{ block.settings.stat_3_number }}</div>
          <div class="ai-stat-label-{{ ai_gen_id }}">{{ block.settings.stat_3_label }}</div>
        </div>
      {% endif %}
    </div>

    {% if block.settings.transition_text != blank %}
      <div class="ai-stats-transition-{{ ai_gen_id }}">{{ block.settings.transition_text }}</div>
    {% endif %}

    <div class="ai-stats-cta-{{ ai_gen_id }}">
      {% if block.settings.cta_headline != blank %}
        <h3 class="ai-cta-headline-{{ ai_gen_id }}">{{ block.settings.cta_headline }}</h3>
      {% endif %}

      {% if block.settings.cta_text != blank %}
        <div class="ai-cta-text-{{ ai_gen_id }}">{{ block.settings.cta_text }}</div>
      {% endif %}

      {% if block.settings.button_text != blank %}
        <a href="{{ block.settings.button_link }}" class="ai-cta-button-{{ ai_gen_id }}">
          {{ block.settings.button_text }}
        </a>
      {% endif %}
    </div>
  </div>
</div>

