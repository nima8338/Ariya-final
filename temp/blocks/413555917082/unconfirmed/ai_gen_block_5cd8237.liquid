{% doc %}
  @prompt
    Create a mobile-first educational statistics section for Ariya Supplements’ sleep product, Calm Nights.The design should feel premium, modern, and clean, similar to leading DTC wellness brands.Use Ariya’s purple branding, large bold statistics, plenty of white space, rounded corners, and a strong call-to-action button.Section Headline:Your Brain Wasn’t Designed For Modern Life.Supporting Text:Late-night scrolling. Constant notifications. Endless stimulation.Statistic #1:Visual Icon Instructions:
    Use a brain icon or brain silhouette in Ariya purple. 48%of U.S. adults report lying awake at night due to stress.Statistic #2:Visual Icon Instructions:
    Use three person silhouettes with one highlighted in Ariya purple to visually represent “1 in 3.” 1 in 3adults don’t get enough sleep on a regular basis.Statistic #3:Visual Icon Instructions:
    Use a moon icon in Ariya purple with subtle stars around it. 50–70 MillionAmericans struggle with ongoing sleep problems.Transition Text:Modern life makes it harder than ever to slow down and relax before bed.CTA Headline:That’s Why We Created Calm Nights.CTA Text:Melatonin-free sleep support designed to help quiet a racing mind, promote relaxation, and help you wake up refreshed.Button Text:Shop Calm NightsDesign Notes:Large statistic numbers should be the visual focus.Statistics should stack vertically on mobile.Do not use generic charts, graphs, arrows, pie charts, or abstract icons.Use only the specified icons for each statistic.Icons should feel premium, minimal, and luxury wellness oriented.Use Ariya purple accents throughout.Maintain a clean DTC wellness aesthetic.Keep the entire section easy to scan in under 5 seconds.Statistics should visually tell a story: Stress → Poor Sleep → Millions Struggling.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-sleep-stats-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding_mobile }}px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-sleep-stats-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-sleep-stats-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.header_spacing_mobile }}px;
  }

  .ai-sleep-stats-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size_mobile }}px;
    font-weight: 700;
    color: {{ block.settings.headline_color }};
    margin: 0 0 {{ block.settings.subtext_spacing }}px 0;
    line-height: 1.2;
  }

  .ai-sleep-stats-subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size_mobile }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0;
  }

  .ai-sleep-stats-grid-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.stat_gap_mobile }}px;
    margin-bottom: {{ block.settings.transition_spacing_mobile }}px;
  }

  .ai-sleep-stat-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding_mobile }}px;
    text-align: center;
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
  }

  .ai-sleep-stat-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size_mobile }}px;
    height: {{ block.settings.icon_size_mobile }}px;
    margin: 0 auto {{ block.settings.icon_spacing }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-sleep-stat-icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: {{ block.settings.icon_color }};
  }

  .ai-sleep-stat-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.stat_number_size_mobile }}px;
    font-weight: 700;
    color: {{ block.settings.stat_number_color }};
    margin: 0 0 {{ block.settings.stat_description_spacing }}px 0;
    line-height: 1.1;
  }

  .ai-sleep-stat-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.stat_description_size_mobile }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.5;
    margin: 0;
  }

  .ai-sleep-stats-transition-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.transition_size_mobile }}px;
    color: {{ block.settings.text_color }};
    margin-bottom: {{ block.settings.cta_spacing_mobile }}px;
    line-height: 1.6;
  }

  .ai-sleep-stats-cta-{{ ai_gen_id }} {
    background-color: {{ block.settings.cta_background }};
    border-radius: {{ block.settings.cta_border_radius }}px;
    padding: {{ block.settings.cta_padding_mobile }}px;
    text-align: center;
  }

  .ai-sleep-stats-cta-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.cta_headline_size_mobile }}px;
    font-weight: 700;
    color: {{ block.settings.cta_headline_color }};
    margin: 0 0 {{ block.settings.cta_text_spacing }}px 0;
    line-height: 1.3;
  }

  .ai-sleep-stats-cta-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.cta_text_size_mobile }}px;
    color: {{ block.settings.text_color }};
    line-height: 1.6;
    margin: 0 0 {{ block.settings.cta_button_spacing }}px 0;
  }

  .ai-sleep-stats-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-sleep-stats-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    transform: translateY(-2px);
  }

  @media screen and (min-width: 750px) {
    .ai-sleep-stats-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_desktop }}px 40px;
    }

    .ai-sleep-stats-header-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.header_spacing_desktop }}px;
    }

    .ai-sleep-stats-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size_desktop }}px;
    }

    .ai-sleep-stats-subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size_desktop }}px;
    }

    .ai-sleep-stats-grid-{{ ai_gen_id }} {
      flex-direction: row;
      gap: {{ block.settings.stat_gap_desktop }}px;
      margin-bottom: {{ block.settings.transition_spacing_desktop }}px;
    }

    .ai-sleep-stat-card-{{ ai_gen_id }} {
      flex: 1;
      padding: {{ block.settings.card_padding_desktop }}px;
    }

    .ai-sleep-stat-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_desktop }}px;
      height: {{ block.settings.icon_size_desktop }}px;
    }

    .ai-sleep-stat-number-{{ ai_gen_id }} {
      font-size: {{ block.settings.stat_number_size_desktop }}px;
    }

    .ai-sleep-stat-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.stat_description_size_desktop }}px;
    }

    .ai-sleep-stats-transition-{{ ai_gen_id }} {
      font-size: {{ block.settings.transition_size_desktop }}px;
      margin-bottom: {{ block.settings.cta_spacing_desktop }}px;
    }

    .ai-sleep-stats-cta-{{ ai_gen_id }} {
      padding: {{ block.settings.cta_padding_desktop }}px;
    }

    .ai-sleep-stats-cta-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.cta_headline_size_desktop }}px;
    }

    .ai-sleep-stats-cta-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.cta_text_size_desktop }}px;
    }
  }
{% endstyle %}

<div class="ai-sleep-stats-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
