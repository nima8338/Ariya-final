    {
      "type": "text",
      "id": "benefit_1",
      "label": "Benefit 1",
      "default": "Falls asleep faster — no synthetic melatonin."
    },
    {
      "type": "text",
      "id": "benefit_2",
      "label": "Benefit 2",
      "default": "Quiets racing thoughts — your brain actually shuts off."
    },
    {
      "type": "text",
      "id": "benefit_3",
      "label": "Benefit 3",
      "default": "Wakes up clear — no grogginess, no dependency."
