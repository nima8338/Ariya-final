{% doc %}
  @prompt
    Create a clean, premium benefits section using our brand colors. Use #3C0E66 for the headline and accents, keep all supporting text black, and use a white background with generous spacing.
    
    Headline: “No melatonin. No grogginess. Just sleep that actually works.”
    
    Below the headline, display these four benefits in a neat, easy-to-scan layout with purple checkmarks:
    
    ✓ Falls asleep faster — no synthetic melatonin.
    ✓ Quiets racing thoughts — your brain actually shuts off.
    ✓ Wakes up clear — no grogginess, no dependency.
    ✓ Standardized extracts — no underdosed fillers.
    
    Keep the design modern, centered, mobile-friendly, and visually balanced. Avoid excessive borders, bright colors, or clutter.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-benefits-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_top }}px {{ block.settings.padding_horizontal }}px {{ block.settings.padding_bottom }}px;
    text-align: center;
  }

  .ai-benefits-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-benefits-headline-{{ ai_gen_id }} {
    color: {{ block.settings.headline_color }};
    font-size: {{ block.settings.headline_size }}px;
    line-height: 1.3;
    margin: 0 0 {{ block.settings.headline_spacing }}px;
    font-weight: 400;
  }

  .ai-benefits-list-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: {{ block.settings.item_spacing }}px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .ai-benefits-item-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-start;
    gap: {{ block.settings.icon_text_gap }}px;
    text-align: left;
  }

  .ai-benefits-checkmark-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.checkmark_size }}px;
    height: {{ block.settings.checkmark_size }}px;
    margin-top: 2px;
  }

  .ai-benefits-checkmark-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    fill: none;
    stroke: {{ block.settings.checkmark_color }};
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .ai-benefits-text-{{ ai_gen_id }} {
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-benefits-section-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px {{ block.settings.padding_horizontal | times: 0.7 }}px {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-benefits-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.7 }}px;
      margin-bottom: {{ block.settings.headline_spacing | times: 0.7 }}px;
    }

    .ai-benefits-list-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.item_spacing | times: 0.8 }}px;
    }

    .ai-benefits-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<div class="ai-benefits-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-benefits-container-{{ ai_gen_id }}">
    {% if block.settings.headline != blank %}
      <h2 class="ai-benefits-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
    {% endif %}

    <ul class="ai-benefits-list-{{ ai_gen_id }}">
      {% if block.settings.benefit_1 != blank %}
        <li class="ai-benefits-item-{{ ai_gen_id }}">
          <div class="ai-benefits-checkmark-{{ ai_gen_id }}">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
          <p class="ai-benefits-text-{{ ai_gen_id }}">{{ block.settings.benefit_1 }}</p>
        </li>
      {% endif %}

      {% if block.settings.benefit_2 != blank %}
        <li class="ai-benefits-item-{{ ai_gen_id }}">
          <div class="ai-benefits-checkmark-{{ ai_gen_id }}">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
          <p class="ai-benefits-text-{{ ai_gen_id }}">{{ block.settings.benefit_2 }}</p>
        </li>
      {% endif %}

      {% if block.settings.benefit_3 != blank %}
        <li class="ai-benefits-item-{{ ai_gen_id }}">
          <div class="ai-benefits-checkmark-{{ ai_gen_id }}">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
          <p class="ai-benefits-text-{{ ai_gen_id }}">{{ block.settings.benefit_3 }}</p>
        </li>
      {% endif %}

      {% if block.settings.benefit_4 != blank %}
        <li class="ai-benefits-item-{{ ai_gen_id }}">
          <div class="ai-benefits-checkmark-{{ ai_gen_id }}">
            <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
          <p class="ai-benefits-text-{{ ai_gen_id }}">{{ block.settings.benefit_4 }}</p>
        </li>
      {% endif %}
    </ul>
  </div>
</div>

