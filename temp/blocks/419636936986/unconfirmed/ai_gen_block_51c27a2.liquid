{% doc %}
  @prompt
    Create the headline text "Calm Nights" with a vertical gradient fill. Start with a deep purple at the top (#3C0E66) and smoothly transition to a lighter purple at the bottom (#C99CF1). Keep the gradient subtle and premium—not bright or neon. Use the existing font, center the text, and make sure the gradient only fills the letters (not the background). The background should stay transparent or inherit the page background., bold it
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-gradient-headline-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-gradient-headline__text-{{ ai_gen_id }} {
    font-family: {{ block.settings.font_family.family }}, {{ block.settings.font_family.fallback_families }};
    font-weight: 700;
    font-style: {{ block.settings.font_family.style }};
    font-size: {{ block.settings.font_size }}px;
    line-height: 1.2;
    text-align: {{ block.settings.text_alignment }};
    margin: 0;
    background: linear-gradient(
      to bottom,
      {{ block.settings.gradient_top_color }} 0%,
      {{ block.settings.gradient_bottom_color }} 100%
    );
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-fill-color: transparent;
  }

  @media screen and (max-width: 749px) {
    .ai-gradient-headline__text-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.6 }}px;
    }
  }
{% endstyle %}

<div
  class="ai-gradient-headline-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <h1 class="ai-gradient-headline__text-{{ ai_gen_id }}">
    {{ block.settings.headline_text }}
  </h1>
</div>

{% schema %}
{
  "name": "Gradient headline",
  "settings": [
    {
      "type": "text",
      "id": "headline_text",
      "label": "Headline text",
      "default": "Calm Nights"
    },
    {
      "type": "font_picker",
      "id": "font_family",
      "label": "Font",
      "default": "libre_baskerville_n4"
    },
    {
      "type": "range",
      "id": "font_size",
      "label": "Font size",
      "min": 24,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "header",
      "content": "Gradient colors"
    },
    {
      "type": "color",
      "id": "gradient_top_color",
      "label": "Top color",
      "default": "#3C0E66"
    },
    {
      "type": "color",
      "id": "gradient_bottom_color",
      "label": "Bottom color",
      "default": "#C99CF1"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Gradient headline"
    }
  ]
}
{% endschema %}
