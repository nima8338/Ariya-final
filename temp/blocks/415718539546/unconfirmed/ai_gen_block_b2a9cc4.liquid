{% doc %}
  @prompt
    Create a new premium transparency/trust section for the Calm Nights product page.
    
    
    
    Goal:
    Replace the current sleep-stat section with a short section that explains why Calm Nights is different.
    
    
    
    Add an image option at the top:
    Allow us to upload or insert a picture at the top of the section. Keep it clean, premium, and mobile-friendly.
    
    
    
    Section copy:
    
    
    
    Headline:
    Most Supplement Labels Don’t Tell The Full Story
    
    
    
    Main stat:
    80%
    
    
    
    Stat sentence:
    of herbal supplements tested were mislabeled.¹
    
    
    
    Make the “¹” a small clickable superscript source link. Do not add a separate source line.
    
    
    
    Supporting line:
    Missing ingredients. Unlisted fillers. Labels that didn’t match.
    
    
    
    Turn:
    Calm Nights was built for people who are done guessing.
    
    
    
    Proof line:
    Every dose disclosed. Standardized extracts. No proprietary blends.
    
    
    
    CTA button:
    Shop Calm Nights
    
    
    
    CTA behavior:
    The button should scroll/take the customer back to the top product purchase section.
    
    
    
    Design:
    Make the 80% the biggest visual element in the section. Use a clean white background, Ariya purple accents, centered layout, and mobile-first spacing. Keep the section short, premium, and conversion-focused. Do not over-explain the study.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_mobile }}px 20px;
  }

  @media screen and (min-width: 750px) {
    .ai-trust-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_desktop }}px 40px;
    }
  }

  .ai-trust-section__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    text-align: center;
  }

  .ai-trust-section__image-wrapper-{{ ai_gen_id }} {
    margin-bottom: 32px;
  }

  .ai-trust-section__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-trust-section__image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    background-color: #f9f6ff;
    border-radius: {{ block.settings.image_border_radius }}px;
    padding: 60px 20px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-trust-section__image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    max-width: 200px;
    height: auto;
    opacity: 0.3;
  }

  .ai-trust-section__headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size_mobile }}px;
    line-height: 1.2;
    color: {{ block.settings.headline_color }};
    margin: 0 0 32px;
    font-weight: 600;
  }

  @media screen and (min-width: 750px) {
    .ai-trust-section__headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size_desktop }}px;
    }
  }

  .ai-trust-section__stat-container-{{ ai_gen_id }} {
    margin-bottom: 16px;
  }

  .ai-trust-section__stat-{{ ai_gen_id }} {
    font-size: {{ block.settings.stat_size_mobile }}px;
    line-height: 1;
    color: {{ block.settings.stat_color }};
    font-weight: 700;
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    .ai-trust-section__stat-{{ ai_gen_id }} {
      font-size: {{ block.settings.stat_size_desktop }}px;
    }
  }

  .ai-trust-section__stat-sentence-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size_mobile }}px;
    line-height: 1.5;
    color: {{ block.settings.text_color }};
    margin: 12px 0 24px;
  }

  @media screen and (min-width: 750px) {
    .ai-trust-section__stat-sentence-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_desktop }}px;
    }
  }

  .ai-trust-section__source-link-{{ ai_gen_id }} {
    color: {{ block.settings.stat_color }};
    text-decoration: none;
    font-size: 0.7em;
    vertical-align: super;
    margin-left: 2px;
  }

  .ai-trust-section__source-link-{{ ai_gen_id }}:hover {
    text-decoration: underline;
  }

  .ai-trust-section__supporting-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size_mobile }}px;
    line-height: 1.5;
    color: {{ block.settings.text_color }};
    margin: 0 0 24px;
    opacity: 0.85;
  }

  @media screen and (min-width: 750px) {
    .ai-trust-section__supporting-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_desktop }}px;
    }
  }

  .ai-trust-section__turn-{{ ai_gen_id }} {
    font-size: {{ block.settings.turn_size_mobile }}px;
    line-height: 1.4;
    color: {{ block.settings.headline_color }};
    margin: 0 0 16px;
    font-weight: 600;
  }

  @media screen and (min-width: 750px) {
    .ai-trust-section__turn-{{ ai_gen_id }} {
      font-size: {{ block.settings.turn_size_desktop }}px;
    }
  }

  .ai-trust-section__proof-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size_mobile }}px;
    line-height: 1.5;
    color: {{ block.settings.text_color }};
    margin: 0 0 32px;
  }

  @media screen and (min-width: 750px) {
    .ai-trust-section__proof-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_desktop }}px;
    }
  }

  .ai-trust-section__cta-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_text_size }}px;
    font-weight: 600;
    transition: all 0.3s ease;
    cursor: pointer;
    border: none;
  }

  .ai-trust-section__cta-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    color: {{ block.settings.button_hover_text_color }};
    transform: translateY(-2px);
  }
{% endstyle %}

<div class="ai-trust-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-trust-section__container-{{ ai_gen_id }}">
    {% if block.settings.image != blank %}
      <div class="ai-trust-section__image-wrapper-{{ ai_gen_id }}">
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-trust-section__image-{{ ai_gen_id }}"
        >
      </div>
    {% elsif block.settings.show_image_placeholder %}
      <div class="ai-trust-section__image-wrapper-{{ ai_gen_id }}">
        <div class="ai-trust-section__image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      </div>
    {% endif %}

    <h2 class="ai-trust-section__headline-{{ ai_gen_id }}">
      {{ block.settings.headline }}
    </h2>

    <div class="ai-trust-section__stat-container-{{ ai_gen_id }}">
      <p class="ai-trust-section__stat-{{ ai_gen_id }}">{{ block.settings.stat }}</p>
    </div>

    <p class="ai-trust-section__stat-sentence-{{ ai_gen_id }}">
      {{ block.settings.stat_sentence }}<a
        href="{{ block.settings.source_url }}"
        class="ai-trust-section__source-link-{{ ai_gen_id }}"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="View source"
        >¹</a
      >
    </p>

    <p class="ai-trust-section__supporting-{{ ai_gen_id }}">
      {{ block.settings.supporting_line }}
    </p>

    <p class="ai-trust-section__turn-{{ ai_gen_id }}">
      {{ block.settings.turn_line }}
    </p>

    <p class="ai-trust-section__proof-{{ ai_gen_id }}">
      {{ block.settings.proof_line }}
    </p>

    <button
      class="ai-trust-section__cta-{{ ai_gen_id }}"
      onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
      type="button"
    >
      {{ block.settings.cta_text }}
    </button>
  </div>
</div>

