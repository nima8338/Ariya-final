{% doc %}
  @prompt
    make a fruit cherry float up and down and under it has a description
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-floating-cherry-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.padding }}px;
  }

  .ai-floating-cherry__image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.cherry_size }}px;
    height: {{ block.settings.cherry_size }}px;
    margin-bottom: {{ block.settings.spacing }}px;
  }

  .ai-floating-cherry__image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: contain;
    animation: ai-float-{{ ai_gen_id }} {{ block.settings.animation_speed }}s ease-in-out infinite;
  }

  .ai-floating-cherry__placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    animation: ai-float-{{ ai_gen_id }} {{ block.settings.animation_speed }}s ease-in-out infinite;
  }

  .ai-floating-cherry__placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-floating-cherry__description-{{ ai_gen_id }} {
    text-align: center;
    color: {{ block.settings.text_color }};
    font-size: {{ block.settings.text_size }}px;
    line-height: 1.5;
    max-width: {{ block.settings.description_max_width }}px;
  }

  @keyframes ai-float-{{ ai_gen_id }} {
    0%, 100% {
      transform: translateY(0px);
    }
    50% {
      transform: translateY(-{{ block.settings.float_distance }}px);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-floating-cherry__image-wrapper-{{ ai_gen_id }} {
      width: {{ block.settings.cherry_size | times: 0.7 }}px;
      height: {{ block.settings.cherry_size | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-floating-cherry-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-floating-cherry__image-wrapper-{{ ai_gen_id }}">
    {% if block.settings.cherry_image %}
      <img
        src="{{ block.settings.cherry_image | image_url: width: 800 }}"
        alt="{{ block.settings.cherry_image.alt | escape }}"
        class="ai-floating-cherry__image-{{ ai_gen_id }}"
        loading="lazy"
        width="{{ block.settings.cherry_image.width }}"
        height="{{ block.settings.cherry_image.height }}"
      >
    {% else %}
      <div class="ai-floating-cherry__placeholder-{{ ai_gen_id }}">
        {{ 'product-1' | placeholder_svg_tag }}
      </div>
    {% endif %}
  </div>

  {% if block.settings.description != blank %}
    <div class="ai-floating-cherry__description-{{ ai_gen_id }}">
      {{ block.settings.description }}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Floating cherry",
  "settings": [
    {
      "type": "header",
      "content": "Cherry image"
    },
    {
      "type": "image_picker",
      "id": "cherry_image",
      "label": "Cherry image"
    },
    {
      "type": "range",
      "id": "cherry_size",
      "label": "Cherry size",
      "min": 50,
      "max": 400,
      "step": 10,
      "unit": "px",
      "default": 200
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "range",
      "id": "float_distance",
      "label": "Float distance",
      "min": 5,
      "max": 50,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "animation_speed",
      "label": "Animation speed",
      "min": 1,
      "max": 5,
      "step": 0.5,
      "unit": "s",
      "default": 3
    },
    {
      "type": "header",
      "content": "Description"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Fresh, juicy cherries packed with antioxidants and natural sweetness</p>"
    },
    {
      "type": "range",
      "id": "text_size",
      "label": "Text size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#3c0e66"
    },
    {
      "type": "range",
      "id": "description_max_width",
      "label": "Description max width",
      "min": 200,
      "max": 600,
      "step": 20,
      "unit": "px",
      "default": 400
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Space between cherry and text",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Floating cherry"
    }
  ]
}
{% endschema %}