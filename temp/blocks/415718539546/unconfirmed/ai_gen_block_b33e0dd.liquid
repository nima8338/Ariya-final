    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding_mobile }}px 20px;
  }

  @media screen and (min-width: 750px) {
    .ai-trust-section-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_desktop }}px 40px;
    }
  }

  .ai-trust-section__container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    text-align: center;
  }

  .ai-trust-section__image-wrapper-{{ ai_gen_id }} {
    margin-bottom: 32px;
  }

  .ai-trust-section__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-trust-section__headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size_mobile }}px;
    line-height: 1.2;
    color: {{ block.settings.headline_color }};
    margin: 0 0 32px;
    font-weight: 600;
  }

  @media screen and (min-width: 750px) {
    .ai-trust-section__headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size_desktop }}px;
      margin-bottom: 40px;
    }
  }

  .ai-trust-section__stat-container-{{ ai_gen_id }} {
    margin-bottom: 12px;
  }

  .ai-trust-section__stat-{{ ai_gen_id }} {
    font-size: {{ block.settings.stat_size_mobile }}px;
    line-height: 1;
    color: {{ block.settings.stat_color }};
    font-weight: 700;
    margin: 0;
  }

  @media screen and (min-width: 750px) {
    .ai-trust-section__stat-{{ ai_gen_id }} {
      font-size: {{ block.settings.stat_size_desktop }}px;
    }
  }

  .ai-trust-section__stat-sentence-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size_mobile }}px;
    line-height: 1.5;
    color: {{ block.settings.text_color }};
    margin: 0 0 24px;
  }

  @media screen and (min-width: 750px) {
    .ai-trust-section__stat-sentence-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_desktop }}px;
      margin-bottom: 32px;
    }
  }

  .ai-trust-section__source-link-{{ ai_gen_id }} {
    position: relative;
    display: inline-block;
    margin-left: 2px;
    text-decoration: none;
    cursor: pointer;
    vertical-align: super;
    font-size: 10px;
    line-height: 1;
    color: {{ block.settings.stat_color }};
  }

  .ai-trust-section__source-link-{{ ai_gen_id }}:hover {
    opacity: 0.7;
  }

  .ai-trust-section__supporting-{{ ai_gen_id }} {
    font-size: {{ block.settings.text_size_mobile }}px;
    line-height: 1.5;
    color: {{ block.settings.text_color }};
    margin: 0 0 24px;
  }

  @media screen and (min-width: 750px) {
    .ai-trust-section__supporting-{{ ai_gen_id }} {
      font-size: {{ block.settings.text_size_desktop }}px;
      margin-bottom: 32px;
    }
  }

  .ai-trust-section__turn-{{ ai_gen_id }} {
    font-size: {{ block.settings.turn_size_mobile }}px;
    line-height: 1.4;
    color: {{ block.settings.headline_color }};
    margin: 0 0 24px;
    font-weight: 600;
  }

  @media screen and (min-width: 750px) {
    .ai-trust-section__turn-{{ ai_gen_id }} {
      font-size: {{ block.settings.turn_size_desktop }}px;
      margin-bottom: 32px;
    }
  }

  .ai-trust-section__checkmarks-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    margin-bottom: 32px;
  }

