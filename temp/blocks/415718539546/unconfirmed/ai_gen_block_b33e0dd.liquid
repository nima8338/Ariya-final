{% endstyle %}

<trust-section-{{ ai_gen_id }} class="ai-trust-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-trust-section__container-{{ ai_gen_id }}">
    {% if block.settings.image %}
      <div class="ai-trust-section__image-wrapper-{{ ai_gen_id }}">
        <img
          src="{{ block.settings.image | image_url: width: 1200 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-trust-section__image-{{ ai_gen_id }}"
        >
      </div>
    {% endif %}

    {% if block.settings.headline != blank %}
      <h2 class="ai-trust-section__headline-{{ ai_gen_id }}">
        {{ block.settings.headline }}
      </h2>
    {% endif %}

    <div class="ai-trust-section__stat-container-{{ ai_gen_id }}">
      <p class="ai-trust-section__stat-{{ ai_gen_id }}" data-target-value="{{ block.settings.stat_number }}">0%</p>
    </div>

    {% if block.settings.stat_sentence != blank %}
      <p class="ai-trust-section__stat-sentence-{{ ai_gen_id }}">
        {{ block.settings.stat_sentence }}{% if block.settings.source_url != blank %}<a href="{{ block.settings.source_url }}" class="ai-trust-section__source-link-{{ ai_gen_id }}" target="_blank" rel="noopener">★</a>{% endif %}
      </p>
    {% endif %}

    {% if block.settings.supporting_line != blank %}
      <p class="ai-trust-section__supporting-{{ ai_gen_id }}">
        {{ block.settings.supporting_line }}
      </p>
    {% endif %}

    {% if block.settings.turn_line != blank %}
      <p class="ai-trust-section__turn-{{ ai_gen_id }}">
        {{ block.settings.turn_line }}
      </p>
    {% endif %}

    <div class="ai-trust-section__checkmarks-{{ ai_gen_id }}">
      {% if block.settings.checkmark_1_text != blank %}
        <div class="ai-trust-section__checkmark-item-{{ ai_gen_id }}">
          <div class="ai-trust-section__checkmark-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
          <span class="ai-trust-section__checkmark-text-{{ ai_gen_id }}">{{ block.settings.checkmark_1_text }}</span>
        </div>
      {% endif %}

      {% if block.settings.checkmark_2_text != blank %}
        <div class="ai-trust-section__checkmark-item-{{ ai_gen_id }}">
          <div class="ai-trust-section__checkmark-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
          <span class="ai-trust-section__checkmark-text-{{ ai_gen_id }}">{{ block.settings.checkmark_2_text }}</span>
        </div>
      {% endif %}

      {% if block.settings.checkmark_3_text != blank %}
        <div class="ai-trust-section__checkmark-item-{{ ai_gen_id }}">
          <div class="ai-trust-section__checkmark-icon-{{ ai_gen_id }}">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
          <span class="ai-trust-section__checkmark-text-{{ ai_gen_id }}">{{ block.settings.checkmark_3_text }}</span>
        </div>
      {% endif %}
    </div>

    {% if block.settings.cta_text != blank %}
      <button class="ai-trust-section__cta-{{ ai_gen_id }}">
        {{ block.settings.cta_text }}
      </button>
    {% endif %}
  </div>
</trust-section-{{ ai_gen_id }}>

<script>
  (function() {
    class TrustSection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.hasAnimated = false;
      }

      connectedCallback() {
        this.button = this.querySelector('.ai-trust-section__cta-{{ ai_gen_id }}');
        this.statElement = this.querySelector('.ai-trust-section__stat-{{ ai_gen_id }}');
        
        if (this.button) {
          this.button.addEventListener('click', this.handleClick.bind(this));
        }

        if (this.statElement) {
          this.setupIntersectionObserver();
        }
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.5
        };

        this.observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && !this.hasAnimated) {
              this.animateCounter();
              this.hasAnimated = true;
            }
          });
        }, options);

        this.observer.observe(this.statElement);
      }

      animateCounter() {
        const targetValue = this.statElement.getAttribute('data-target-value');
        const numericValue = parseInt(targetValue);
        const hasPercentSign = targetValue.includes('%');
        const duration = 2000;
        const startTime = performance.now();

        const animate = (currentTime) => {
          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / duration, 1);
          
          const easeOutQuart = 1 - Math.pow(1 - progress, 4);
          const currentValue = Math.floor(easeOutQuart * numericValue);
          
          if (hasPercentSign) {
            this.statElement.textContent = currentValue + '%';
          } else {
            this.statElement.textContent = currentValue;
          }

          if (progress < 1) {
            requestAnimationFrame(animate);
          } else {
            this.statElement.textContent = targetValue;
          }
        };

        requestAnimationFrame(animate);
      }

      handleClick() {
        window.scrollTo({
          top: 0,
          behavior: 'smooth'
        });
      }

      disconnectedCallback() {
        if (this.button) {
          this.button.removeEventListener('click', this.handleClick.bind(this));
        }
        if (this.observer) {
          this.observer.disconnect();
        }
      }
    }

    customElements.define('trust-section-{{ ai_gen_id }}', TrustSection{{ ai_gen_id }});
  })();
</script>

