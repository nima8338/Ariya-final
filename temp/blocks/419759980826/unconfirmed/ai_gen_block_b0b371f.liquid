{% doc %}
  @prompt
    Create a premium, minimal section focused on transparency, not selling. The design should feel like Apple, AG1, or Eight Sleep—clean, spacious, and easy to scan on mobile.
    
    Layout
    White background (#FFFFFF).
    Maximum content width around 700–800px.
    Generous vertical spacing (80–120px between sections).
    Rounded corners (20–24px) on cards and buttons.
    Use our brand purple (#7D45C6) for accents and buttons.
    Mobile-first design with excellent spacing and typography.
    Eyebrow
    
    Small uppercase text in purple:
    
    WHY ARIYA IS DIFFERENT
    
    Headline
    
    Large bold headline:
    
    Don't Take Our Word For It.
    Check The Formula Yourself.
    
    Center align.
    
    Supporting Text
    
    Keep this short and readable.
    
    Every bottle includes a QR code that lets you verify every ingredient, exact dose, extract ratio, testing information, and why each ingredient was chosen.
    
    Limit the paragraph to about two lines on mobile.
    
    Video
    
    Place a large rounded video immediately below the text.
    
    The thumbnail should show:
    
    The Calm Nights bottle
    The QR code visible
    A centered play button
    
    The video should autoplay muted when visible (or play when tapped if autoplay isn't possible).
    
    Video sequence (10–15 seconds):
    
    Show the bottle.
    Smoothly zoom toward the QR code.
    Scan the QR code.
    Open the ingredient transparency page.
    Smoothly scroll through:
    Ingredients
    Exact doses
    Extract ratios
    Testing/manufacturing information
    Finish on the "Shop Calm Nights" button.
    Loop seamlessly.
    
    Animations should feel smooth and premium—not flashy or fast-paced.
    
    Trust Points
    
    Below the video, create three compact rows with small purple check icons.
    
    ✓ Every dose disclosed
    
    ✓ Standardized extracts
    
    ✓ No proprietary blends
    
    Keep these left aligned and close together to reduce vertical space.
    
    CTA
    
    Add a single centered button.
    
    Button text:
    
    Explore Every Ingredient
    
    Use our brand purple (#7D45C6) with white text.
    
    Under the button, add small gray text:
    
    See exactly what's inside before you decide.
    
    Design Style
    
    The section should communicate honesty, transparency, and premium quality.
    
    Avoid:
    
    Large statistics
    Large checkmark icons
    Long paragraphs
    Excessive vertical whitespace
    Busy layouts
    Heavy shadows
    
    The overall feeling should immediately communicate:
    
    "We're confident enough to let you inspect everything before buying."
    
    Make this one of the cleanest and most premium-looking sections on the website, optimized primarily for mobile conversion.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-transparency-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: #FFFFFF;
    padding: 80px 20px;
  }

  @media screen and (min-width: 750px) {
    .ai-transparency-section-{{ ai_gen_id }} {
      padding: 100px 40px;
    }
  }

  .ai-transparency-container-{{ ai_gen_id }} {
    max-width: 750px;
    margin: 0 auto;
  }

  .ai-transparency-eyebrow-{{ ai_gen_id }} {
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: {{ block.settings.accent_color }};
    text-align: center;
    margin-bottom: 16px;
  }

  .ai-transparency-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.mobile_headline_size }}px;
    font-weight: 700;
    line-height: 1.1;
    color: {{ block.settings.text_color }};
    text-align: center;
    margin: 0 0 20px;
  }

  @media screen and (min-width: 750px) {
    .ai-transparency-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.desktop_headline_size }}px;
    }
  }

  .ai-transparency-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    line-height: 1.5;
    color: {{ block.settings.description_color }};
    text-align: center;
    margin: 0 auto 40px;
    max-width: 600px;
  }

  @media screen and (min-width: 750px) {
    .ai-transparency-description-{{ ai_gen_id }} {
      margin-bottom: 48px;
    }
  }

  .ai-transparency-video-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    border-radius: {{ block.settings.video_border_radius }}px;
    overflow: hidden;
    margin-bottom: 32px;
    background-color: #f5f5f5;
  }

  .ai-transparency-video-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-transparency-video-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f5f5f5;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-transparency-video-placeholder-{{ ai_gen_id }} svg {
    width: 80px;
    height: 80px;
    opacity: 0.3;
  }

  .ai-transparency-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-transparency-trust-points-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 40px;
  }

  @media screen and (min-width: 750px) {
    .ai-transparency-trust-points-{{ ai_gen_id }} {
      margin-bottom: 48px;
    }
  }

  .ai-transparency-trust-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .ai-transparency-check-icon-{{ ai_gen_id }} {
    width: 18px;
    height: 18px;
    flex-shrink: 0;
    color: {{ block.settings.accent_color }};
  }

  .ai-transparency-trust-text-{{ ai_gen_id }} {
    font-size: 15px;
    line-height: 1.4;
    color: {{ block.settings.text_color }};
    margin: 0;
  }

  .ai-transparency-cta-wrapper-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-transparency-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: 16px 32px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    border: none;
    cursor: pointer;
  }

  .ai-transparency-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
    transform: translateY(-1px);
  }

  .ai-transparency-subtext-{{ ai_gen_id }} {
    font-size: 13px;
    color: {{ block.settings.subtext_color }};
    margin-top: 12px;
  }
{% endstyle %}

<transparency-section-{{ ai_gen_id }}
  class="ai-transparency-section-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-transparency-container-{{ ai_gen_id }}">
    {% if block.settings.eyebrow_text != blank %}
      <div class="ai-transparency-eyebrow-{{ ai_gen_id }}">
        {{ block.settings.eyebrow_text }}
      </div>
    {% endif %}

    {% if block.settings.headline != blank %}
      <h2 class="ai-transparency-headline-{{ ai_gen_id }}">
        {{ block.settings.headline }}
      </h2>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-transparency-description-{{ ai_gen_id }}">
        {{ block.settings.description }}
      </div>
    {% endif %}

    <div class="ai-transparency-video-wrapper-{{ ai_gen_id }}">
      {% if block.settings.video != blank %}
        <video
          class="ai-transparency-video-{{ ai_gen_id }}"
          src="{{ block.settings.video }}"
          {% if block.settings.autoplay %}autoplay{% endif %}
          {% if block.settings.loop %}loop{% endif %}
          muted
          playsinline
          {% if block.settings.show_controls %}controls{% endif %}
        ></video>
      {% else %}
        <div class="ai-transparency-video-placeholder-{{ ai_gen_id }}">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polygon points="5 3 19 12 5 21 5 3"></polygon>
          </svg>
          <div class="ai-transparency-empty-state-{{ ai_gen_id }}">
            Next, add your transparency video
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-transparency-trust-points-{{ ai_gen_id }}">
      {% if block.settings.trust_point_1 != blank %}
        <div class="ai-transparency-trust-item-{{ ai_gen_id }}">
          <svg class="ai-transparency-check-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <p class="ai-transparency-trust-text-{{ ai_gen_id }}">{{ block.settings.trust_point_1 }}</p>
        </div>
      {% endif %}

      {% if block.settings.trust_point_2 != blank %}
        <div class="ai-transparency-trust-item-{{ ai_gen_id }}">
          <svg class="ai-transparency-check-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <p class="ai-transparency-trust-text-{{ ai_gen_id }}">{{ block.settings.trust_point_2 }}</p>
        </div>
      {% endif %}

      {% if block.settings.trust_point_3 != blank %}
        <div class="ai-transparency-trust-item-{{ ai_gen_id }}">
          <svg class="ai-transparency-check-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="20 6 9 17 4 12"></polyline>
          </svg>
          <p class="ai-transparency-trust-text-{{ ai_gen_id }}">{{ block.settings.trust_point_3 }}</p>
        </div>
      {% endif %}
    </div>

    <div class="ai-transparency-cta-wrapper-{{ ai_gen_id }}">
      {% if block.settings.button_text != blank %}
        <a
          href="{{ block.settings.button_link }}"
          class="ai-transparency-button-{{ ai_gen_id }}"
        >
          {{ block.settings.button_text }}
        </a>
      {% endif %}

      {% if block.settings.button_subtext != blank %}
        <div class="ai-transparency-subtext-{{ ai_gen_id }}">
          {{ block.settings.button_subtext }}
        </div>
      {% endif %}
    </div>
  </div>
</transparency-section-{{ ai_gen_id }}>

<script>
  (function() {
    class TransparencySection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.video = this.querySelector('.ai-transparency-video-{{ ai_gen_id }}');
        if (this.video && this.video.hasAttribute('autoplay')) {
          this.setupIntersectionObserver();
        }
      }

      setupIntersectionObserver() {
        const options = {
          root: null,
          rootMargin: '0px',
          threshold: 0.5
        };

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              this.video.play().catch(() => {});
            } else {
              this.video.pause();
            }
          });
        }, options);

        observer.observe(this.video);
      }
    }

    customElements.define('transparency-section-{{ ai_gen_id }}', TransparencySection{{ ai_gen_id }});
  })();
</script>

