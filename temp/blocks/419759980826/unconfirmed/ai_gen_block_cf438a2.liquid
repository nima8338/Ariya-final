{% doc %}
  @prompt
    Create a custom product page section called "Transparency" with two stacked parts in one section, full-width, using our brand colors (deep purple background #(your purple), lavender and white text).
    Top half — the problem:
    
    Large centered statistic: "80%" — displayed in very large type. IMPORTANT: the number must be hardcoded as "80%" in the HTML so it displays correctly even if JavaScript doesn't load. A count-up animation on scroll is optional, but it must never render as "0%" — the static fallback value is 80.
    Headline below the stat: "of herbal supplements tested were mislabeled."
    Supporting line in smaller text: "Wrong doses. Hidden blends. Ingredients that weren't even in the bottle."
    
    Bottom half — the answer (same section, directly below, separated by a subtle divider or color shift):
    
    Two-column layout on desktop (stacked on mobile): left side is an image block (I will upload a photo of our bottle label showing the moon QR code), right side is text.
    Headline: "So we put our entire formula on the bottle."
    Subheadline: "Scan the moon. See everything."
    Body text: "Every ingredient. Every exact dose. Standardized extracts at full potency — verified, with nothing hidden behind a proprietary blend."
    Small caption under the image: "Scan the moon on any Calm Nights bottle — even right off your screen."
    
    Style notes:
    
    Mobile-first: stat should fill the screen width on mobile without overflowing.
    Generous padding between the two halves so each reads as its own moment, but they scroll as one continuous section.
    No buttons in this section — it's an education/trust section, not a CTA.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-transparency-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    color: {{ block.settings.text_color }};
  }

  .ai-transparency-problem-{{ ai_gen_id }} {
    padding: {{ block.settings.problem_padding_mobile }}px 20px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 50vh;
  }

  .ai-transparency-stat-{{ ai_gen_id }} {
    font-size: {{ block.settings.stat_size_mobile }}px;
    font-weight: 700;
    line-height: 1;
    margin: 0 0 {{ block.settings.stat_spacing }}px 0;
    color: {{ block.settings.stat_color }};
    letter-spacing: -0.02em;
  }

  .ai-transparency-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size_mobile }}px;
    font-weight: 600;
    line-height: 1.2;
    margin: 0 0 {{ block.settings.headline_spacing }}px 0;
    max-width: 600px;
  }

  .ai-transparency-supporting-{{ ai_gen_id }} {
    font-size: {{ block.settings.supporting_size_mobile }}px;
    line-height: 1.5;
    margin: 0;
    opacity: 0.9;
    max-width: 500px;
  }

  .ai-transparency-divider-{{ ai_gen_id }} {
    height: 1px;
    background: {{ block.settings.divider_color }};
    opacity: {{ block.settings.divider_opacity | divided_by: 100.0 }};
    margin: 0 auto;
    max-width: {{ block.settings.divider_width }}%;
  }

  .ai-transparency-answer-{{ ai_gen_id }} {
    padding: {{ block.settings.answer_padding_mobile }}px 20px;
    background-color: {{ block.settings.answer_background_color }};
  }

  .ai-transparency-answer-content-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  .ai-transparency-image-block-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ai-transparency-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    max-width: 400px;
    position: relative;
  }

  .ai-transparency-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-transparency-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 1;
    background-color: {{ block.settings.placeholder_bg_color }};
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-transparency-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-transparency-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 8px 16px;
    font-size: 12px;
    color: {{ block.settings.text_color }};
    opacity: 0.7;
    text-align: center;
    pointer-events: none;
  }

  .ai-transparency-caption-{{ ai_gen_id }} {
    font-size: {{ block.settings.caption_size }}px;
    margin-top: 12px;
    opacity: 0.8;
    text-align: center;
  }

  .ai-transparency-text-block-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .ai-transparency-answer-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.answer_headline_size_mobile }}px;
    font-weight: 600;
    line-height: 1.2;
    margin: 0;
  }

  .ai-transparency-answer-subheadline-{{ ai_gen_id }} {
    font-size: {{ block.settings.answer_subheadline_size_mobile }}px;
    font-weight: 500;
    line-height: 1.3;
    margin: 0;
    color: {{ block.settings.subheadline_color }};
  }

  .ai-transparency-answer-body-{{ ai_gen_id }} {
    font-size: {{ block.settings.answer_body_size_mobile }}px;
    line-height: 1.6;
    margin: 0;
    opacity: 0.9;
  }

  @media screen and (min-width: 750px) {
    .ai-transparency-problem-{{ ai_gen_id }} {
      padding: {{ block.settings.problem_padding_desktop }}px 40px;
      min-height: 60vh;
    }

    .ai-transparency-stat-{{ ai_gen_id }} {
      font-size: {{ block.settings.stat_size_desktop }}px;
    }

    .ai-transparency-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size_desktop }}px;
    }

    .ai-transparency-supporting-{{ ai_gen_id }} {
      font-size: {{ block.settings.supporting_size_desktop }}px;
    }

    .ai-transparency-answer-{{ ai_gen_id }} {
      padding: {{ block.settings.answer_padding_desktop }}px 40px;
    }

    .ai-transparency-answer-content-{{ ai_gen_id }} {
      flex-direction: row;
      gap: 60px;
      align-items: center;
    }

    .ai-transparency-image-block-{{ ai_gen_id }} {
      width: 45%;
      flex-shrink: 0;
    }

    .ai-transparency-text-block-{{ ai_gen_id }} {
      width: 55%;
      gap: 20px;
    }

    .ai-transparency-answer-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.answer_headline_size_desktop }}px;
    }

    .ai-transparency-answer-subheadline-{{ ai_gen_id }} {
      font-size: {{ block.settings.answer_subheadline_size_desktop }}px;
    }

    .ai-transparency-answer-body-{{ ai_gen_id }} {
      font-size: {{ block.settings.answer_body_size_desktop }}px;
    }

    .ai-transparency-caption-{{ ai_gen_id }} {
      text-align: left;
    }
  }
{% endstyle %}

<transparency-section-{{ ai_gen_id }} class="ai-transparency-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-transparency-problem-{{ ai_gen_id }}">
    <div class="ai-transparency-stat-{{ ai_gen_id }}" data-stat-value="80">
      {{ block.settings.stat_text }}
    </div>
    <h2 class="ai-transparency-headline-{{ ai_gen_id }}">
      {{ block.settings.problem_headline }}
    </h2>
    <p class="ai-transparency-supporting-{{ ai_gen_id }}">
      {{ block.settings.problem_supporting }}
    </p>
  </div>

  {% if block.settings.show_divider %}
    <div class="ai-transparency-divider-{{ ai_gen_id }}"></div>
  {% endif %}

  <div class="ai-transparency-answer-{{ ai_gen_id }}">
    <div class="ai-transparency-answer-content-{{ ai_gen_id }}">
      <div class="ai-transparency-image-block-{{ ai_gen_id }}">
        <div class="ai-transparency-image-wrapper-{{ ai_gen_id }}">
          {% if block.settings.bottle_image %}
            <img
              src="{{ block.settings.bottle_image | image_url: width: 800 }}"
              alt="{{ block.settings.bottle_image.alt | escape }}"
              loading="lazy"
              width="{{ block.settings.bottle_image.width }}"
              height="{{ block.settings.bottle_image.height }}"
              class="ai-transparency-image-{{ ai_gen_id }}"
            >
          {% else %}
            <div class="ai-transparency-image-placeholder-{{ ai_gen_id }}">
              {{ 'product-1' | placeholder_svg_tag }}
              <div class="ai-transparency-empty-state-{{ ai_gen_id }}">
                Upload your bottle label image
              </div>
            </div>
          {% endif %}
        </div>
        {% if block.settings.image_caption != blank %}
          <p class="ai-transparency-caption-{{ ai_gen_id }}">
            {{ block.settings.image_caption }}
          </p>
        {% endif %}
      </div>

      <div class="ai-transparency-text-block-{{ ai_gen_id }}">
        <h3 class="ai-transparency-answer-headline-{{ ai_gen_id }}">
          {{ block.settings.answer_headline }}
        </h3>
        <p class="ai-transparency-answer-subheadline-{{ ai_gen_id }}">
          {{ block.settings.answer_subheadline }}
        </p>
        <p class="ai-transparency-answer-body-{{ ai_gen_id }}">
          {{ block.settings.answer_body }}
        </p>
      </div>
    </div>
  </div>
</transparency-section-{{ ai_gen_id }}>

<script>
  (function() {
    class TransparencySection{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.statElement = this.querySelector('.ai-transparency-stat-{{ ai_gen_id }}');
        this.hasAnimated = false;
      }

      connectedCallback() {
        if (this.statElement && 'IntersectionObserver' in window) {
          this.setupObserver();
        }
      }

      setupObserver() {
        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting && !this.hasAnimated) {
              this.animateStat();
              this.hasAnimated = true;
            }
          });
        }, {
          threshold: 0.5
        });

        observer.observe(this.statElement);
      }

      animateStat() {
        const targetValue = parseInt(this.statElement.getAttribute('data-stat-value'));
        const duration = 1500;
        const startTime = performance.now();
        const startValue = 0;

        const animate = (currentTime) => {
          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const easeOutQuart = 1 - Math.pow(1 - progress, 4);
          const currentValue = Math.floor(startValue + (targetValue - startValue) * easeOutQuart);

          this.statElement.textContent = currentValue + '%';

          if (progress < 1) {
            requestAnimationFrame(animate);
          } else {
            this.statElement.textContent = targetValue + '%';
          }
        };

        requestAnimationFrame(animate);
      }
    }

    customElements.define('transparency-section-{{ ai_gen_id }}', TransparencySection{{ ai_gen_id }});
  })();
</script>

