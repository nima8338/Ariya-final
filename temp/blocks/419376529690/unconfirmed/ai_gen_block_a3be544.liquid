{% doc %}
  @prompt
    create a header that is center aligned and the headline spans across the whole section, can you make the background color span to the edges of the horizontal left and right
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-full-width-header-{{ ai_gen_id }} {
    display: block;
    width: 100vw;
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw;
    margin-right: -50vw;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-full-width-header__container-{{ ai_gen_id }} {
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
    text-align: center;
  }

  .ai-full-width-header__heading-{{ ai_gen_id }} {
    margin: 0;
    color: {{ block.settings.heading_color }};
    font-size: {{ block.settings.heading_size }}px;
    line-height: 1.2;
    letter-spacing: {{ block.settings.letter_spacing }}px;
    text-transform: {% if block.settings.text_uppercase %}uppercase{% else %}none{% endif %};
    width: 100%;
    padding: 0 {{ block.settings.horizontal_padding }}px;
    box-sizing: border-box;
  }

  @media screen and (max-width: 749px) {
    .ai-full-width-header__heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.6 }}px;
      padding: 0 {{ block.settings.horizontal_padding | times: 0.5 }}px;
    }
  }
{% endstyle %}

<div class="ai-full-width-header-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-full-width-header__container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-full-width-header__heading-{{ ai_gen_id }}">
        {{ block.settings.heading }}
      </h2>
    {% else %}
      <h2 class="ai-full-width-header__heading-{{ ai_gen_id }}">
        Add your headline here
      </h2>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "Full width header",
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1a0a2e"
    },
    {
      "type": "checkbox",
      "id": "text_uppercase",
      "label": "Uppercase text",
      "default": false
    },
    {
      "type": "range",
      "id": "letter_spacing",
      "label": "Letter spacing",
      "min": 0,
      "max": 10,
      "step": 0.5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "horizontal_padding",
      "label": "Horizontal padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Full width header"
    }
  ]
}
{% endschema %}