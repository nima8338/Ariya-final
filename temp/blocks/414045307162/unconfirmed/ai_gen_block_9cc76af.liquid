<script>
  (function() {
    const buttons = document.querySelectorAll('[data-scroll-to-top]');
    
    buttons.forEach(button => {
      button.addEventListener('click', function(e) {
        e.preventDefault();
        window.scrollTo({
          top: 0,
          behavior: 'smooth'
        });
      });
    });
  })();
</script>

