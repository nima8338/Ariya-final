{% doc %}
  @prompt
    give me the option to insert to images one above and one under each other, on the desktop version only can you make the images smaller and have them next to each other instead of vertically , make the images bigger on the desktop version oly, give me the option to adjust the background color
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-stacked-images-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.padding }}px;
  }

  .ai-stacked-images-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.spacing }}px;
    width: 100%;
  }

  .ai-stacked-images-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-stacked-images-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .ai-stacked-images-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    aspect-ratio: {{ block.settings.aspect_ratio }};
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    border-radius: {{ block.settings.border_radius }}px;
  }

  .ai-stacked-images-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 400px;
    max-height: 400px;
  }

  .ai-stacked-images-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (min-width: 750px) {
    .ai-stacked-images-{{ ai_gen_id }} {
      width: {{ block.settings.desktop_width_percent }}%;
    }

    .ai-stacked-images-container-{{ ai_gen_id }} {
      flex-direction: row;
    }

    .ai-stacked-images-wrapper-{{ ai_gen_id }} {
      width: calc((100% - {{ block.settings.spacing }}px) / 2);
    }
  }
{% endstyle %}

<stacked-images-{{ ai_gen_id }}
  class="ai-stacked-images-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-stacked-images-container-{{ ai_gen_id }}">
    <div class="ai-stacked-images-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image_left %}
        <img
          src="{{ block.settings.image_left | image_url: width: 2000 }}"
          alt="{{ block.settings.image_left.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image_left.width }}"
          height="{{ block.settings.image_left.height }}"
        >
      {% else %}
        <div class="ai-stacked-images-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-stacked-images-empty-state-{{ ai_gen_id }}">
            Add left image
          </div>
        </div>
      {% endif %}
    </div>

    <div class="ai-stacked-images-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image_right %}
        <img
          src="{{ block.settings.image_right | image_url: width: 2000 }}"
          alt="{{ block.settings.image_right.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image_right.width }}"
          height="{{ block.settings.image_right.height }}"
        >
      {% else %}
        <div class="ai-stacked-images-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-stacked-images-empty-state-{{ ai_gen_id }}">
            Add right image
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</stacked-images-{{ ai_gen_id }}>

{% schema %}
{
  "name": "Side by side images",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "image_left",
      "label": "Left image"
    },
    {
      "type": "image_picker",
      "id": "image_right",
      "label": "Right image"
    },
    {
      "type": "header",
      "content": "Desktop layout"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "spacing",
      "label": "Spacing between images",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Padding",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "select",
      "id": "aspect_ratio",
      "label": "Image aspect ratio",
      "options": [
        {
          "value": "1 / 1",
          "label": "Square (1:1)"
        },
        {
          "value": "4 / 3",
          "label": "Landscape (4:3)"
        },
        {
          "value": "16 / 9",
          "label": "Wide (16:9)"
        },
        {
          "value": "3 / 4",
          "label": "Portrait (3:4)"
        },
        {
          "value": "auto",
          "label": "Original"
        }
      ],
      "default": "auto"
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Side by side images"
    }
  ]
}
{% endschema %}
