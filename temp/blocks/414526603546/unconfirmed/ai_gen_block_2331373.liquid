{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-accordion-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding_mobile }}px 16px;
  }

  @media screen and (min-width: 750px) {
    .ai-accordion-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_desktop }}px 40px;
    }
  }

  .ai-accordion-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-accordion-header-{{ ai_gen_id }} {
    text-align: {{ block.settings.text_alignment }};
    margin-bottom: {{ block.settings.header_spacing_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-accordion-header-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.header_spacing_desktop }}px;
    }
  }

  .ai-accordion-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size_mobile }}px;
    font-weight: 600;
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.title_spacing }}px 0;
    line-height: 1.2;
  }

  @media screen and (min-width: 750px) {
    .ai-accordion-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size_desktop }}px;
    }
  }

  .ai-accordion-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size_mobile }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    line-height: 1.5;
  }

  @media screen and (min-width: 750px) {
    .ai-accordion-subtitle-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtitle_size_desktop }}px;
    }
  }

  .ai-accordion-items-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.card_spacing }}px;
  }

  .ai-accordion-item-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .ai-accordion-item-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.card_border_hover_color }};
  }

  .ai-accordion-button-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    align-items: center;
    gap: {{ block.settings.icon_spacing }}px;
    padding: {{ block.settings.card_padding_mobile }}px;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background-color 0.2s ease;
  }

  @media screen and (min-width: 750px) {
    .ai-accordion-button-{{ ai_gen_id }} {
      padding: {{ block.settings.card_padding_desktop }}px;
    }
  }

  .ai-accordion-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.card_hover_background }};
  }

  .ai-accordion-icon-wrapper-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: {{ block.settings.icon_background }};
    border-radius: {{ block.settings.icon_border_radius }}px;
  }

  .ai-accordion-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_inner_size }}px;
    height: {{ block.settings.icon_inner_size }}px;
    color: {{ block.settings.icon_color }};
  }

  .ai-accordion-text-wrapper-{{ ai_gen_id }} {
    flex-grow: 1;
  }

  .ai-accordion-item-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.item_title_size_mobile }}px;
    font-weight: 600;
    color: {{ block.settings.item_title_color }};
    margin: 0 0 {{ block.settings.item_title_spacing }}px 0;
    line-height: 1.3;
  }

  @media screen and (min-width: 750px) {
    .ai-accordion-item-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.item_title_size_desktop }}px;
    }
  }

  .ai-accordion-item-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.item_subtitle_size }}px;
    color: {{ block.settings.item_subtitle_color }};
    margin: 0;
    line-height: 1.4;
  }

  .ai-accordion-chevron-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    color: {{ block.settings.chevron_color }};
    transition: transform 0.3s ease;
  }

  .ai-accordion-item-{{ ai_gen_id }}.active .ai-accordion-chevron-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-accordion-content-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
  }

  .ai-accordion-item-{{ ai_gen_id }}.active .ai-accordion-content-{{ ai_gen_id }} {
    max-height: 500px;
    padding: 0 {{ block.settings.card_padding_mobile }}px {{ block.settings.card_padding_mobile }}px {{ block.settings.card_padding_mobile }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-accordion-item-{{ ai_gen_id }}.active .ai-accordion-content-{{ ai_gen_id }} {
      padding: 0 {{ block.settings.card_padding_desktop }}px {{ block.settings.card_padding_desktop }}px {{ block.settings.card_padding_desktop }}px;
    }
  }

  .ai-accordion-content-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.content_size }}px;
    color: {{ block.settings.content_color }};
    line-height: 1.6;
    margin: 0;
    padding-left: calc({{ block.settings.icon_size }}px + {{ block.settings.icon_spacing }}px);
  }

  .ai-accordion-z-wrapper-{{ ai_gen_id }} {
    display: flex;
    align-items: flex-end;
    gap: {{ block.settings.z_spacing }}px;
    position: relative;
  }

  .ai-accordion-z-icon-{{ ai_gen_id }} {
    font-family: {{ block.settings.icon_font_family }}, serif;
    font-size: {{ block.settings.icon_inner_size }}px;
    font-weight: 700;
    font-style: italic;
    color: {{ block.settings.icon_color }};
    line-height: 1;
  }

  .ai-accordion-z-icon-{{ ai_gen_id }}:nth-child(2) {
    position: relative;
    top: -{{ block.settings.z_offset_second }}px;
  }

  .ai-accordion-z-icon-{{ ai_gen_id }}:nth-child(3) {
    position: relative;
    top: -{{ block.settings.z_offset_third }}px;
  }
{% endstyle %}

