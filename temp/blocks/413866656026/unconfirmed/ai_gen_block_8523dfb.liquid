{% doc %}
  @prompt
    Create a New Ingredient Spotlight SectionReplace the current “Inside Calm Nights” accordion section with a visual ingredient grid inspired by premium wellness brands.Section TitleInside Calm NightsSupporting TextEvery ingredient was chosen for a reason. No proprietary blends. No hidden doses.Design StyleCreate a clean card-based ingredient grid similar to premium supplement brands.Each ingredient should appear inside its own card.Each card should include:Real ingredient image (not icons)Ingredient nameSmall benefit badgeOne sentence explanationUse soft shadows, rounded corners, generous spacing, and a premium wellness aesthetic.Cards should stack vertically on mobile and display in a grid on desktop.Use Ariya’s color palette:White backgroundsSoft purple accentsBlack textLight gray bordersConsistent image sizingCard 1L-TheanineBadge:
    Calm MindDescription:Supports relaxation and helps quiet racing thoughts before bed.Image:
    Green tea leaves or L-Theanine source image.Card 2L-TryptophanBadge:
    Sleep SupportDescription:Amino acid that helps support your body’s natural melatonin and serotonin production.Image:
    Salmon image.Card 3Lemon Balm ExtractBadge:
    Stress ReliefDescription:Traditional botanical used to promote calmness and support relaxation.Image:
    Real lemon balm plant.Card 4Chamomile ExtractBadge:
    RelaxationDescription:Well-known herbal extract traditionally used to support restful sleep.Image:
    Chamomile flower.Card 5Magnolia Bark ExtractBadge:
    Deep CalmDescription:Supports relaxation and helps ease mental tension before bed.Image:
    Magnolia tree or magnolia bark.Card 6Tart Cherry ExtractBadge:
    Sleep QualityDescription:Naturally contains compounds that support healthy sleep quality and recovery.Image:
    Tart cherries.Card 7Vitamin B6Badge:
    Sleep PathwaysDescription:Supports neurotransmitter production involved in healthy sleep cycles.Image:
    Sunrise or vitamin-rich food imagery.Layout GoalCreate a highly visual ingredient section that feels premium, educational, and easy to browse without requiring users to tap open individual ingredients.The section should break up the page visually and make the formula feel tangible and trustworthy.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-ingredient-spotlight-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: 60px 20px;
    background-color: {{ block.settings.background_color }};
  }

  .ai-ingredient-spotlight-container-{{ ai_gen_id }} {
    max-width: 1200px;
    margin: 0 auto;
  }

  .ai-ingredient-spotlight-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 48px;
  }

  .ai-ingredient-spotlight-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    color: {{ block.settings.title_color }};
    margin: 0 0 16px;
    font-weight: 600;
  }

  .ai-ingredient-spotlight-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .ai-ingredient-spotlight-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.card_spacing }}px;
  }

  @media screen and (min-width: 750px) {
    .ai-ingredient-spotlight-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat({{ block.settings.columns_desktop }}, 1fr);
    }
  }

  .ai-ingredient-card-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }};
    border-radius: {{ block.settings.card_border_radius }}px;
    padding: {{ block.settings.card_padding }}px;
    box-shadow: {{ block.settings.card_shadow_x }}px {{ block.settings.card_shadow_y }}px {{ block.settings.card_shadow_blur }}px {{ block.settings.card_shadow_color }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .ai-ingredient-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: {{ block.settings.card_shadow_x }}px {{ block.settings.card_shadow_y | plus: 4 }}px {{ block.settings.card_shadow_blur | plus: 8 }}px {{ block.settings.card_shadow_color }};
  }

  .ai-ingredient-card-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: {{ block.settings.image_height }}px;
    margin-bottom: 20px;
    border-radius: {{ block.settings.image_border_radius }}px;
    overflow: hidden;
  }

  .ai-ingredient-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-ingredient-card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-ingredient-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-ingredient-card-badge-{{ ai_gen_id }} {
    display: inline-block;
    padding: 6px 12px;
    background-color: {{ block.settings.badge_background }};
    color: {{ block.settings.badge_text_color }};
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 600;
    border-radius: {{ block.settings.badge_border_radius }}px;
    margin-bottom: 12px;
  }

  .ai-ingredient-card-name-{{ ai_gen_id }} {
    font-size: {{ block.settings.ingredient_name_size }}px;
    color: {{ block.settings.ingredient_name_color }};
    margin: 0 0 12px;
    font-weight: 600;
  }

  .ai-ingredient-card-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    line-height: 1.6;
    margin: 0;
  }
{% endstyle %}

<div class="ai-ingredient-spotlight-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-ingredient-spotlight-container-{{ ai_gen_id }}">
    <div class="ai-ingredient-spotlight-header-{{ ai_gen_id }}">
      {% if block.settings.title != blank %}
        <h2 class="ai-ingredient-spotlight-title-{{ ai_gen_id }}">{{ block.settings.title }}</h2>
      {% endif %}
      {% if block.settings.subtitle != blank %}
        <p class="ai-ingredient-spotlight-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}
    </div>

    <div class="ai-ingredient-spotlight-grid-{{ ai_gen_id }}">
      {% for i in (1..7) %}
        {% liquid
          assign enabled_key = 'ingredient_' | append: i | append: '_enabled'
          assign image_key = 'ingredient_' | append: i | append: '_image'
          assign name_key = 'ingredient_' | append: i | append: '_name'
          assign badge_key = 'ingredient_' | append: i | append: '_badge'
          assign description_key = 'ingredient_' | append: i | append: '_description'

          assign enabled = block.settings[enabled_key]
          assign image = block.settings[image_key]
          assign name = block.settings[name_key]
          assign badge = block.settings[badge_key]
          assign description = block.settings[description_key]
        %}

        {% if enabled %}
          <div class="ai-ingredient-card-{{ ai_gen_id }}">
            <div class="ai-ingredient-card-image-wrapper-{{ ai_gen_id }}">
              {% if image %}
                <img
                  src="{{ image | image_url: width: 600 }}"
                  alt="{{ name | escape }}"
                  class="ai-ingredient-card-image-{{ ai_gen_id }}"
                  loading="lazy"
                  width="600"
                  height="{{ block.settings.image_height }}"
                >
              {% else %}
                <div class="ai-ingredient-card-image-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            </div>

            {% if badge != blank %}
              <div class="ai-ingredient-card-badge-{{ ai_gen_id }}">{{ badge }}</div>
            {% endif %}

            {% if name != blank %}
              <h3 class="ai-ingredient-card-name-{{ ai_gen_id }}">{{ name }}</h3>
            {% endif %}

            {% if description != blank %}
              <p class="ai-ingredient-card-description-{{ ai_gen_id }}">{{ description }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

