{% doc %}
  @prompt
    Create three equal-width columns.
    
    Each column should contain:
    
    Custom uploaded image
    Badge text underneath
    
    I want to upload my own icons/images instead of using built-in icons.
    
    The three default badge texts should be:
    
    30-Day Money-Back Guarantee
    Vegan & Non-GMO
    Free Shipping
    Trust Badge Requirements
    Center align each badge.
    Display the uploaded image above the text.
    Make all uploaded images the same size.
    Keep the images noticeably large and easy to see.
    Keep all three badges evenly spaced.
    Use Ariya Purple #7D45C6 for the badge text.
    Prevent badge text from wrapping whenever possible so each badge stays on a single line.
    The entire row should remain responsive on desktop and mobile.
    Section Customization Options
    Founder Support
    First line text
    Phone number
    First line font size (desktop)
    First line font size (mobile)
    Phone number font size (desktop)
    Phone number font size (mobile)
    First line font weight
    Phone number font weight
    Underline first line (toggle)
    Underline phone number (toggle)
    Text color (first line)
    Phone number color
    Space below founder support
    Badge Settings
    Badge 1 image upload
    Badge 1 text
    Badge 2 image upload
    Badge 2 text
    Badge 3 image upload
    Badge 3 text
    Badge Design Settings
    Text size (desktop)
    Text size (mobile)
    Badge font weight
    Icon size (desktop)
    Icon size (mobile)
    Icon to text spacing
    Badge spacing (desktop)
    Badge spacing (mobile)
    Background color
    Top padding
    Bottom padding
    Side padding
    Desktop width
    Overall Design
    
    The final section should feel premium, clean, and modern, matching the Ariya brand. Keep the layout compact, mobile-first, and conversion-focused with balanced spacing and consistent alignment throughout
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-trust-badges-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.top_padding }}px {{ block.settings.side_padding }}px {{ block.settings.bottom_padding }}px;
  }

  .ai-trust-badges-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.desktop_width_percent }}%;
    margin: 0 auto;
  }

  .ai-trust-badges-founder-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: {{ block.settings.founder_space_below }}px;
  }

  .ai-trust-badges-founder-line1-{{ ai_gen_id }} {
    color: {{ block.settings.founder_line1_color }};
    font-size: {{ block.settings.founder_line1_size_desktop }}px;
    font-weight: {{ block.settings.founder_line1_weight }};
    margin: 0 0 4px 0;
    {% if block.settings.founder_line1_underline %}
      text-decoration: underline;
    {% else %}
      text-decoration: none;
    {% endif %}
  }

  .ai-trust-badges-founder-phone-{{ ai_gen_id }} {
    color: {{ block.settings.founder_phone_color }};
    font-size: {{ block.settings.founder_phone_size_desktop }}px;
    font-weight: {{ block.settings.founder_phone_weight }};
    margin: 0;
    {% if block.settings.founder_phone_underline %}
      text-decoration: underline;
    {% else %}
      text-decoration: none;
    {% endif %}
  }

  .ai-trust-badges-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.badge_spacing_desktop }}px;
    align-items: start;
  }

  .ai-trust-badge-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: {{ block.settings.icon_text_spacing }}px;
  }

  .ai-trust-badge-icon-{{ ai_gen_id }} {
    width: {{ block.settings.icon_size_desktop }}px;
    height: {{ block.settings.icon_size_desktop }}px;
    flex-shrink: 0;
  }

  .ai-trust-badge-icon-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-trust-badge-icon-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 4px;
  }

  .ai-trust-badge-icon-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-trust-badge-text-{{ ai_gen_id }} {
    color: {{ block.settings.badge_text_color }};
    font-size: {{ block.settings.badge_text_size_desktop }}px;
    font-weight: {{ block.settings.badge_font_weight }};
    margin: 0;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    max-width: 100%;
  }

  @media screen and (max-width: 749px) {
    .ai-trust-badges-founder-line1-{{ ai_gen_id }} {
      font-size: {{ block.settings.founder_line1_size_mobile }}px;
    }

    .ai-trust-badges-founder-phone-{{ ai_gen_id }} {
      font-size: {{ block.settings.founder_phone_size_mobile }}px;
    }

    .ai-trust-badges-grid-{{ ai_gen_id }} {
      gap: {{ block.settings.badge_spacing_mobile }}px;
    }

    .ai-trust-badge-icon-{{ ai_gen_id }} {
      width: {{ block.settings.icon_size_mobile }}px;
      height: {{ block.settings.icon_size_mobile }}px;
    }

    .ai-trust-badge-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.badge_text_size_mobile }}px;
    }
  }
{% endstyle %}

<div class="ai-trust-badges-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-trust-badges-container-{{ ai_gen_id }}">
    {% if block.settings.founder_line1 != blank or block.settings.founder_phone != blank %}
      <div class="ai-trust-badges-founder-{{ ai_gen_id }}">
        {% if block.settings.founder_line1 != blank %}
          <p class="ai-trust-badges-founder-line1-{{ ai_gen_id }}">{{ block.settings.founder_line1 }}</p>
        {% endif %}
        {% if block.settings.founder_phone != blank %}
          <p class="ai-trust-badges-founder-phone-{{ ai_gen_id }}">{{ block.settings.founder_phone }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="ai-trust-badges-grid-{{ ai_gen_id }}">
      <div class="ai-trust-badge-item-{{ ai_gen_id }}">
        <div class="ai-trust-badge-icon-{{ ai_gen_id }}">
          {% if block.settings.badge_1_image %}
            <img
              src="{{ block.settings.badge_1_image | image_url: width: 200 }}"
              alt="{{ block.settings.badge_1_text | escape }}"
              loading="lazy"
              width="200"
              height="200"
            >
          {% else %}
            <div class="ai-trust-badge-icon-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        {% if block.settings.badge_1_text != blank %}
          <p class="ai-trust-badge-text-{{ ai_gen_id }}">{{ block.settings.badge_1_text }}</p>
        {% endif %}
      </div>

      <div class="ai-trust-badge-item-{{ ai_gen_id }}">
        <div class="ai-trust-badge-icon-{{ ai_gen_id }}">
          {% if block.settings.badge_2_image %}
            <img
              src="{{ block.settings.badge_2_image | image_url: width: 200 }}"
              alt="{{ block.settings.badge_2_text | escape }}"
              loading="lazy"
              width="200"
              height="200"
            >
          {% else %}
            <div class="ai-trust-badge-icon-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        {% if block.settings.badge_2_text != blank %}
          <p class="ai-trust-badge-text-{{ ai_gen_id }}">{{ block.settings.badge_2_text }}</p>
        {% endif %}
      </div>

      <div class="ai-trust-badge-item-{{ ai_gen_id }}">
        <div class="ai-trust-badge-icon-{{ ai_gen_id }}">
          {% if block.settings.badge_3_image %}
            <img
              src="{{ block.settings.badge_3_image | image_url: width: 200 }}"
              alt="{{ block.settings.badge_3_text | escape }}"
              loading="lazy"
              width="200"
              height="200"
            >
          {% else %}
            <div class="ai-trust-badge-icon-placeholder-{{ ai_gen_id }}">
              {{ 'image' | placeholder_svg_tag }}
            </div>
          {% endif %}
        </div>
        {% if block.settings.badge_3_text != blank %}
          <p class="ai-trust-badge-text-{{ ai_gen_id }}">{{ block.settings.badge_3_text }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</div>

