    "quality_manufacturing": {
      "type": "custom-liquid",
      "settings": {
        "custom_liquid": "<div class=\"ariya-section ariya-quality\">\n  <div class=\"ariya-container\">\n    <div class=\"ariya-quality__header ariya-reveal\">\n      <p class=\"ariya-label\">Manufacturing &amp; Quality</p>\n      <div class=\"ariya-divider ariya-divider--center\"></div>\n      <h2 class=\"ariya-heading ariya-heading--lg\">Tested for Safety &amp; Quality</h2>\n      <p class=\"ariya-body\">Manufactured in Hauppauge, New York, USA. Every batch undergoes testing before release to verify purity, potency, and safety standards.</p>\n    </div>\n\n    <div class=\"ariya-quality__cards\">\n      <div class=\"ariya-quality__card ariya-reveal ariya-delay-1\">\n        <div class=\"ariya-quality__card-icon\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"/><path d=\"M9 12l2 2 4-4\"/></svg></div>\n        <h4>Third-Party Tested</h4>\n        <p>Every batch is independently verified for purity, potency, and safety before release.</p>\n      </div>\n      <div class=\"ariya-quality__card ariya-reveal ariya-delay-2\">\n        <div class=\"ariya-quality__card-icon\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M2 22c1.25-1.25 2.5-3.5 2.5-5A4.5 4.5 0 0 1 9 12.5c1.5 0 3.75 1.25 5 2.5\"/><path d=\"M15 2c-1.25 1.25-2.5 3.5-2.5 5A4.5 4.5 0 0 0 17 11.5c1.5 0 3.75-1.25 5-2.5\"/></svg></div>\n        <h4>Non-GMO &amp; Vegan</h4>\n        <p>All ingredients are plant-derived or synthetically produced. Capsules are vegetable-based.</p>\n      </div>\n      <div class=\"ariya-quality__card ariya-reveal ariya-delay-3\">\n        <div class=\"ariya-quality__card-icon\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2\"/><path d=\"M8.5 2h7\"/></svg></div>\n        <h4>GMP Compliant</h4>\n        <p>Produced in a GMP-compliant, FDA-registered facility with standardized manufacturing protocols.</p>\n      </div>\n      <div class=\"ariya-quality__card ariya-reveal ariya-delay-1\">\n        <div class=\"ariya-quality__card-icon\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><path d=\"M22 11.08V12a10 10 0 1 1-5.93-9.14\"/><path d=\"M22 4L12 14.01l-3-3\"/></svg></div>\n        <h4>Heavy Metal Tested</h4>\n        <p>Screened for heavy metals, microbial contamination, E. coli, yeast, mold, and pesticide residues.</p>\n      </div>\n      <div class=\"ariya-quality__card ariya-reveal ariya-delay-2\">\n        <div class=\"ariya-quality__card-icon\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><rect x=\"3\" y=\"3\" width=\"18\" height=\"18\" rx=\"2\"/><path d=\"M3 9h18M9 21V9\"/></svg></div>\n        <h4>Made in New York</h4>\n        <p>Manufactured in Hauppauge, New York. Made in the USA with full traceability from source to shelf.</p>\n      </div>\n      <div class=\"ariya-quality__card ariya-reveal ariya-delay-3\">\n        <div class=\"ariya-quality__card-icon\"><svg width=\"22\" height=\"22\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\"><circle cx=\"12\" cy=\"12\" r=\"10\"/><path d=\"M12 6v6l4 2\"/></svg></div>\n        <h4>Standardized Extracts</h4>\n        <p>Verified active compounds in every serving. No proprietary blends — exact doses on every label.</p>\n      </div>\n    </div>\n  </div>\n</div>",
