{% doc %}
  @prompt
    create a button that does exaclt what add to cart does but its name is Start Now , the button should add to cart whatever product is selected either one time purchase or subscription
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-start-now-button-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
  }

  .ai-start-now-button-form-{{ ai_gen_id }} {
    width: 100%;
  }

  .ai-start-now-button-submit-{{ ai_gen_id }} {
    width: 100%;
    padding: 15px 30px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    border: {{ block.settings.button_border_width }}px solid {{ block.settings.button_border_color }};
    border-radius: {{ block.settings.button_border_radius }}px;
    font-size: {{ block.settings.button_font_size }}px;
    cursor: pointer;
    transition: all 0.3s ease;
    {% if block.settings.button_text_transform == 'uppercase' %}
      text-transform: uppercase;
    {% endif %}
  }

  .ai-start-now-button-submit-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
    color: {{ block.settings.button_hover_text_color }};
    border-color: {{ block.settings.button_hover_border_color }};
  }

  .ai-start-now-button-submit-{{ ai_gen_id }}:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  @media screen and (max-width: 749px) {
    .ai-start-now-button-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<start-now-button-{{ ai_gen_id }}
  class="ai-start-now-button-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <form
    method="post"
    action="/cart/add"
    class="ai-start-now-button-form-{{ ai_gen_id }}"
    accept-charset="UTF-8"
    enctype="multipart/form-data"
  >
    <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}" class="ai-variant-id-{{ ai_gen_id }}">
    <input type="hidden" name="quantity" value="1">
    <input type="hidden" name="selling_plan" value="" class="ai-selling-plan-{{ ai_gen_id }}">
    <button
      type="submit"
      name="add"
      class="ai-start-now-button-submit-{{ ai_gen_id }}"
      {% unless product.selected_or_first_available_variant.available %}disabled{% endunless %}
    >
      {% if product.selected_or_first_available_variant.available %}
        {{ block.settings.button_text }}
      {% else %}
        {{ block.settings.sold_out_text }}
      {% endif %}
    </button>
  </form>
</start-now-button-{{ ai_gen_id }}>

<script>
  (function() {
    class StartNowButton{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.form = this.querySelector('form');
        this.submitButton = this.querySelector('button[type="submit"]');
        this.variantInput = this.querySelector('.ai-variant-id-{{ ai_gen_id }}');
        this.sellingPlanInput = this.querySelector('.ai-selling-plan-{{ ai_gen_id }}');
      }

      connectedCallback() {
        this.form.addEventListener('submit', this.onSubmitHandler.bind(this));
        this.setupVariantListener();
        this.setupSellingPlanListener();
      }

      setupVariantListener() {
        document.addEventListener('variant:change', (event) => {
          if (event.detail && event.detail.variant) {
            this.variantInput.value = event.detail.variant.id;
            this.updateButtonState(event.detail.variant.available);
          }
        });

        const variantSelects = document.querySelectorAll('variant-selects, variant-radios');
        variantSelects.forEach(selector => {
          selector.addEventListener('change', () => {
            const selectedVariantId = selector.querySelector('input[name="id"]')?.value;
            if (selectedVariantId) {
              this.variantInput.value = selectedVariantId;
            }
          });
        });
      }

      setupSellingPlanListener() {
        const sellingPlanInputs = document.querySelectorAll('input[name="selling_plan"]');
        sellingPlanInputs.forEach(input => {
          input.addEventListener('change', (event) => {
            this.sellingPlanInput.value = event.target.value;
          });
        });

        const initialSellingPlan = document.querySelector('input[name="selling_plan"]:checked');
        if (initialSellingPlan) {
          this.sellingPlanInput.value = initialSellingPlan.value;
        }
      }

      updateButtonState(available) {
        this.submitButton.disabled = !available;
        if (available) {
          this.submitButton.textContent = '{{ block.settings.button_text }}';
        } else {
          this.submitButton.textContent = '{{ block.settings.sold_out_text }}';
        }
      }

      onSubmitHandler(event) {
        event.preventDefault();

        const formData = new FormData(this.form);
        
        if (!this.sellingPlanInput.value) {
          formData.delete('selling_plan');
        }

        const config = {
          method: 'POST',
          headers: {
            'X-Requested-With': 'XMLHttpRequest',
            'Accept': 'application/javascript'
          },
          body: formData
        };

        this.submitButton.disabled = true;

        fetch('/cart/add.js', config)
          .then(response => response.json())
          .then(data => {
            this.submitButton.disabled = false;
            
            if (window.theme && window.theme.cart) {
              window.theme.cart.refresh();
            }
            
            document.dispatchEvent(new CustomEvent('cart:item-added', {
              detail: { product: data }
            }));

            const cartDrawer = document.querySelector('cart-drawer');
            if (cartDrawer) {
              cartDrawer.open();
            } else {
              window.location.href = '/cart';
            }
          })
          .catch(error => {
            console.error('Error:', error);
            this.submitButton.disabled = false;
          });
      }
    }

    customElements.define('start-now-button-{{ ai_gen_id }}', StartNowButton{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Start now button",
  "settings": [
    {
      "type": "header",
      "content": "Button text"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "Start Now"
    },
    {
      "type": "text",
      "id": "sold_out_text",
      "label": "Sold out text",
      "default": "Sold Out"
    },
    {
      "type": "header",
      "content": "Button style"
    },
    {
      "type": "color",
      "id": "button_color",
      "label": "Background color",
      "default": "#3c0e66"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Border color",
      "default": "#3c0e66"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Hover background color",
      "default": "#5a1a9a"
    },
    {
      "type": "color",
      "id": "button_hover_text_color",
      "label": "Hover text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_border_color",
      "label": "Hover border color",
      "default": "#5a1a9a"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Font size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "button_border_width",
      "label": "Border width",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 100
    },
    {
      "type": "select",
      "id": "button_text_transform",
      "label": "Text case",
      "options": [
        {
          "value": "none",
          "label": "Default"
        },
        {
          "value": "uppercase",
          "label": "Uppercase"
        }
      ],
      "default": "none"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Start now button"
    }
  ]
}
{% endschema %}
