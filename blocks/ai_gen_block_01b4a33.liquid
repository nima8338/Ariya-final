{% doc %}
  @prompt
    Create a New “Why Sleep Matters” SectionCreate a new section inspired by the simple statistics layout used by premium wellness brands.LayoutAllow a large image at the top of the section that can be uploaded and changed inside the Shopify editor.Image should be full width with rounded corners.Keep the section clean, minimal, and easy to scan.No icons.No decorative graphics.No extra cards.No animations.Use a simple vertical flow:ImageHeadlineShort supporting textStatistic 1Statistic 2Design StyleWhite backgroundAriya purple for numbers and headingsDark text for descriptionsLarge bold percentagesMinimal spacingMobile-first designInspired by the clean simplicity of Grüns’ statistics sectionContentHeadlineModern Life Makes Restful Sleep Harder Than EverSupporting TextStress, screens, and constant stimulation make it harder to unwind and get quality sleep.Statistic 174%of adults say stress disrupts their sleep.Statistic 272%of adults experience daytime sleepiness linked to:Mood Changes • Increased Stress • Lower ProductivityTypographyPercentages should be the largest element in the section.Headline should be bold and easy to read.Descriptions should be noticeably smaller than the percentages.Center align all content.ImportantKeep this section extremely simple.Do not add icons, badges, symbols, extra statistics, explanations, or feature callouts.The goal is to create a clean, high-impact visual section where the large percentages immediately grab attention, similar to premium wellness brands., at the bottom put this,                                          That’s Why We Created Calm Nights.
    Melatonin-free sleep support designed to quiet a racing mind and help you wake up feeling rested., at the bottom put a SHOP Calm Nights button that when you click it it scrolls back to the very top of the page
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-sleep-stats-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 20px;
  }

  .ai-sleep-stats-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
    text-align: center;
  }

  .ai-sleep-stats-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    margin-bottom: {{ block.settings.spacing_after_image }}px;
  }

  .ai-sleep-stats-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: block;
  }

  .ai-sleep-stats-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: 16 / 9;
    background-color: #f4f4f4;
    border-radius: {{ block.settings.image_border_radius }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-sleep-stats-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-sleep-stats-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  .ai-sleep-stats-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    font-weight: 700;
    color: {{ block.settings.headline_color }};
    margin: 0 0 {{ block.settings.spacing_after_headline }}px 0;
    line-height: 1.2;
  }

  .ai-sleep-stats-subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.subtext_color }};
    margin: 0 0 {{ block.settings.spacing_after_subtext }}px 0;
    line-height: 1.5;
  }

  .ai-sleep-stats-stat-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.spacing_between_stats }}px;
  }

  .ai-sleep-stats-stat-{{ ai_gen_id }}:last-child {
    margin-bottom: {{ block.settings.spacing_after_last_stat }}px;
  }

  .ai-sleep-stats-percentage-{{ ai_gen_id }} {
    font-size: {{ block.settings.percentage_size }}px;
    font-weight: 700;
    color: {{ block.settings.percentage_color }};
    margin: 0 0 {{ block.settings.spacing_after_percentage }}px 0;
    line-height: 1;
  }

  .ai-sleep-stats-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0;
    line-height: 1.5;
  }

  .ai-sleep-stats-closing-{{ ai_gen_id }} {
    margin-top: {{ block.settings.spacing_before_closing }}px;
  }

  .ai-sleep-stats-closing-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.closing_headline_size }}px;
    font-weight: 700;
    color: {{ block.settings.closing_headline_color }};
    margin: 0 0 {{ block.settings.spacing_after_closing_headline }}px 0;
    line-height: 1.2;
  }

  .ai-sleep-stats-closing-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.closing_text_size }}px;
    color: {{ block.settings.closing_text_color }};
    margin: 0 0 {{ block.settings.spacing_after_closing_text }}px 0;
    line-height: 1.5;
  }

  .ai-sleep-stats-button-{{ ai_gen_id }} {
    display: inline-block;
    padding: {{ block.settings.button_padding_vertical }}px {{ block.settings.button_padding_horizontal }}px;
    background-color: {{ block.settings.button_background_color }};
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    text-decoration: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    border: none;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .ai-sleep-stats-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background_color }};
    color: {{ block.settings.button_hover_text_color }};
  }

  @media screen and (max-width: 749px) {
    .ai-sleep-stats-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_mobile }}px 16px;
    }

    .ai-sleep-stats-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size_mobile }}px;
    }

    .ai-sleep-stats-subtext-{{ ai_gen_id }} {
      font-size: {{ block.settings.subtext_size_mobile }}px;
    }

    .ai-sleep-stats-percentage-{{ ai_gen_id }} {
      font-size: {{ block.settings.percentage_size_mobile }}px;
    }

    .ai-sleep-stats-description-{{ ai_gen_id }} {
      font-size: {{ block.settings.description_size_mobile }}px;
    }

    .ai-sleep-stats-closing-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.closing_headline_size_mobile }}px;
    }

    .ai-sleep-stats-closing-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.closing_text_size_mobile }}px;
    }

    .ai-sleep-stats-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size_mobile }}px;
    }
  }
{% endstyle %}

<sleep-stats-{{ ai_gen_id }} class="ai-sleep-stats-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-sleep-stats-container-{{ ai_gen_id }}">
    <div class="ai-sleep-stats-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.image %}
        <img
          src="{{ block.settings.image | image_url: width: 2000 }}"
          alt="{{ block.settings.image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.image.width }}"
          height="{{ block.settings.image.height }}"
          class="ai-sleep-stats-image-{{ ai_gen_id }}"
        >
      {% else %}
        <div class="ai-sleep-stats-image-placeholder-{{ ai_gen_id }}">
          {{ 'lifestyle-1' | placeholder_svg_tag }}
          <div class="ai-sleep-stats-empty-state-{{ ai_gen_id }}">
            Add an image to get started
          </div>
        </div>
      {% endif %}
    </div>

    {% if block.settings.headline != blank %}
      <h2 class="ai-sleep-stats-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
    {% endif %}

    {% if block.settings.subtext != blank %}
      <p class="ai-sleep-stats-subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</p>
    {% endif %}

    {% if block.settings.stat_1_percentage != blank %}
      <div class="ai-sleep-stats-stat-{{ ai_gen_id }}">
        <div class="ai-sleep-stats-percentage-{{ ai_gen_id }}">{{ block.settings.stat_1_percentage }}</div>
        {% if block.settings.stat_1_description != blank %}
          <p class="ai-sleep-stats-description-{{ ai_gen_id }}">{{ block.settings.stat_1_description }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.stat_2_percentage != blank %}
      <div class="ai-sleep-stats-stat-{{ ai_gen_id }}">
        <div class="ai-sleep-stats-percentage-{{ ai_gen_id }}">{{ block.settings.stat_2_percentage }}</div>
        {% if block.settings.stat_2_description != blank %}
          <p class="ai-sleep-stats-description-{{ ai_gen_id }}">{{ block.settings.stat_2_description }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if block.settings.closing_headline != blank or block.settings.closing_text != blank or block.settings.show_button %}
      <div class="ai-sleep-stats-closing-{{ ai_gen_id }}">
        {% if block.settings.closing_headline != blank %}
          <h3 class="ai-sleep-stats-closing-headline-{{ ai_gen_id }}">{{ block.settings.closing_headline }}</h3>
        {% endif %}
        {% if block.settings.closing_text != blank %}
          <p class="ai-sleep-stats-closing-text-{{ ai_gen_id }}">{{ block.settings.closing_text }}</p>
        {% endif %}
        {% if block.settings.show_button %}
          <button class="ai-sleep-stats-button-{{ ai_gen_id }}" data-scroll-to-top>
            {{ block.settings.button_text }}
          </button>
        {% endif %}
      </div>
    {% endif %}
  </div>
</sleep-stats-{{ ai_gen_id }}>

<script>
  (function() {
    class SleepStats{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.button = this.querySelector('[data-scroll-to-top]');
        if (this.button) {
          this.button.addEventListener('click', this.scrollToTop.bind(this));
        }
      }

      scrollToTop() {
        window.scrollTo({
          top: 0,
          behavior: 'smooth'
        });
      }
    }

    customElements.define('sleep-stats-{{ ai_gen_id }}', SleepStats{{ ai_gen_id }});
  })();
</script>

