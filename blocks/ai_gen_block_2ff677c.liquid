{% doc %}
  @prompt
    create 2 insert image option, one should pop up when someone presses one time purchase and the other when someone presses subscription and goes to their cart 
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-cart-purchase-image-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-cart-purchase-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
  }

  .ai-cart-purchase-image-wrapper-{{ ai_gen_id }} img {
    width: 100%;
    height: auto;
    display: block;
  }

  .ai-cart-purchase-image-placeholder-{{ ai_gen_id }} {
    background-color: #f4f4f4;
    width: 100%;
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
  }

  .ai-cart-purchase-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-cart-purchase-image-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    padding: 12px 20px;
    font-size: 14px;
    color: #666;
    text-align: center;
    pointer-events: none;
  }

  @media screen and (max-width: 749px) {
    .ai-cart-purchase-image-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div
  class="ai-cart-purchase-image-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% liquid
    assign has_subscription = false
    for item in cart.items
      if item.selling_plan_allocation != blank
        assign has_subscription = true
        break
      endif
    endfor
  %}

  {% if has_subscription %}
    <div class="ai-cart-purchase-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.subscription_image %}
        <img
          src="{{ block.settings.subscription_image | image_url: width: 1200 }}"
          alt="{{ block.settings.subscription_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.subscription_image.width }}"
          height="{{ block.settings.subscription_image.height }}"
        >
      {% else %}
        <div class="ai-cart-purchase-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-cart-purchase-image-empty-state-{{ ai_gen_id }}">
            Add subscription image
          </div>
        </div>
      {% endif %}
    </div>
  {% else %}
    <div class="ai-cart-purchase-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.one_time_image %}
        <img
          src="{{ block.settings.one_time_image | image_url: width: 1200 }}"
          alt="{{ block.settings.one_time_image.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.one_time_image.width }}"
          height="{{ block.settings.one_time_image.height }}"
        >
      {% else %}
        <div class="ai-cart-purchase-image-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
          <div class="ai-cart-purchase-image-empty-state-{{ ai_gen_id }}">
            Add one-time purchase image
          </div>
        </div>
      {% endif %}
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Purchase type image",
  "settings": [
    {
      "type": "header",
      "content": "One-time purchase"
    },
    {
      "type": "image_picker",
      "id": "one_time_image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Subscription"
    },
    {
      "type": "image_picker",
      "id": "subscription_image",
      "label": "Image"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Purchase type image"
    }
  ]
}
{% endschema %}
