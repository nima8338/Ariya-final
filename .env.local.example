# Shopify Headless Configuration
# Copy this file to .env.local and fill in your credentials.
#
# How to get these:
# 1. Shopify Admin → Apps → Develop apps → Create app
# 2. Configure the app with Storefront API access
# 3. Copy the Public Storefront API access token

NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=your-public-storefront-access-token
